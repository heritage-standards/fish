  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/163426">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/599/concepts/163426</dcterms:identifier>
