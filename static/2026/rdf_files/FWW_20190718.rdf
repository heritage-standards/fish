        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <skos:prefLabel xml:lang="en">Floatplane</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A type of seaplane, with one or more slender pontoons (known as "floats") mounted under the fuselage to provide buoyancy.</skos:scopeNote>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/599"/>
