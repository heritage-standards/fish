  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/163985">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Breaking Down House</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/599"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building within a gunpowder works complex, where the mill cake (pulverised and incorporated ingredients of gunpowder) was broken down. It was crushed or broken down by passing it between pairs of revolving gunmetal rollers in a breaking-down machine.</skos:scopeNote>
    <skos:related>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/163986">
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/599/concepts/163985"/>
        <skos:scopeNote xml:lang="en">A building within the gunpowder works complex. During the gunpowder production process, the mill cake was broken down, pressed and then corned. The remaining dust was removed from the corned powder by tumbling it in gauze-covered revolving cylinders.</skos:scopeNote>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/599/concepts/163986</dcterms:identifier>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/599"/>
        <skos:prefLabel xml:lang="en">Dusting House</skos:prefLabel>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:15:51</dcterms:issued>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/599/concepts/163977"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
      </skos:Concept>
    </skos:related>
