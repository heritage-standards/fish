  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/163750">
    <skos:scopeNote xml:lang="en">A concrete, circular concave dish 20 feet in diameter used as an acoustic listening device to detect approaching enemy aircraft.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
