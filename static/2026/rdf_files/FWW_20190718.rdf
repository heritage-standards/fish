  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/168167">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A French aircraft manufacturer founded by Louis Bleriot and Gabriel Voisin, both aviators and inventors, in 1903, dissolved in 1906. After the First World War Bleriot founded Bleriot Aeronautique developing commercial aircraft.</skos:scopeNote>
