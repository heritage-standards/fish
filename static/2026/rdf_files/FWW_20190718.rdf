    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building or group of buildings, incorporating radio masts, built to intercept radio transmissions from enemy vessels and aircraft during WWI.</skos:scopeNote>
