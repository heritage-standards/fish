  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/599/concepts/168223">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/599/concepts/168221"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/599/concepts/168223</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/599"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">Twin-engine, three-crew, long-range heavy bomber biplane. Entered service in 1917. Of wooden construction with a fabric covering, the Vimy was fitted with a skid under the nose of its fuselage to prevent tipping forward upon landing.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:15:51</dcterms:issued>
    <skos:prefLabel xml:lang="en">Vimy</skos:prefLabel>
