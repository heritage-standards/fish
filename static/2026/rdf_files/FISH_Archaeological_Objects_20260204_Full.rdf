  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96055">
    <skos:scopeNote xml:lang="en">A knife used for sacrifices.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96058">
    <skos:scopeNote xml:lang="en">A string of beads used to aid the memory in reciting a set of devotions.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96066">
    <skos:scopeNote xml:lang="en">An ornament at the top of a roof or spire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96067">
    <skos:scopeNote xml:lang="en">An architectural ornament usually surmounting the apex of a gable, canopy or roof.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96070">
    <skos:scopeNote xml:lang="en">A brick made of clay which is difficult to fuse, used in boilers and fireplaces.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96071">
    <skos:scopeNote xml:lang="en">A layer of impervious material, such as lead or bitumen, usually placed between a wall and a roofline to exclude water.Impervious material to exclude water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96072">
    <skos:scopeNote xml:lang="en">The lower surface of a room.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96075">
    <skos:scopeNote xml:lang="en">A tile used within a floor.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96080">
    <skos:scopeNote xml:lang="en">A metal or wooden framework suspended within an opening in an external wall, fence, hedge etc, to allow ingress or egress.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96084">
    <skos:scopeNote xml:lang="en">A curved roofing tile.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96085">
    <skos:scopeNote xml:lang="en">A horizontal beam over an opening to support a wall.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96089">
    <skos:scopeNote xml:lang="en">An ornamental decoration which projects from the surface it is part of.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96093">
    <skos:scopeNote xml:lang="en">A fence made of pales.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96095">
    <skos:scopeNote xml:lang="en">An individual section of panelling. Can form fences, ceilings, an outer layer to a wall etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96102">
