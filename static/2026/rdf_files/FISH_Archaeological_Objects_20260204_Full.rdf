  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100048">
    <skos:scopeNote xml:lang="en">Pieces of leather connected to a bridle designed to direct a horse's vision straight forward only.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100049">
    <skos:scopeNote xml:lang="en">Lenses worn in a frame designed to improve or protect the vision of the wearer.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100051">
    <skos:scopeNote xml:lang="en">The hood used to completely cover a hawk's head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100052">
    <skos:scopeNote xml:lang="en">A head cover which can be attached to a piece of outerwear, eg a coat, or can be separate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100054">
