  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96308">
    <skos:scopeNote xml:lang="en">A three sided or U-shaped metal fastener on which the ends are pointed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96310">
    <skos:scopeNote xml:lang="en">A plug for closing the neck of a container.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96311">
    <skos:scopeNote xml:lang="en">A thin strip of material used for binding.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96313">
    <skos:scopeNote xml:lang="en">A sharp pointed nail with a large flat head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96314">
    <skos:scopeNote xml:lang="en">A device to limit the amount of liquid coming from a pipe or hole.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96315">
