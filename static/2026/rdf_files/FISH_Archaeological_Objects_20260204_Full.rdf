  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96930">
    <skos:scopeNote xml:lang="en">A tool, usually metal, with roughened surfaces in the form of very small teeth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96932">
