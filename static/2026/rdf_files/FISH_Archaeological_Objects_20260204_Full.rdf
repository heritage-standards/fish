  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95988">
    <skos:scopeNote xml:lang="en">A religious receptacle, especially Jewish where it contains four Hebrew texts worn during morning prayers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95989">
