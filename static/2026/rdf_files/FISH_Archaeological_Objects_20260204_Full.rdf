  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95990">
    <skos:scopeNote xml:lang="en">A tablet with a handle fitted to the back of it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95991">
    <skos:scopeNote xml:lang="en">A plate used in the Eucharist.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95992">
    <skos:scopeNote xml:lang="en">A religious cloth often used to cover coffins.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95993">
    <skos:scopeNote xml:lang="en">An object that contains bones. Use a monuments thesaurus where this is a site type.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95996">
    <skos:scopeNote xml:lang="en">A ring used in the marriage ceremony.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95999">
    <skos:scopeNote xml:lang="en">A flat level structure, can be part of a series, used to allow a person to move from one level to another, or can occur singularly on a threshold.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96001">
    <skos:scopeNote xml:lang="en">The spanning of an opening without the use of a lintel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96002">
    <skos:scopeNote xml:lang="en">Fragments of a structure, usually material that has been worked.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96004">
    <skos:scopeNote xml:lang="en">A vertical pillar or post, often shaped.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96006">
    <skos:scopeNote xml:lang="en">A load carrying horizontal structural member.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96007">
    <skos:scopeNote xml:lang="en">A hollow or rectangular block which acts as a flue allowing the passage of gases or heat.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96008">
