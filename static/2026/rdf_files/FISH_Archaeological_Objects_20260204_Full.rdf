  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97653">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137051">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97653"/>
        <skos:scopeNote xml:lang="en">A fragment of a vessel, or hollow object, usually of ceramic or glass. If known, use specific vessel type.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137052">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97653"/>
        <skos:scopeNote xml:lang="en">A fragment of the rim of a vessel, or hollow object, usually of ceramic or glass. If known, use specific vessel type.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137053">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97653"/>
        <skos:scopeNote xml:lang="en">A fragment of the base of a vessel, or hollow object, usually of ceramic or glass. If known, use specific vessel type.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137054">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97653"/>
        <skos:scopeNote xml:lang="en">A fragment of the body of a vessel, or hollow object, usually of ceramic or glass. If known, use specific vessel type.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">Use specific form where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100086">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142883">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/100086"/>
        <skos:scopeNote xml:lang="en">A ring, flange or short piece of pipe, made of iron, clay or other materials, used to join and seal two sections of water pipe.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A pipe allowing the passage of water through it and designed only for this.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100107">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152464">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/100107"/>
        <skos:scopeNote xml:lang="en">A portable writing-case or surface, especially one for use on the lap. May contain compartments for storing writing materials and paper.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A flat surface often with drawers used for working upon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100151">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143226">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/100151"/>
        <skos:scopeNote xml:lang="en">A piece of wire or similarly flexible material shaped to form a clip for fastening papers together; invented by the Norwegian Johann Vaaler in 1899.  The familiar double-oval 'Gem' clip was developed by Gem Manufacturing Ltd. in England the same year.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A thin vegetable based sheet used for writing, drawing, printing etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141203">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142892">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/141203"/>
        <skos:scopeNote xml:lang="en">Use for the remains of internal parasites of vertebrates, including humans, such as flukes, tapeworm, including their calcified cysts, etc. Eggs of the nematodes Ascaris sp. (maw-worm) and Trichuris sp. (whipworm) are commonly reported.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">Remains of parasitic or free-living worms of the phylum Nematoda, characterized as having slender, cylindrical unsegmented bodies. Cysts of Heterodera commonly occur archaeologically</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148301">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141192">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/148301"/>
        <skos:scopeNote xml:lang="en">A collection of associated artefacts recovered from a single site.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">Objects found buried alongside the dead in graves.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95060">
    <skos:scopeNote xml:lang="en">A style of dressing including all the clothes, accessories etc worn at one time, as in a particular country or period.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95074">
    <skos:scopeNote xml:lang="en">The remains of any part of any animal. Use specific term where possible.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95088">
    <skos:scopeNote xml:lang="en">Use for the remains of an egg whether from a bird, reptile or amphibian.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95091">
    <skos:scopeNote xml:lang="en">Use for the remains of any part of a fish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95093">
    <skos:scopeNote xml:lang="en">Use for the remains of any part of a human.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95094">
    <skos:scopeNote xml:lang="en">Use for the remains of any part of an insect.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95096">
    <skos:scopeNote xml:lang="en">Use for the remains of any part of a mollusc. Use more specific term if known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95098">
    <skos:scopeNote xml:lang="en">The remains of the shell of an oyster.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95105">
    <skos:scopeNote xml:lang="en">Pieces of bone used in a game, the pieces are thrown and then picked up between bounces of a small ball or throws of another piece.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95106">
    <skos:scopeNote xml:lang="en">A ball of chalk found on Neolithic sites.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95108">
    <skos:scopeNote xml:lang="en">A precious or semi precious stone used within jewellery.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95128">
    <skos:scopeNote xml:lang="en">Use for the remains of any part of a bird.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95132">
    <skos:scopeNote xml:lang="en">The weapon end of an arrow, often shaped for particular uses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95133">
    <skos:scopeNote xml:lang="en">A tube through which missiles are blown.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95136">
    <skos:scopeNote xml:lang="en">A thick heavy weapon used to strike the opponent.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95137">
    <skos:scopeNote xml:lang="en">A bow, fixed to a stock, with a mechanism to fire the bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95138">
    <skos:scopeNote xml:lang="en">A short stabbing weapon with a pointed blade. In Medieval period daggers served a dual function being also used as knives.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95140">
    <skos:scopeNote xml:lang="en">A long spear designed to be thrown in order to injure or kill a given target.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95141">
    <skos:scopeNote xml:lang="en">A long spear used on horseback.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95143">
    <skos:scopeNote xml:lang="en">A single edged sword.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95144">
    <skos:scopeNote xml:lang="en">A projectile or group of projectiles fired from a weapon, usually solid rather than explosive.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95145">
    <skos:scopeNote xml:lang="en">A long shafted weapon with a pointed head used for thrusting or as a missile.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95147">
    <skos:scopeNote xml:lang="en">An object made to hurl a spear further and faster than possible by hand.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95150">
    <skos:scopeNote xml:lang="en">A fencing sword often used for recreational purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95152">
    <skos:scopeNote xml:lang="en">A flag or military symbolic representation on a pole.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95153">
    <skos:scopeNote xml:lang="en">A container used to hold ammunition.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95156">
    <skos:scopeNote xml:lang="en">Protective covering for the body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95158">
    <skos:scopeNote xml:lang="en">Piece of armour worn to protect the back, often permanently connected to the breastplate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95160">
    <skos:scopeNote xml:lang="en">A stone missile fired from a ballista, larger in diameter than ballista shot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95161">
    <skos:scopeNote xml:lang="en">A large bolt or arrow fired from a ballista.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95162">
