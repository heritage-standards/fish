  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96316">
    <skos:scopeNote xml:lang="en">An iron rod with both ends sharpened and turned down, used for holding timbers together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96317">
    <skos:scopeNote xml:lang="en">A wooden cylinder or dowel used for pinning planks or timbers together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96318">
    <skos:scopeNote xml:lang="en">A hook with a spiked tang which allows it to be driven into a vertical surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96319">
    <skos:scopeNote xml:lang="en">A small disc or flat ring of metal, wood or leather.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96320">
    <skos:scopeNote xml:lang="en">A tent especially one made of bark, rushes or skins spread over a set of arched poles that are lashed together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96321">
    <skos:scopeNote xml:lang="en">An object attached to a window which is removable.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96336">
