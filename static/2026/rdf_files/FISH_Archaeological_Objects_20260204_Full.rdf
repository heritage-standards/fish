  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96621">
    <skos:scopeNote xml:lang="en">Clothing worn on the upper body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96622">
    <skos:scopeNote xml:lang="en">A garment used to wrap around a person.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96623">
    <skos:scopeNote xml:lang="en">A band worn around the leg to hold up a sock or stocking.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96624">
    <skos:scopeNote xml:lang="en">A form of belt or sash worn to hold in garments.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96625">
    <skos:scopeNote xml:lang="en">An opaque, rigid sheath used to cover the penis. Not usually contraceptive and not for obvious visual display.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96626">
    <skos:scopeNote xml:lang="en">A covering for the leg which fits closely.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96628">
    <skos:scopeNote xml:lang="en">Dress designed to be worn for theatrical purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96629">
    <skos:scopeNote xml:lang="en">A piece of material worn as a band around the arm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96630">
    <skos:scopeNote xml:lang="en">A band of leather, cloth etc worn usually around the waist to support clothing, carry weapons, pouches, tools etc or as a decoration.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96632">
    <skos:scopeNote xml:lang="en">A piece of material, eg metal, cloth, leather etc, added to a button to enhance or embellish it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96633">
    <skos:scopeNote xml:lang="en">A neck band or necklace worn tightly around the throat.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96634">
    <skos:scopeNote xml:lang="en">A piece of material worn around the neck. Where it is a collar for an animal use animal collar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96635">
    <skos:scopeNote xml:lang="en">The bottom part of a sleeve, can be ornamental.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96637">
    <skos:scopeNote xml:lang="en">A square of fabric tied around the neck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96638">
    <skos:scopeNote xml:lang="en">A piece of fabric worn tied or knotted around the neck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96639">
    <skos:scopeNote xml:lang="en">A cylinder of fur or cloth into which the hands are placed to keep warm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96640">
    <skos:scopeNote xml:lang="en">A covering for the hand.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96641">
    <skos:scopeNote xml:lang="en">An object which fastens cross ways.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96642">
    <skos:scopeNote xml:lang="en">A garment hook having a flat plate, often decorated, with two or more holes for attachment and a hooked projection. The term is often used for early Medieval examples.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96643">
    <skos:scopeNote xml:lang="en">An object designed to be the end of a lace or simimlar to aid the insertion of the lace through a loop or eyelet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96644">
    <skos:scopeNote xml:lang="en">Two discs at the end of a short shank, used to fasten shirt fronts, collars etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96645">
    <skos:scopeNote xml:lang="en">A small pin or stud worn in the lapel, often decorative.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96646">
    <skos:scopeNote xml:lang="en">A projection used to clip clothing together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96647">
    <skos:scopeNote xml:lang="en">A projecting stud which fastens into a socket.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96648">
    <skos:scopeNote xml:lang="en">A pin worn to hold two or more pieces of material together, often when being worn as clothing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96650">
    <skos:scopeNote xml:lang="en">An ornamental chain, worn around the ankle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96651">
    <skos:scopeNote xml:lang="en">A purse, sometimes of bronze, usually worn on the forearm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96652">
    <skos:scopeNote xml:lang="en">A band or bracelet worn around the arm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96653">
    <skos:scopeNote xml:lang="en">A flexible container with an opening at one end.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96654">
    <skos:scopeNote xml:lang="en">Ornamental band or chain worn around the arm or wrist.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96662">
    <skos:scopeNote xml:lang="en">Any brooch with the pin sprung or hinged at one end and the catchplate at the other end of a curved or flat bow. Can be one or two piece construction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96663">
    <skos:scopeNote xml:lang="en">An ornament made of thin plates of gold or silver, with repousse ornament.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96665">
    <skos:scopeNote xml:lang="en">Ornament often with a hinged pin and catch, worn fastened to clothing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96666">
    <skos:scopeNote xml:lang="en">A specific type of early medieval pin. Do not use in instances where a pin has become detached from the brooch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96667">
    <skos:scopeNote xml:lang="en">Clasp for fastening together two loose ends.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96674">
    <skos:scopeNote xml:lang="en">A stud used for fastening an item usually used for clothing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96675">
    <skos:scopeNote xml:lang="en">A fastener made of a metal circle connected to a metal loop fixed to an object and used to fasten to another object by means of a button or a loop. The usage of these items is unclear, could include use for animals or for dress.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96676">
    <skos:scopeNote xml:lang="en">A medallion, as on a brooch or ring, with a stone which is often semi precious with a device carved in relief.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96677">
    <skos:scopeNote xml:lang="en">A large portable container used for carrying items such as clothes, papers etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96679">
    <skos:scopeNote xml:lang="en">A circular ornament worn on the head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96683">
    <skos:scopeNote xml:lang="en">A small object designed to hold together the two ends of a cuff.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96684">
    <skos:scopeNote xml:lang="en">Ornamentation worn specifically for formalised dancing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96685">
    <skos:scopeNote xml:lang="en">A hook to join parts of clothing together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96686">
    <skos:scopeNote xml:lang="en">An ornament for the ear, usually clipped to the lobe or fastened through a hole pierced in the lobe.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96687">
    <skos:scopeNote xml:lang="en">An ornamental shoulder piece, usually a badge of military office.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96688">
    <skos:scopeNote xml:lang="en">A small hole for a lace, cord or hook to be passed through.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96691">
    <skos:scopeNote xml:lang="en">A circular band, usually metal, worn on the finger for ornamentation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96692">
    <skos:scopeNote xml:lang="en">A fob can consist of a chain and or a ring.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96696">
    <skos:scopeNote xml:lang="en">Protective eyewear.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96697">
    <skos:scopeNote xml:lang="en">Decorative ornamentation worn in the hair.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96698">
    <skos:scopeNote xml:lang="en">A wig, toupee or section of extra hair designed to replace or enhance the wearer's real hair giving greater quantity, bulk or length.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96699">
    <skos:scopeNote xml:lang="en">A pin used to hold hair in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96700">
    <skos:scopeNote xml:lang="en">A ring used to hold hair in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96701">
    <skos:scopeNote xml:lang="en">A comb or slide used to hold hair in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96703">
    <skos:scopeNote xml:lang="en">A piece of fabric for wiping the nose, face or hands.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96705">
    <skos:scopeNote xml:lang="en">Decorative ornamentation worn on the head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96706">
    <skos:scopeNote xml:lang="en">An object, often including gems and ornamentation, used as an adornment, usually on a person.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96707">
    <skos:scopeNote xml:lang="en">Part of a piece of jewellery.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96710">
    <skos:scopeNote xml:lang="en">A small ornamental case, usually on a necklace or chain, that holds a picture, keepsake etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96712">
    <skos:scopeNote xml:lang="en">Early Bronze Age assumed to be a neck ornament, crescent moon shaped, often gold and elaborately decorated.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96713">
    <skos:scopeNote xml:lang="en">A large medal.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96714">
    <skos:scopeNote xml:lang="en">A melon shaped bead.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96715">
    <skos:scopeNote xml:lang="en">A ring worn around the neck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96716">
    <skos:scopeNote xml:lang="en">A chain, band or cord, often bearing beads, pearls, jewels etc worn around the neck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96717">
    <skos:scopeNote xml:lang="en">A light weight umbrella used as a sun shade.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96718">
    <skos:scopeNote xml:lang="en">Breast ornament</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96719">
    <skos:scopeNote xml:lang="en">A circular or sub circular brooch with an attached pin. There is a gap in the circular part of the brooch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96720">
    <skos:scopeNote xml:lang="en">A ring with separated, often ornamented, terminals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96721">
    <skos:scopeNote xml:lang="en">A supended ornament.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96722">
    <skos:scopeNote xml:lang="en">A small bag or detachable outside pocket.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96723">
    <skos:scopeNote xml:lang="en">A small bag or pouch for carrying money, especially coins.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96728">
    <skos:scopeNote xml:lang="en">A projecting starched frill worn around the neck, especially 16th century.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96729">
    <skos:scopeNote xml:lang="en">Long piece of silk etc worn around waist or over one shoulder often as a symbol of rank.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96730">
    <skos:scopeNote xml:lang="en">A band of material worn around the neck, waist or shoulder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96731">
    <skos:scopeNote xml:lang="en">A decorative clasp to fix sleeve cuffs together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96735">
    <skos:scopeNote xml:lang="en">A long stick or rod used as an aid in walking, climbing etc. Where it is a weapon use quarterstaff or staff weapon. Where there is another use, use the appropriate term eg surveying staff.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96736">
    <skos:scopeNote xml:lang="en">A long scarf or shawl.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96737">
    <skos:scopeNote xml:lang="en">A decorative panel worn over the chest and stomach by both men and women in the 16th century and later only by women.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96738">
    <skos:scopeNote xml:lang="en">A semi circular jewelled headdress for formal occasions.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96739">
    <skos:scopeNote xml:lang="en">Woman's fur cape for the shoulders.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96740">
    <skos:scopeNote xml:lang="en">Long stole worn by Anglican clergy during a service.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96741">
    <skos:scopeNote xml:lang="en">A ring worn on a toe.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96745">
    <skos:scopeNote xml:lang="en">A folding circular cover on a stick held in the hand for protection against rain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96747">
    <skos:scopeNote xml:lang="en">A stick used as an aid or accessory when walking.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96748">
    <skos:scopeNote xml:lang="en">A band worn around the wrist as a bracelet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96750">
    <skos:scopeNote xml:lang="en">Storage vessel, usually a two handled narrow necked jar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96752">
    <skos:scopeNote xml:lang="en">A tool for removing the core from an apple.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96753">
    <skos:scopeNote xml:lang="en">Used for holding water and washing hands, usually in the shape of an animal.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96754">
    <skos:scopeNote xml:lang="en">A straight sided drinking vessel, usually with a wide mouth and without handles.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96755">
    <skos:scopeNote xml:lang="en">A round container open at the top, usually to hold liquids.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96757">
    <skos:scopeNote xml:lang="en">A large pot used for boiling.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96759">
    <skos:scopeNote xml:lang="en">A large, flat dish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96760">
    <skos:scopeNote xml:lang="en">A device with two flat plates and a mechanism used to force the plates together, to  help solidify milk products in cheese making.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96761">
    <skos:scopeNote xml:lang="en">A stick for agitating milk in a butter churn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96762">
    <skos:scopeNote xml:lang="en">A pan with a perforated bottom for straining or rinsing food.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96764">
    <skos:scopeNote xml:lang="en">A stone or stone platform in a fire upon which cooking vessels are placed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96765">
