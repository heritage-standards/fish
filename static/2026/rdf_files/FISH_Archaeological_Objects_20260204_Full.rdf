<?xml version="1.0" encoding="utf-8" ?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:skos="http://www.w3.org/2004/02/skos/core#"
         xmlns:dc="http://purl.org/dc/terms/"
         xmlns:cc="http://creativecommons.org/ns#">

  <skos:ConceptScheme rdf:about="http://purl.org/heritagedata/schemes/mda_obj">
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-04</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/mda_obj</dc:identifier>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:title xml:lang="en">FISH Archaeological Objects Thesaurus</dc:title>
    <dc:description xml:lang="en">Originally developed by the Archaeological Objects Working Party and published by the mda. It provides guidance for the recording of archaeological objects in Britain and Ireland covering all historical periods. Now maintained by FISH on behalf of the heritage sector.</dc:description>
    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95054">
        <skos:scopeNote xml:lang="en">Objects associated with the care and use of animals.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95055">
        <skos:scopeNote xml:lang="en">Objects associated with cultivation, the rearing of livestock, gathering, hunting, fishing, horticulture and the primary processing of foodstuffs.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95056">
        <skos:scopeNote xml:lang="en">Objects forming fragments or parts of a building's fabric, structures and associated services, eg drain pipes. Where an object is a fixture or fitting use the separate class.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95064">
        <skos:scopeNote xml:lang="en">Soft coverings and associated objects for walls, furniture, floors and windows. Also items such as chairs, beds, and cupboards.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95069">
        <skos:scopeNote xml:lang="en">Objects used or associated with the movement of goods or people.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95070">
        <skos:scopeNote xml:lang="en">Objects which cannot be assigned to any one particular class, or the function of which is unknown.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95654">
        <skos:scopeNote xml:lang="en">Objects used for, or associated with, the production of heat and light.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96751">
        <skos:scopeNote xml:lang="en">Objects used for the preparation of food and drink,for cooking and consumption.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96817">
        <skos:scopeNote xml:lang="en">An object which serves as a vessel. This class includes containers for which the function is either specific or unknown. Where the function is known, the term is also included within another class, eg churn.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96982">
        <skos:scopeNote xml:lang="en">Tools and equipment with a specific function and those for which a function cannot be assigned with any degree of certainty. Where the function is known, the term is also included under the relevant Class.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97083">
        <skos:scopeNote xml:lang="en">Protective covering for personal defence, objects designed to kill, injure or overwhelm an opponent or quarry, and ancillary equipment.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97085">
        <skos:scopeNote xml:lang="en">Animal, vegetable and mineral remains including edible materials, drink or residues and unworked imported objects which have been retrieved from archaeological contexts. Also soil samples taken for environmental analysis.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97086"/>
    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97087">
        <skos:scopeNote xml:lang="en">Objects used for the preparation of medicines or the diagnosis and treatment of ill health or disease.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97088">
        <skos:scopeNote xml:lang="en">Instruments and their component parts used to produce music or audible signals of all forms.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97089">
        <skos:scopeNote xml:lang="en">Objects used or associated with religious, ritual or funerary activities.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97090">
        <skos:scopeNote xml:lang="en">Objects used or associated with sport and games, eg gaming piece. This class includes toys.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97209"/>
    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97212">
        <skos:scopeNote xml:lang="en">Objects used to transmit a definite message through a visual non written means, includes stamps and matrices to create these.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97581">
        <skos:scopeNote xml:lang="en">Objects used in, or which are created as part of, a manufacturing or production process, including the by-products of such processes. This does not include finished items, these will appear in other appropriate classes.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97685">
        <skos:scopeNote xml:lang="en">Objects used or associated with the transmission of ideas and information through the written medium.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97692">
        <skos:scopeNote xml:lang="en">Objects used to secure buildings, furniture or objects or used in the finishing and (non-structural) decoration of buildings, equipment and furniture.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/99614">
        <skos:scopeNote xml:lang="en">Objects relating to the punishment and restraint of humans.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100075">
        <skos:scopeNote xml:lang="en">Clothes, items of attire and ornament and objects for personal use by individuals, including toiletries.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

    <skos:hasTopConcept>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100141">
        <skos:scopeNote xml:lang="en">Objects denoting membership and/or authority. Including objects associated with ceremonial rites or symbolising secular power.</skos:scopeNote>
        <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
      </rdf:Description>
    </skos:hasTopConcept>

  </skos:ConceptScheme>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95131">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95142">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95131"/>
        <skos:scopeNote xml:lang="en">A holder for arrows.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96911">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95131"/>
        <skos:scopeNote xml:lang="en">A stone grooved on one face thought to have been used to straighten and smooth arrow shafts.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97100">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95131"/>
        <skos:scopeNote xml:lang="en">A weapon for shooting arrows.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A projectile fired from a bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95135">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97340"/>
    <skos:scopeNote xml:lang="en">A projectile discharged from a weapon, usually a firearm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97340">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95135"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95200">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97340"/>
        <skos:scopeNote xml:lang="en">A metal sphere, usually lead, fired from a musket. Often bound into a cartridge.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A mould in which bullets or musket balls are cast.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95159">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95221"/>
    <skos:scopeNote xml:lang="en">A sash or belt worn over the shoulder to the hip for carrying a sword.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95221">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95159"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95222"/>
    <skos:scopeNote xml:lang="en">A cutting and thrusting weapon consisting of a blade and a hilt. The blade varies in length and width and the cutting edge can vary from being purely the point to being one or both sides or a combination of these.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95166">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95222"/>
    <skos:scopeNote xml:lang="en">A short stabbing weapon, designed to be fixed to the muzzle of a musket or rifle, even in some cases to pistols. Some were designed to be used both fixed to long guns and independent of them.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95222">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95166"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95221"/>
    <skos:scopeNote xml:lang="en">A belt worn around the waist from which a sword is hung. Where worn over the shoulder use baldric.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95172">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/143484"/>
    <skos:scopeNote xml:lang="en">A heavy artillery piece consisting of a metal tube mounted on a gun  carriage.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143484">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95172"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95523">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/143484"/>
        <skos:scopeNote xml:lang="en">An instrument with a series of pipes at different pitches, the air being produced by bellows, and pipes selected by keyboard or sliders.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A plug to keep out dust, moisture etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95208">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95235"/>
    <skos:scopeNote xml:lang="en">A container for loose gun powder. Sometimes with a regulator to release enough powder for one shot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95235">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95208"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95209">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95235"/>
        <skos:scopeNote xml:lang="en">A horn used to hold loose gun powder for recharging firearms.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95212">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95235"/>
        <skos:scopeNote xml:lang="en">A flask holding gunpowder used to prime a firearm, ie to provide a small quantity of gunpowder to be put in the pan which would be lit to set off  the main charge in the barrel. The powder would often be a finer grade than that used for the charge.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96885">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95235"/>
        <skos:scopeNote xml:lang="en">A horn containing gun powder used for priming a firearm.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A handheld weapon that fires missiles by means of explosives.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95214">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97093"/>
    <skos:scopeNote xml:lang="en">A rigid holder for a bladed weapon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97093">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95214"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96820">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97093"/>
        <skos:scopeNote xml:lang="en">A container in which weapons are put for storage and or transportation.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A weapon with a sharp edge or point.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95215">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95241">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95215"/>
        <skos:scopeNote xml:lang="en">A convex, usually round, piece of metal or other material mounted at the centre of a shield. Originally serving  a practical purpose in deflecting blows and providing a mounting for the grip, it later developed into an ornamental feature.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A protective piece of armour carried in the hand to protect the bearer from weapons.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95217">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95218">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95217"/>
        <skos:scopeNote xml:lang="en">A missile fired from a sling.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A hand held weapon used to throw missiles such as stones or bullets.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95297">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96950">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95297"/>
        <skos:scopeNote xml:lang="en">A thin, pointed implement used for sewing with a hole at the blunt end for threading the sewing material.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">An instrument used for surgery, which is the treatment of injuries by instruments and manually.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95330">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/145062">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95330"/>
        <skos:scopeNote xml:lang="en">A key for winding a clockwork mechanism.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">An instrument for measuring time.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95364">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95423"/>
    <skos:scopeNote xml:lang="en">One of a set, used as standards for specific coins, often bearing stamps and other marks of authenticity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95423">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95364"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96994">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95423"/>
        <skos:scopeNote xml:lang="en">A block of metal with a device cut into it, used to impress a coin blank.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97349">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95423"/>
        <skos:scopeNote xml:lang="en">A mould used to cast coins.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/136753">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95423"/>
        <skos:scopeNote xml:lang="en">A metal disc before it is stamped to become a coin.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A piece of metal, usually cast, struck or stamped, with a definite value.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95398">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95403"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95400">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95398"/>
        <skos:scopeNote xml:lang="en">A small, usually hinged, box made of copper alloy which protected a seal.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A piece of wax, lead, paper etc, with a stamped design, attached to a document as a guarantee of authenticity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95403">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95398"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95402">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95403"/>
        <skos:scopeNote xml:lang="en">The object used to make impressions in wax as seals.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">Wax used to seal letters, envelopes, documents, etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95424">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97209"/>
    <skos:scopeNote xml:lang="en">A piece of cast metal obtained from a mould in a form suitable for storage.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97209">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95424"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97086"/>
    <skos:scopeNote xml:lang="en">Objects primarily intended to be used as a medium of exchange, eg coins.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/mda_obj"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95426">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97452">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95426"/>
        <skos:scopeNote xml:lang="en">A marker used to represent a gambling stake.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A metal counter used in calculation of financial sums but not itself directly exchangeable for coins, goods or services.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95520">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170768">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95520"/>
        <skos:scopeNote xml:lang="en">A triangular piece of wood, usually of ebony, to which the lower ends of the strings of a musical instrument are fastened.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">An instrument played mainly by bowing the strings. Use narrower terms where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95573">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97647">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95573"/>
        <skos:scopeNote xml:lang="en">A pipe used for smoking tobacco.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A pouch for containing tobacco.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95609">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96849"/>
    <skos:scopeNote xml:lang="en">A basket for the storage and transport of fishing equipment. For the storage and transport of fish use creel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96849">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95609"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97681">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96849"/>
        <skos:scopeNote xml:lang="en">A tool, piece of equipment, container or other object used for or in fishing.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A wickerwork basket for holding fish or catching lobsters.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95650">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137057">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95650"/>
        <skos:scopeNote xml:lang="en">An object used for counting, keeping count or marking the position of a player in a game, usually in the form of a small circular-shaped piece of bone, metal, wood, plastic or other material.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A marker used in the playing of a game.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95758">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97341">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95758"/>
        <skos:scopeNote xml:lang="en">A narrow flake which is the by-product of making a burin.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A graving tool used for engraving objects. Prehistoric versions are usually made of flint or other stone, later versions usually of metal.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95824">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97417">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95824"/>
        <skos:scopeNote xml:lang="en">An Egyptian religious statuette.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A small carved or sculpted figure.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95830">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96079">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95830"/>
        <skos:scopeNote xml:lang="en">A spout allowing water to spill away from a building. Usually carved in images of animals, people or grotesques.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A three dimensional representation of an object, person or animal.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95886">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97661"/>
    <skos:scopeNote xml:lang="en">An urn containing a cremation burial.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97661">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95886"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97305">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97661"/>
        <skos:scopeNote xml:lang="en">A vessel for keeping the ashes of the dead after cremation.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">The burnt remains of a corpse.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95939">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96057">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95939"/>
        <skos:scopeNote xml:lang="en">A stone inscribed or marked with runes.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A stone used for divination.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95971">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96060">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95971"/>
        <skos:scopeNote xml:lang="en">A flail used for the mortification of the flesh.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A form of whip or lash, often used for self mortification.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95979">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96031">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95979"/>
        <skos:scopeNote xml:lang="en">A container for a pyx which is often a canopied niche in a wall.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A container in which the Sacrament is carried.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96054">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96543">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96054"/>
        <skos:scopeNote xml:lang="en">An object fixed to the door or floor to limit the amount a door can open.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A barrier used to close an opening, usually hinged and often hung within a supporting frame.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96063">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96065">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96063"/>
        <skos:scopeNote xml:lang="en">A container for holy relics.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A cross connected to a reliquary or containing a relic itself.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96126">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96290">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96126"/>
        <skos:scopeNote xml:lang="en">A floor composed of small cubes (tesserae) of variously coloured materials (eg tile, stone, marble). In the Roman period, mosaics often depict a religious theme or symbol.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A cube of material used to make up a mosaic.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96129">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96132">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96129"/>
        <skos:scopeNote xml:lang="en">A fastener used within a cavity wall to hold the two sides together.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97638">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96129"/>
        <skos:scopeNote xml:lang="en">A single or pair of figures or plates attached to a joist or bar either at the time of construction or later and built into the wall to provide support.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A vertical structure usually made of stone, brick, timber, etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96146">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96410"/>
    <skos:scopeNote xml:lang="en">A mortar used specifically for grinding cosmetics.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96410">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96146"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96392"/>
    <skos:scopeNote xml:lang="en">A mixing or grinding vessel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96147">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96392"/>
    <skos:scopeNote xml:lang="en">A pestle used specifically for grinding cosmetics.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96392">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96147"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96410"/>
    <skos:scopeNote xml:lang="en">A tool for pounding or grinding.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96278">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317"/>
    <skos:scopeNote xml:lang="en">An object which is going to become a key. It has the shape but has not been cut to fit a lock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96278"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96279"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96287"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96678">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317"/>
        <skos:scopeNote xml:lang="en">A short chain or chains attached to a woman's belt for carrying keys etc.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96695">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317"/>
        <skos:scopeNote xml:lang="en">T shaped piece of bronze imitating a key and hung from a chatelaine.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A device for operating a lock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96279">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96287"/>
    <skos:scopeNote xml:lang="en">An object which surrounds or makes up a keyhole.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96287">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96279"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96283">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96287"/>
        <skos:scopeNote xml:lang="en">A shaped rod which passed through a hole in the door and was used to raise a latch or to slide a bolt.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97317"/>
    <skos:scopeNote xml:lang="en">A security device attached to objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96377">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97667"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141914">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96377"/>
        <skos:scopeNote xml:lang="en">A knife prior to undergoing the processes of sharpening or finishing, consisting of a single piece of metal from which the blade and tang have been shaped.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A cutting blade with handle used for food preparation and consumption.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97667">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96377"/>
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97253">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97667"/>
        <skos:scopeNote xml:lang="en">A leaf or diamond-shaped arrowhead with shallow retouching at the edges.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A large flake or blade blank thinned on both faces to form an approximate leaf shape. Precise function unknown.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96399">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97322">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96399"/>
        <skos:scopeNote xml:lang="en">Waste flakes and cores produced in the manufacture of stone implements.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A struck piece of flint or other stone where the length is at least twice the width.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96517">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151833">
        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/96517"/>
        <skos:scopeNote xml:lang="en">A two dimensional image using paint applied to the surface of a ceiling.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A painting executed directly onto a wall.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96553">
