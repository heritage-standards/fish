  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/99650">
    <skos:scopeNote xml:lang="en">A bayonet designed to plug into the muzzle of a musket or rifle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/99651">
    <skos:scopeNote xml:lang="en">A bayonet designed to fit over the muzzle of a musket or rifle, allowing the gun still to be fired.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/99652">
    <skos:scopeNote xml:lang="en">A long hollow tube used to blow molten glass into shapes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100011">
