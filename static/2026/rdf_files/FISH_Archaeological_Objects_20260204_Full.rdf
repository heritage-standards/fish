  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97693">
    <skos:scopeNote xml:lang="en">An object used in lighting a fire, lamp, oven, candle etc.</skos:scopeNote>
