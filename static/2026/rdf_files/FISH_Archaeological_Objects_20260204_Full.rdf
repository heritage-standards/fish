    <skos:scopeNote xml:lang="en">An amulet containing a charm in the shape of a scarab.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97312">
    <skos:scopeNote xml:lang="en">An ancient Egyptian gem cut in the shape of a scarab beetle and engraved with symbols on its flat side.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97313">
    <skos:scopeNote xml:lang="en">A ring containing a scarab shape.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97314">
    <skos:scopeNote xml:lang="en">A stone basin for containing holy water often set in inside walls of a church, especially near the entrance.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97315">
    <skos:scopeNote xml:lang="en">An Egyptian container for holding the entrails of a mummy.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97316">
    <skos:scopeNote xml:lang="en">A screen of wood or stone, used to divide the nave from the choir.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97318">
    <skos:scopeNote xml:lang="en">Any object which bears an inscription.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97319">
    <skos:scopeNote xml:lang="en">A rail used to suspend objects from.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97320">
    <skos:scopeNote xml:lang="en">A container used in the distilling process to catch the distilled liquid.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97321">
    <skos:scopeNote xml:lang="en">A flake of stone struck from the core where the length is less than twice the width.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97323">
    <skos:scopeNote xml:lang="en">An object showing signs of being worked. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97324">
    <skos:scopeNote xml:lang="en">An object used in the sublimation process. It is pear shaped with both ends open.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97325">
    <skos:scopeNote xml:lang="en">A stone blade with one edge blunted.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97326">
    <skos:scopeNote xml:lang="en">A small stone blade with one edge blunted.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97328">
    <skos:scopeNote xml:lang="en">A bone or antler point with rows of barbs, usually on one side only.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97329">
    <skos:scopeNote xml:lang="en">A type of helmet with a hinged visor.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97330">
    <skos:scopeNote xml:lang="en">A gaming implement usually used in conjunction with a ball.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97332">
    <skos:scopeNote xml:lang="en">A long seat usually without a back.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97333">
    <skos:scopeNote xml:lang="en">A rough table usually for working upon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97334">
    <skos:scopeNote xml:lang="en">A cage for containing birds.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97335">
    <skos:scopeNote xml:lang="en">A material resulting from the smelting of iron ore.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97336">
    <skos:scopeNote xml:lang="en">A belt used to confine a hawk's wings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97337">
    <skos:scopeNote xml:lang="en">A collective name for the pans and fire bars used in the making of salt through evaporation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97344">
    <skos:scopeNote xml:lang="en">A war trumpet, usually Iron Age.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97347">
    <skos:scopeNote xml:lang="en">Ash and partially fused residues from a coal fired furnace or fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97348">
    <skos:scopeNote xml:lang="en">An item used to fasten a cloak either to another garment or to itself.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97350">
    <skos:scopeNote xml:lang="en">A device with a spirally twisted shaft, pointed end and handle for removing corks from bottles.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97351">
    <skos:scopeNote xml:lang="en">A machine for freeing the cotton from the plant.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97353">
    <skos:scopeNote xml:lang="en">A staff with a bent head used by a shepherd. For a crook used by a bishop use crozier.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97354">
    <skos:scopeNote xml:lang="en">An iron bar used as a lever.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97356">
    <skos:scopeNote xml:lang="en">A small shallow cup used in assaying gold or silver.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97358">
    <skos:scopeNote xml:lang="en">A container in which  dice are shaken and from which dice are thrown.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97359">
    <skos:scopeNote xml:lang="en">A form of dagger.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97360">
    <skos:scopeNote xml:lang="en">A container used with an alembic as part of the distilling process.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97364">
    <skos:scopeNote xml:lang="en">An object used to catch fish. The line is tied in the middle of the fish gorge which then lodges in the throat after the fish has swallowed it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97365">
    <skos:scopeNote xml:lang="en">An axehead of flint or other stone commonly used for Neolithic types.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97367">
    <skos:scopeNote xml:lang="en">A bronze axehead of earlier Bronze Age date the sides of which are raised, either by casting or hammering, to form flanges on both faces which aid hafting. Some types also feature a raised bar or stop between the flanges.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97368">
    <skos:scopeNote xml:lang="en">An axehead of early Bronze Age date, made of copper or bronze, which is flat on both sides and generally lacks side flanges or other hafting aids.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97369">
    <skos:scopeNote xml:lang="en">An instrument for letting blood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97371">
    <skos:scopeNote xml:lang="en">Any form of fastener used to fasten a girdle together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97372">
    <skos:scopeNote xml:lang="en">Weight used for weighing specific quantities and qualities of gold.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97373">
    <skos:scopeNote xml:lang="en">A metal grid, usually iron, used to support pots over a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97376">
    <skos:scopeNote xml:lang="en">A small, handled axe.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97377">
    <skos:scopeNote xml:lang="en">A very small spoon used to provide liquid to mix with ink on an ink stone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97378">
    <skos:scopeNote xml:lang="en">A stand or tray for ink bottles and or pens</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97379">
    <skos:scopeNote xml:lang="en">A kind of stone used in making ink.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97380">
    <skos:scopeNote xml:lang="en">A cage specifically designed to hold insects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97383">
    <skos:scopeNote xml:lang="en">A kind of scourge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97388">
    <skos:scopeNote xml:lang="en">A fishing spear with two heads to grip fish between.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97389">
    <skos:scopeNote xml:lang="en">A shackle for the hand.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97390">
    <skos:scopeNote xml:lang="en">A by-product of the production of microliths.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97395">
    <skos:scopeNote xml:lang="en">A vessel to contain the wafers used in the Eucharist.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97396">
    <skos:scopeNote xml:lang="en">A clasp on a cope.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97397">
    <skos:scopeNote xml:lang="en">A flat based stone used in conjunction with a grinding stone</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97399">
    <skos:scopeNote xml:lang="en">An astronomical instrument for telling the time at night. The date is set on the nocturnal then its pointers lined up with the Pole Star and the two primary stars in the Great Bear, thus allowing an approximate time to be read off.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97401">
    <skos:scopeNote xml:lang="en">An example from which another object is made.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97404">
    <skos:scopeNote xml:lang="en">The blade or sharp-pointed head attached to the end of a spear's shaft.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97405">
    <skos:scopeNote xml:lang="en">An axehead of flint or other stone, commonly used for Neolithic types.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97406">
    <skos:scopeNote xml:lang="en">A stone tool, often only polished on the edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97407">
    <skos:scopeNote xml:lang="en">A type of spur which ends in a point, blunt or sharp, which is used to aid control of an animal eg a horse.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97408">
    <skos:scopeNote xml:lang="en">A type of spike, often on candlesticks.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97410">
    <skos:scopeNote xml:lang="en">An initially worked quern that is still to be finished.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97411">
    <skos:scopeNote xml:lang="en">A tool for smoothing objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97412">
    <skos:scopeNote xml:lang="en">One or more ropes or straps attached to an animal's head to provide guidance and control.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97418">
    <skos:scopeNote xml:lang="en">A by-product usually from the smelting process.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97419">
    <skos:scopeNote xml:lang="en">A collar, usually metal, used to signify slavery and to inhibit freedom, usually with a chain attached.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97420">
    <skos:scopeNote xml:lang="en">A gun using an explosive propellant to fire sharpened metal shafts, usually fired through water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97421">
    <skos:scopeNote xml:lang="en">A tool, possibly for cleaning mud from parts of a plough.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97422">
    <skos:scopeNote xml:lang="en">A closed chamber used for heating or baking objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97424">
    <skos:scopeNote xml:lang="en">The fittings or parts on a strap.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97425">
    <skos:scopeNote xml:lang="en">A small round shield.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97426">
    <skos:scopeNote xml:lang="en">An instrument of torture used to compress one or both thumbs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97427">
    <skos:scopeNote xml:lang="en">An African cloth garment.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97428">
    <skos:scopeNote xml:lang="en">A chisel ended flaked axehead common in the Mesolithic.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97429">
    <skos:scopeNote xml:lang="en">A shallow dish or plate used to serve main meals off or to serve sweetmeats, these usually being painted with devices and riddles.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97430">
    <skos:scopeNote xml:lang="en">A clay cone, part of a furnace.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97432">
    <skos:scopeNote xml:lang="en">A medical container for collecting urine for study.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97433">
    <skos:scopeNote xml:lang="en">An object which has been rejected eg due to being misshapen, spoilt etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97440">
    <skos:scopeNote xml:lang="en">Items which are used in clothing but which are not necessarily a separate item of clothing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97441">
    <skos:scopeNote xml:lang="en">A general tool used to beat objects with.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97443">
    <skos:scopeNote xml:lang="en">A vessel for collecting tears.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97444">
    <skos:scopeNote xml:lang="en">A container used in the preparartion of food.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97446">
    <skos:scopeNote xml:lang="en">A two pronged spear for catching eels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97448">
    <skos:scopeNote xml:lang="en">An object used to provide heat for various purposes eg to cook or to heat a room etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97449">
    <skos:scopeNote xml:lang="en">An object used in the lighting of an area.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97450">
    <skos:scopeNote xml:lang="en">Tools used to maintain a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97453">
    <skos:scopeNote xml:lang="en">An intially worked object, prepared to be made into a final product.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97454">
    <skos:scopeNote xml:lang="en">An object belonging to, used by, or related exclusively to one person and normally carried or kept privately by that person.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97455">
    <skos:scopeNote xml:lang="en">A nail of distinctive form, specifically used in the shoeing of animals, eg horses, donkeys, oxen.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97456">
    <skos:scopeNote xml:lang="en">A crosspiece fastened over the necks of two or more animals, often oxen, and attached to the plough or cart to be drawn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97457">
    <skos:scopeNote xml:lang="en">A frame shaped to fit around the neck and shoulders of a person for carrying buckets. Usually made of wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97484">
    <skos:scopeNote xml:lang="en">An item that cannot be identified. Use more specific term, if possible.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97485">
    <skos:scopeNote xml:lang="en">A decorative piece connected to the altar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97486">
    <skos:scopeNote xml:lang="en">A square, wooden drinking vessel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97488">
    <skos:scopeNote xml:lang="en">Glass which has been coloured and decorated by painting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97489">
    <skos:scopeNote xml:lang="en">Curved, interlocking roof tile of S-shaped section usually made of clay or concrete.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97490">
    <skos:scopeNote xml:lang="en">An object which has words inscribed, engraved carved or written upon it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97493">
    <skos:scopeNote xml:lang="en">A bead used to create a space or interval within a necklace.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97494">
    <skos:scopeNote xml:lang="en">A mounting or fitting attached to a chariot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97500">
    <skos:scopeNote xml:lang="en">A small shovel for adding or placing coals onto a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97501">
    <skos:scopeNote xml:lang="en">A pair of tongs used for placing coals onto a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97502">
    <skos:scopeNote xml:lang="en">A weight made to be hung from a steelyard.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97503">
    <skos:scopeNote xml:lang="en">A small container for holding oil, vinegar, salt etc for use at the table.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97504">
    <skos:scopeNote xml:lang="en">An object used in the Eucharist.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97507">
    <skos:scopeNote xml:lang="en">A stone used to cover a grave.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97508">
    <skos:scopeNote xml:lang="en">A piece of bone used for divination.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97509">
    <skos:scopeNote xml:lang="en">A die used in divination.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97510">
    <skos:scopeNote xml:lang="en">An item with both secular and religious signifigance.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97511">
    <skos:scopeNote xml:lang="en">A tablet, often made of lead, on which curses are written. Sometimes the tablet is transfixed with a nail.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97513">
    <skos:scopeNote xml:lang="en">A type of spur with the goad in the form of a rotating disc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97516">
    <skos:scopeNote xml:lang="en">A form of bronze axehead of middle or late Bronze Age date in which narrow, high flanges on both faces are hammered over to enclose the axe haft. Some types feature a side loop to further assist hafting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97517">
    <skos:scopeNote xml:lang="en">A discoidal flint tool often has a ground edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97524">
    <skos:scopeNote xml:lang="en">A rod, often of antler, with a hole through it and decorated.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97526">
    <skos:scopeNote xml:lang="en">Characteristic waste flakes struck off in the production of axes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97529">
    <skos:scopeNote xml:lang="en">A specialised fitting for Roman armour. For a part of a garment use APRON.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97532">
    <skos:scopeNote xml:lang="en">A machine for creating bails of straw.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97533">
    <skos:scopeNote xml:lang="en">A piece of iron cut from blooms and lengths of bar, probably for transportation, which were then reworked.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97534">
    <skos:scopeNote xml:lang="en">A wheeled open box for carrying loads.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97536">
    <skos:scopeNote xml:lang="en">An object constructed to allow birds to bathe in it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97537">
    <skos:scopeNote xml:lang="en">An object designed to hold food for birds.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97538">
    <skos:scopeNote xml:lang="en">An object used in the preparation of a body following death. It was used to plug the orifices of the body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97540">
    <skos:scopeNote xml:lang="en">Flint which has been burnt. It is not necessarily worked.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97541">
    <skos:scopeNote xml:lang="en">A three dimensional representation usually done in wood, ivory or stone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97542">
    <skos:scopeNote xml:lang="en">Waste products ensuing from the casting process.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97552">
    <skos:scopeNote xml:lang="en">The piece of stone or flint remaining after flakes have been produced. This is a by-product of tool manufacture.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97553">
    <skos:scopeNote xml:lang="en">A flint blade with negative impressions of removals on one side of the dorsal surface, creating a crest. These constitute part of a previously worked striking platfom or result from preparing the flaked surface on a core before detaching flakes or blades.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97554">
    <skos:scopeNote xml:lang="en">A guard or cover put in front of a fire to prevent embers or flames setting fire to a building.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97555">
    <skos:scopeNote xml:lang="en">A metal or ceramic cover for an open fire or hearth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97558">
    <skos:scopeNote xml:lang="en">A tool for creating holes in the ground in which to plant seeds or plants.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97559">
    <skos:scopeNote xml:lang="en">An object of Bronze Age date, usually of gold, with an unknown function.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97565">
    <skos:scopeNote xml:lang="en">A piece of metal in front of a fire to stop embers rolling onto the carpet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97566">
    <skos:scopeNote xml:lang="en">Knapped or ground stone/flint tool where the specific type is unknown. Use more specific type where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97568">
    <skos:scopeNote xml:lang="en">Part of the glass making process, the frit is broken up into a crucible and heated to create glass.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97571">
    <skos:scopeNote xml:lang="en">A fan designed to fan the coals of a fire to increase the oxygen around the coals and thus to help the fire burn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97572">
    <skos:scopeNote xml:lang="en">A small rake used to move the embers of a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97573">
    <skos:scopeNote xml:lang="en">The debris resulting from the production of glass.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97574">
    <skos:scopeNote xml:lang="en">A slender, cylindrical object. Use specific types of rod where possible. Where it is a rod of material which is part of a production process, eg a glass rod, use rod and enter the material in an object material field.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97575">
    <skos:scopeNote xml:lang="en">A container to hold and/or apply grease.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97576">
    <skos:scopeNote xml:lang="en">A small spherical bell for fastening onto the leg of a hawk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97578">
    <skos:scopeNote xml:lang="en">Ornamentation fixed to a horse's harness.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97579">
    <skos:scopeNote xml:lang="en">A by-product created during the manufacture of a tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97580">
    <skos:scopeNote xml:lang="en">A by-product created through a manufacturing process. This does not include the production of tools, for this use tool by product.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97582">
    <skos:scopeNote xml:lang="en">A nodule of iron pyrites used to create fire in combination with tinder and flint or another nodule of iron pyrites.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97583">
    <skos:scopeNote xml:lang="en">The vertical side of a window, archway, doorway or fireplace.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97584">
    <skos:scopeNote xml:lang="en">Waste material from a kiln</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97586">
    <skos:scopeNote xml:lang="en">A set of two or more pins joined together by a chain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97590">
    <skos:scopeNote xml:lang="en">A fitting incorporating a series of overlapping flaps providing ventilation or transmission of sound.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97592">
    <skos:scopeNote xml:lang="en">A early match made of a piece of wood and an inflammable substance, lit by friction between the inflammable substance and a rough surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97593">
    <skos:scopeNote xml:lang="en">The remains of a manufacturing process.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97595">
    <skos:scopeNote xml:lang="en">An inscribed tablet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97596">
    <skos:scopeNote xml:lang="en">An ornamental tablet of brass. Use a materials thesaurus where brass is a material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97597">
    <skos:scopeNote xml:lang="en">The debris resulting from metal working processes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97598">
    <skos:scopeNote xml:lang="en">A deliberate miniaturised replica of an object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97601">
    <skos:scopeNote xml:lang="en">A blank for a knife that has not been hammered out.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97602">
    <skos:scopeNote xml:lang="en">A tool for cleaning a person's nails.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97606">
    <skos:scopeNote xml:lang="en">An object that has been cut off.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97607">
    <skos:scopeNote xml:lang="en">A bowl in which an offering is made.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97608">
    <skos:scopeNote xml:lang="en">A dish in which an offering is made.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97609">
    <skos:scopeNote xml:lang="en">A jar that contains an offering.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97610">
    <skos:scopeNote xml:lang="en">A plate on which an offering is made.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97611">
    <skos:scopeNote xml:lang="en">A tray on which an offering is made.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97612">
    <skos:scopeNote xml:lang="en">An object which has one or more holes through it. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97614">
    <skos:scopeNote xml:lang="en">A support for an arch, lintel, beam etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97615">
    <skos:scopeNote xml:lang="en">A detached vertical structure acting as support to a superstructure. Where a pillar is a separate monument, use a monument type thesaurus.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97616">
    <skos:scopeNote xml:lang="en">A freestanding pole, stake etc often used to support a superstructure.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97620">
    <skos:scopeNote xml:lang="en">The tool used to create a mark on pottery by the potter.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97621">
    <skos:scopeNote xml:lang="en">The original pattern/type of an object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97623">
    <skos:scopeNote xml:lang="en">A tool with one or more serrated edges.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97625">
    <skos:scopeNote xml:lang="en">A weight used to sink a fishing line or a net in water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97626">
    <skos:scopeNote xml:lang="en">A slate tablet, often framed in wood, for writing purposes. Use a materials thesaurus to record the material type slate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97631">
    <skos:scopeNote xml:lang="en">A small pierced disc which glitters, used as ornamentation on clothing</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97637">
    <skos:scopeNote xml:lang="en">A piece of metal or timber holding two elements together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97639">
    <skos:scopeNote xml:lang="en">A container for the storage of tobacco.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97649">
    <skos:scopeNote xml:lang="en">A stone used to test how genuine an object is by rubbing the object against the stone, particularly used for testing gold and silver.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97651">
    <skos:scopeNote xml:lang="en">A container with three legs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97652">
    <skos:scopeNote xml:lang="en">A vessel consisting of three small pots joined, often on a hollow ring, at the base.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97654">
    <skos:scopeNote xml:lang="en">A wedge shaped stone used in an arch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97656">
    <skos:scopeNote xml:lang="en">A container, usually ceramic, used to water plants.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97658">
    <skos:scopeNote xml:lang="en">A metal thread.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97660">
    <skos:scopeNote xml:lang="en">Use specific type where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97662">
    <skos:scopeNote xml:lang="en">A container with a human face appliqued onto it, often used as a funerary vessel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97666">
    <skos:scopeNote xml:lang="en">A metal ring which joins the jess to the leash. The owner's name is often on the vervel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97668">
    <skos:scopeNote xml:lang="en">A prepared core from which a single flake or blade has been produced. The technique was primarily used in the Palaeolithic and Neolithic.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97669">
    <skos:scopeNote xml:lang="en">A flake produced from a carefully prepared core.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97672">
    <skos:scopeNote xml:lang="en">A container for dried foodstuffs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97673">
    <skos:scopeNote xml:lang="en">A container filled with musket balls, metal fragments, nails etc. Designed to kill or maim the enemy at a close range.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97675">
    <skos:scopeNote xml:lang="en">A rod used to measure the imperial measurements of a pole or a perch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97676">
    <skos:scopeNote xml:lang="en">A projection which can be used to lift or suspend an object, often used as a handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97677">
    <skos:scopeNote xml:lang="en">A piece of armour used to protect the armpit.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97680">
    <skos:scopeNote xml:lang="en">Equipment used in the preparation and maintenance of ground, and in the planting and maintenance of crops.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97682">
    <skos:scopeNote xml:lang="en">An object used in the harvesting or mowing of crops etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97684">
    <skos:scopeNote xml:lang="en">Objects used to thresh and winnow crops.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97686">
    <skos:scopeNote xml:lang="en">A pipe used for smoking where the smoke passes through water.</skos:scopeNote>
  </rdf:Description>

