  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97073">
    <skos:scopeNote xml:lang="en">An appliance for holding an object while work is done on it, usually has a pair of jaws.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97075">
