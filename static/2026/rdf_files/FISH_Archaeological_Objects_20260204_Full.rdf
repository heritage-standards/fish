        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97632"/>
        <skos:scopeNote xml:lang="en">A woven fabric used to trim clothes.</skos:scopeNote>
      </rdf:Description>
    </skos:related>

