    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/97252"/>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97103">
    <skos:altLabel xml:lang="en">Wrist Guard</skos:altLabel>
    <skos:altLabel xml:lang="en">Bracer</skos:altLabel>
    <skos:altLabel xml:lang="en">Arm Piece</skos:altLabel>
    <skos:altLabel xml:lang="en">Vambrace</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/mda_obj/concepts/95838"/>
  </rdf:Description>

