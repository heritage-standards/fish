      </rdf:Description>
    </skos:related>

    <skos:scopeNote xml:lang="en">A pipe in which a substance is smoked.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97632">
    <skos:related>
      <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97634">
