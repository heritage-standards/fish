  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96363">
    <skos:scopeNote xml:lang="en">A container made of interwoven strips of pliable materials, such as cane or reed, often carried by a handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96364">
