    <skos:scopeNote xml:lang="en">An object that is to become a padlock key. It has the correct shape but has yet to be cut to fit the lock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96295">
