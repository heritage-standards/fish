  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96369">
    <skos:scopeNote xml:lang="en">A container in which plants are grown.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96370">
    <skos:scopeNote xml:lang="en">A revolving stone used to sharpen or polish by grinding.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96371">
    <skos:scopeNote xml:lang="en">A small flake or blade with a series of notches along the edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96372">
    <skos:scopeNote xml:lang="en">A flake or blade tool with more than one notch on its edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96373">
    <skos:scopeNote xml:lang="en">A very small flint or other stone tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96374">
    <skos:scopeNote xml:lang="en">A tool of flint or other stone, usually worked bifacially, and thought to be a fairly general purpose tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96375">
    <skos:scopeNote xml:lang="en">A bronze axehead of middle or late Bronze Age date in which the side flanges and the bar/stop on both faces are connected, forming a single hafting aid. For palstaves with side loops use looped palstave.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96378">
    <skos:scopeNote xml:lang="en">A flint tool with a convex top and flat base.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96379">
    <skos:scopeNote xml:lang="en">A tool with a sharp tapering end used for piercing materials or as a weapon point.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96380">
    <skos:scopeNote xml:lang="en">A container, usually round and deep.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96381">
    <skos:scopeNote xml:lang="en">The point or tine of a fork.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96382">
    <skos:scopeNote xml:lang="en">A device for winding and casting a fishing line, consisting of a revolving spool with a handle attached to a fishing rod.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96383">
    <skos:scopeNote xml:lang="en">A flake that has had small flakes removed to blunt, sharpen, refine the outline or prepare the edge of the tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96385">
    <skos:scopeNote xml:lang="en">A tool used to filter solid material from liquid by means of a mesh, net or sheet with holes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96386">
    <skos:scopeNote xml:lang="en">A narrow container, especially one in which food or water for animals is put.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96387">
    <skos:scopeNote xml:lang="en">A large container for holding or storing liquids.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96390">
    <skos:scopeNote xml:lang="en">A small, heavy object used for keeping loose papers in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96391">
    <skos:scopeNote xml:lang="en">A container used to hold substances for dying or painting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96393">
    <skos:scopeNote xml:lang="en">A long usually cylindrical object usually made of wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96396">
    <skos:scopeNote xml:lang="en">A stick or rod with an attached lash.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96397">
    <skos:scopeNote xml:lang="en">A cylindrical container, usually bulging outward in the middle and usually held together by metal hoops.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96398">
    <skos:scopeNote xml:lang="en">A round container, open and wide at the top with sides sloping inwards toward the bottom.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96400">
    <skos:scopeNote xml:lang="en">A hand held device with bristles or hairs used for cleaning or painting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96401">
    <skos:scopeNote xml:lang="en">A large stopper, often of cork.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96402">
    <skos:scopeNote xml:lang="en">A unifacially worked early stone tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96403">
    <skos:scopeNote xml:lang="en">A block on which objects are chopped or cut.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96404">
    <skos:scopeNote xml:lang="en">A tool for splitting and chopping.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96405">
    <skos:scopeNote xml:lang="en">A stone used to crush objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96409">
    <skos:scopeNote xml:lang="en">An object used to aid pouring a substance through a small opening.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96411">
    <skos:scopeNote xml:lang="en">A tool for scooping loose substances, usually with a handle and a curved blade partially covered at the handle end.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96412">
    <skos:scopeNote xml:lang="en">A container with a perforated bottom through which material is shaken or poured.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96413">
    <skos:scopeNote xml:lang="en">A form of stopper used to regulate the flow of liquid, often used in a barrel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96416">
    <skos:scopeNote xml:lang="en">An object worn, or carried, to cover the face.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96417">
