  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97695">
    <skos:scopeNote xml:lang="en">A shoe fixed to an animal, either permanently or temporarily, to protect the hoof and provide improved grip.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/97697">
