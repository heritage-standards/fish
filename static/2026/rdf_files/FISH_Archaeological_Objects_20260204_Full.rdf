  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96011">
    <skos:scopeNote xml:lang="en">A strip of lead holding small pieces of glass (quarries) in a window.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96016">
    <skos:scopeNote xml:lang="en">A container for holding votive offerings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96017">
