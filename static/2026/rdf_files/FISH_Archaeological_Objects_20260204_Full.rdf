  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100130">
    <skos:scopeNote xml:lang="en">A musical instrument producing sound from its own body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100131">
    <skos:scopeNote xml:lang="en">A device fitted and locked onto the head of a woman as a form of punishment, featuring a metal plate that fits into the mouth to impede speech..</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100132">
    <skos:scopeNote xml:lang="en">A part of a coffin that is removable eg handle, mount etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100135">
    <skos:scopeNote xml:lang="en">A stone inscribed or marked with ogham letters used for a memorial</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100138">
    <skos:scopeNote xml:lang="en">Polished stone balls interpreted as ritual objects in the Scottish Iron Age.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100142">
    <skos:scopeNote xml:lang="en">A playing piece for the medieval game of table.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100143">
    <skos:scopeNote xml:lang="en">A playing piece for draughts</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100144">
    <skos:scopeNote xml:lang="en">A circular toy which spins on a point.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100146">
    <skos:scopeNote xml:lang="en">A metal or pneumatic rubber rim to a wheel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100147">
    <skos:scopeNote xml:lang="en">A craft of uncertain function over 30 metres long.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100148">
    <skos:scopeNote xml:lang="en">A means of transportation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100149">
    <skos:scopeNote xml:lang="en">A long handled hook used for pulling a boat to a place eg another boat, or pushing off from a place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100152">
    <skos:scopeNote xml:lang="en">A device with hooks or claws attached to a rope and used for dragging or grasping.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100153">
    <skos:scopeNote xml:lang="en">The cutting or chopping part of an axe; bifacially worked, longitudinal section symmetrical, cutting edge  parallel to the direction of the hafted tool as swung.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100155">
    <skos:scopeNote xml:lang="en">A small tool with a shovel blade and a pick blade set at right angles to the handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100156">
    <skos:scopeNote xml:lang="en">A drill where the bit is twisted by means of a bow with the string wound around the shaft of the drill.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100157">
    <skos:scopeNote xml:lang="en">A key for a padlock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100159">
    <skos:scopeNote xml:lang="en">A long handled heavy hammer used by two hands.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100161">
    <skos:scopeNote xml:lang="en">A small bobbin used in lace making.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100162">
    <skos:scopeNote xml:lang="en">A bobbin where thread is wound around it, used for example in spinning and weaving</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100181">
    <skos:scopeNote xml:lang="en">An object which when hot is used to smooth fabric.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100184">
    <skos:scopeNote xml:lang="en">Any form of fastener used to fasten clothing together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100186">
    <skos:scopeNote xml:lang="en">A flat nail of the same thickness that tapers in width to a point.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100188">
    <skos:scopeNote xml:lang="en">A length of cord usually made from twisting fibres together which increases the strength of the rope.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100191">
    <skos:scopeNote xml:lang="en">An musical instrument where the strings are played by plucking or bowing. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100193">
    <skos:scopeNote xml:lang="en">A gaming piece for the Viking game of Hnefatafl.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/136750">
    <skos:scopeNote xml:lang="en">A coin which has been struck in relief on one side, usually the obverse side face down on the anvil die, and incuse on the other side, due to a previously struck coin sticking to the upper or punch die.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/136751">
    <skos:scopeNote xml:lang="en">A primitive musical instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/136754">
    <skos:scopeNote xml:lang="en">An earth based plaster the mixture of which may contain clay, dung, straw, lime putty, sand or horsehair.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/136755">
    <skos:scopeNote xml:lang="en">Several strands of string twisted together to form a strong thin rope, or thick string, though it has been used in the past as synonomous with rope particularly for ropes on ships.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137050">
    <skos:scopeNote xml:lang="en">A bracelet or necklace formed by hammering gold onto a triangular-sectioned bar and twisting the metal to form a spiral pattern.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137055">
    <skos:scopeNote xml:lang="en">A grooved ring holding a gem or semi-precious stone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137056">
    <skos:scopeNote xml:lang="en">A small notebook formed from two tablets usually made of wood, bone, ivory or metal. They were given as commemorative gift by a consul on his installation and often decorated with the image of the consul.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137058">
    <skos:scopeNote xml:lang="en">A flat, circular object often made from metal, wood, bone or ivory and of unidentified purpose.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137061">
    <skos:scopeNote xml:lang="en">A hinge composed of two parts: a u-shaped hinge attached to a door which slotted over an L-shaped staple in the door jamb.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137062">
    <skos:scopeNote xml:lang="en">A flat stone, often sandstone, used for paving.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137063">
    <skos:scopeNote xml:lang="en">A chain used to inhibit a prisoner's freedom.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137064">
    <skos:scopeNote xml:lang="en">A piece of armour worn to protect the throat.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137065">
    <skos:scopeNote xml:lang="en">A small, metal, crescent-shaped object, often highly decorated,  worn across the upper part of the chest by military personnel as a badge of rank and as a symbolic representation of the former piece of armour (see GORGET (ARMOUR).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137066">
    <skos:scopeNote xml:lang="en">A net worn over the hair to hold it in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137067">
    <skos:scopeNote xml:lang="en">The part of an object by which it is held when in use, being moved or carried.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137068">
    <skos:scopeNote xml:lang="en">The part of the bridle that fits around the horses head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137069">
    <skos:scopeNote xml:lang="en">A device for holding a lamp in a fixed position. These could take many forms from a simple bracket fixed to a wall to an onrate candelabra.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137070">
    <skos:scopeNote xml:lang="en">A tall, thin pillar of wood, stone or metal on which a lamp could be fixed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137071">
    <skos:scopeNote xml:lang="en">A boat fashioned out of a section of tree trunk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137072">
    <skos:scopeNote xml:lang="en">A large, powerful, hand-drawn bow, usually 6 ft (1.8m) in length and traditionally made of wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137073">
    <skos:scopeNote xml:lang="en">A strap from the reins to the girth of a horse, preventing it from raising its head too high.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137074">
    <skos:scopeNote xml:lang="en">A long, thin cane of glass made by layering glass of various colours in a mould and pulling the soft glass until the cane was of the desired thickness. When cut and viewed in section the cane has a mosaic like appearance.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137076">
    <skos:scopeNote xml:lang="en">A object fitted to an item or garment for the purpose of display or decoration.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137077">
    <skos:scopeNote xml:lang="en">A piece of openwork fabric made from twine or cord, either natural fibre or artificial, forming a mesh used for catching birds, animals or fish or for holding other inanimate objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137079">
    <skos:scopeNote xml:lang="en">A shrine often including representations of a god or gods or other holy relics which could be carried by worshippers whilst travelling.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137082">
    <skos:scopeNote xml:lang="en">A maritime fitting for spacing rigging elements and preventing entanglement.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137084">
    <skos:scopeNote xml:lang="en">A small container used for dispensing table salt for seasoning purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137086">
    <skos:scopeNote xml:lang="en">A metal, shankless bit, with a ring on either side used to control an animal (usually a horse) by exerting direct pressure on the  tongue, lips and the side of the mouth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137088">
    <skos:scopeNote xml:lang="en">A tubular orifice to assist in pouring.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137089">
    <skos:scopeNote xml:lang="en">A decorative fitting of mid to late 11th century date, exclusively of copper alloy, and mostly zoomorphic. Arranged in pairs, on each stirrup either side of the footplate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137090">
    <skos:scopeNote xml:lang="en">A decorative fitting of mid to late 11th century date, mainly of copper alloy, often traingular or trapezoidal in shape. Mounted at the junction of the stirrup and stirrup strap.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137091">
    <skos:scopeNote xml:lang="en">A decorative tile incorporated into the front of a tile stove.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137092">
    <skos:scopeNote xml:lang="en">A metal, often decorative, hinge constructed with a single large strap attached to the surface of the moving part wiht a loop in the end which fits over a pintle attached to the adjacent stationary frame.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/137093">
    <skos:scopeNote xml:lang="en">A weight used to hold down thatch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/139085">
    <skos:scopeNote xml:lang="en">A coin struck, cast or stamped imitating an official coinage issue of contemporary or slightly later time period. The piece may consist of a similar alloy or a base core with plating of varying thickness.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/139086">
    <skos:scopeNote xml:lang="en">A modern piece imitating an ancient coin, such as a replica sold in a museum.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/139087">
    <skos:scopeNote xml:lang="en">A modern piece imitating an ancient coin in an attempt to deceive, usually for financial gain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/140090">
    <skos:scopeNote xml:lang="en">A piece of animal bone roughly shaped with grooves in which pins are laid and held whilst being sharpened.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/140465">
    <skos:scopeNote xml:lang="en">A fitting specifically functioning as the strengthener and support for the end of a strap of leather or fabric.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141179">
    <skos:scopeNote xml:lang="en">A tool with an edged head and a wooden shaft, used for a variety of purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141181">
    <skos:scopeNote xml:lang="en">A weapon featuring a single or double edged head attached to a wooden shaft.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141182">
    <skos:scopeNote xml:lang="en">One of a number of tiles cemented together to form pillars supporting the floor above a hypocaust.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141183">
    <skos:scopeNote xml:lang="en">One of the component tiles used in the construction of a tile hearth, being the floor of, or area in front of, a fireplace.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141184">
    <skos:scopeNote xml:lang="en">A three-cornered arrowhead.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141185">
    <skos:scopeNote xml:lang="en">An arrowhead with its base hollowed to allow it to fit onto the shaft of an arrow rather than having a tang that fits into the shaft.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141186">
    <skos:scopeNote xml:lang="en">Animal remains bearing evidence, such as knife marks on bones, that they were slaughtered and used for food.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141188">
    <skos:scopeNote xml:lang="en">Debris resulting from the manufacture of tools and other artifacts from bone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141189">
    <skos:scopeNote xml:lang="en">Rendering material containing lime and sand spread on walls as a pliable mixture before drying to a hard surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141190">
    <skos:scopeNote xml:lang="en">A construction material made by the firing or baking of clay.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141191">
    <skos:scopeNote xml:lang="en">A hard, unglazed earthenware, characteristically reddish-brown in colour, used in decoration and construction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141194">
    <skos:scopeNote xml:lang="en">Remains of any of the groups of animals characterized by having a bony or cartilaginous spinal column (backbone) and a well developed brain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141195">
    <skos:scopeNote xml:lang="en">Remains of one of the groups of animals characterized as lacking any form of backbone or spinal column.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141197">
    <skos:scopeNote xml:lang="en">Remains of Bryozoa, which are small animals, usually marine, that form colonies producing coral-like skeletons or jelly-like masses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141198">
    <skos:scopeNote xml:lang="en">Remains of animals characterized as having bodies made up of annular segments, such as worms and leeches. Earthworm eggs and granule comonly occur. Bristle worms are found associated with marine molluscs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141199">
    <skos:scopeNote xml:lang="en">Remains of the animal group characterized by having jointed limbs and segmented bodies, including woodlice, spiders, insects etc. Note, crustaceans have been included in this category.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141200">
    <skos:scopeNote xml:lang="en">Remains of the animal group Crustacea: hard-shelled arthropods which are largely aquatic. Use for the remains of shrimps, prawns, crabs and lobsters, and also woodlice.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141201">
    <skos:scopeNote xml:lang="en">Remains of arthropods characterized as having a body divided into two segements and four pairs of legs, such as spiders, scorpions, ticks and mites.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141202">
    <skos:scopeNote xml:lang="en">Remains of the group of animals characterized as being radially symmetrical in form, such as sea urchins, sea cucumbers and starfish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141227">
    <skos:scopeNote xml:lang="en">A disc-shaped plate brooch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141228">
    <skos:scopeNote xml:lang="en">An enamelled plate brooch, dating from the second and third centuries AD, depicting an animal often with religious significance, such as hares, birds, fish and horses, sometimes with rider.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141229">
    <skos:scopeNote xml:lang="en">Imported Roman brooch with a wide, highly arched flat backed bow, one end rolled forward onto the head to form a hinge for the the pin. Named for the head inscription assumed to be a maker's name. Dated to first half of 1st entury AD.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141230">
    <skos:scopeNote xml:lang="en">A Roman brooch dating from approximately 50 to 150 AD. Derived from the earlier Aesica Brooch, and fitted with a hinged pin, the body widens to a triangular plate below the bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141231">
    <skos:scopeNote xml:lang="en">Anglo-Saxon two-piece bow brooch, dating from the 8th to 9th centuries AD, so named for the distinctive bow shaped like the arching body of a caterpillar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141232">
    <skos:scopeNote xml:lang="en">A first century AD one-piece bow brooch, one end of which is drawn out to form a spring and pin, characterized by its long, narrow, tapering bow, a small crossbar in front of the spring and a forward hook which holds the spring chord.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141233">
    <skos:scopeNote xml:lang="en">Roman bow brooch, dating from the third to fifth centuries AD, with a P-shaped profile and a characteristic crossbar, often adorned with knobs at its end and on the head. Shown in contemporary illustrations as being worn by high ranking males.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141234">
    <skos:scopeNote xml:lang="en">An Anglo-Saxon brooch type dating from the 5th to 7th centuries AD and influenced by the Crossbow brooch, featuring a sprung pin and a head plate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141235">
    <skos:scopeNote xml:lang="en">An Anglo-Saxon cruciform Long Brooch, often ornamented with knobs across and terminating its crossbar and head, and frequently with its foot shaped into a zoomorphic motif.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141236">
    <skos:scopeNote xml:lang="en">Roman, mid-1st century AD two-piece Bow Brooch, derived from the Colchester Brooch, with a winged, transverse head  protecting a spring mechanism held by a rear facing hook over the chord, its profile evoking a leaping dolphin.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141237">
    <skos:scopeNote xml:lang="en">Roman mid-first to third century AD S or reverse-S shaped brooch. Often enamelled, with its central section expanded for decoration, the brooch depicted stylised creatures derived from Celtic art. The pin was looped over the neck of the brooch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141238">
    <skos:scopeNote xml:lang="en">A two-piece Bow Brooch, derived from the Colchester Brooch, dating from the later first and second centuries AD and so called due to the decorative stud on the upper bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141239">
    <skos:scopeNote xml:lang="en">Roman, mid to late 1st century, hinged  Bow Brooch, related to the Aucissa Brooch, with side knobs on the upper bow, the curvature of which is confined to the brooch's top half, the lower half being straight. Frequently tinned to give a silver appearance.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141240">
    <skos:scopeNote xml:lang="en">A Roman Bow Brooch dating from the mid-second to mid-third centuries AD, characterized by the pronounced curvature of the bow, resembling a knee. Usually used by military personnel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141241">
    <skos:scopeNote xml:lang="en">A two-piece Bow Brooch dating from the early to mid-first century AD in Britain, originating in Gaul. Featuring a wide flat reeded bow, this and the Thistle Brroch were the first to conceal the spring mechanism with a cylindrical or semi-cylindrical hood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141242">
    <skos:scopeNote xml:lang="en">A simple, one-piece Bow Brooch with a spring of four coils, sometimes  less, its chord tucked beneath its head and variations to bow and catchplate. Dating from the first century AD.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141243">
    <skos:scopeNote xml:lang="en">An Anglo-Saxon disc brooch featuring an upturned rim. Usually decorated with zoomorphic or geometric designs either chip-carved directly on the face or applied to a thin bronze plate affixed to the brooch's floor.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141244">
    <skos:scopeNote xml:lang="en">A highly decorated Anglo-Saxon Long Brooch, often made of silver or bronze, worn by women. Contemporary with the Cruciform Brooch, it features a large, square head plate and usually three rounded foot-terminals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141245">
    <skos:scopeNote xml:lang="en">Early to mid-1st century AD Bow Brooch with a P-shaped profile, a cylindrical or semi-cylindrical spring cover and a round or lozenge-shaped centre plate with a short bow above and a flat leg below, both of which are reeded like the Langton Down Brooch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141247">
    <skos:scopeNote xml:lang="en">A Roman Bow Brooch, dating from the later 1st and 2nd centuries often worn in pairs with a linking chain. Characterized by its distinctive head, sometimes enamelled, and resembling the mouth of a trumpet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141250">
    <skos:scopeNote xml:lang="en">One of a pack, or deck, of cards used to play games, each distinguished from the others by markings on its face.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141434">
    <skos:scopeNote xml:lang="en">Bow Brooch derived from the Colchester type in the mid to late 1st and 2nd centuries AD. Typically the spring is held in a semi-cylindrical crossbar with closed ends and holding the axial bar and a hook or lug on the head to hold the chord.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141435">
    <skos:scopeNote xml:lang="en">1st or 2nd century Bow Brooch derived from the Colchester. It typically has a pin hinged on a bar held in a cylindrical crossbar, the bow tapering and commonly decorated. Developed examples often have a headloop and enamelled panels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141436">
    <skos:scopeNote xml:lang="en">Derived from the Colchester in the mid to late 1st century, particularly in south and east Britain. Characterized by the attachment of the separate spring and pin through two holes in a lug behind the head, which projects to form a crest atop the bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141439">
    <skos:scopeNote xml:lang="en">A mid-1st century AD brooch influenced by the Thistle type, commonly with projections on the upper bow and widening to a triangular plate, often described as a fantail, below.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141441">
    <skos:scopeNote xml:lang="en">A small, often of about two inches or less in length, version of the Long Brooch usually made of less expensive materials than other brooch types and frequently worn in pairs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/141508">
    <skos:scopeNote xml:lang="en">A tool with an edged head and a wooden shaft, used for a variety of purposes. Where the function is known use the more specific terms of AXE (TOOL) or AXE (WEAPON).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142086">
    <skos:scopeNote xml:lang="en">A container packed with explosives, with a detonator triggered by contact or a timer,  for the purpose of destroying enemy craft, personnel etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142087">
    <skos:scopeNote xml:lang="en">A mine designed specifically to be dropped from an aircraft, often into the sea.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142088">
    <skos:scopeNote xml:lang="en">A machine consisting of a number of moving parts designed to produce a specific physical effect, such as the powering of a craft or other device.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142089">
    <skos:scopeNote xml:lang="en">The engine housed within the fuselage of an aircraft that powers its flight.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142869">
    <skos:scopeNote xml:lang="en">A pair of cannon balls joined by a solid bar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142871">
    <skos:scopeNote xml:lang="en">A pair of cannon balls joined by a chain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142872">
    <skos:scopeNote xml:lang="en">Cube-shaped shot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142873">
    <skos:scopeNote xml:lang="en">A type of chain shot characterized by a number of chains attached to the main shot, causing maximum damage. Sometimes known as a Spider shot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142874">
    <skos:scopeNote xml:lang="en">A number of small iron balls, each about the size of a cricket ball, often numbering nine, wired together and bound in a canvas bag.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142875">
    <skos:scopeNote xml:lang="en">A solid, spherical projectile, originally made of stone but later iron.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142876">
    <skos:scopeNote xml:lang="en">A fitting of unknown function. Use more specific type where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142877">
    <skos:scopeNote xml:lang="en">Pieces of undressed stone, waste fragments of stone or fragments of slate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142878">
    <skos:scopeNote xml:lang="en">Waste resulting from the processes associated with the making of shoes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142879">
    <skos:scopeNote xml:lang="en">waste resulting from the working of wood or associated with a carpenter's workshop.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142881">
    <skos:scopeNote xml:lang="en">A drinking vessel, made of glass, designed expressly to be used for the consumption of wine.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142882">
    <skos:scopeNote xml:lang="en">An unhewn piece of felled tree, or similar rough mass of wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142884">
    <skos:scopeNote xml:lang="en">The remains of a shell of a mussel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142891">
    <skos:scopeNote xml:lang="en">Use for ticks and true mites. Related to spiders, mites are widely present in archaeological deposits but are rarely studies in detail as they can prove difficult to identify.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142893">
    <skos:scopeNote xml:lang="en">Group of fresh water crustaceans which include the water fleas (Daphnia ssp.) the egg cases (ephippia) of which are found in archaeological deposits.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142894">
    <skos:scopeNote xml:lang="en">Small crustaceans ranging in size from 0.2mm to 30mm and possessing a bivalve carapace or 'shell'.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142895">
    <skos:scopeNote xml:lang="en">Molluscs found in salt or brackish water. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142896">
    <skos:scopeNote xml:lang="en">Molluscs found in dry to damp habitats rather than fully aquatic or marine habitats. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142899">
    <skos:scopeNote xml:lang="en">Use for Insectivores (hedgehogs, shrews, moles), Chiroptera (bats) and rodents (squirrels, rats, voles, mice, dormice).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142900">
    <skos:scopeNote xml:lang="en">Microscopic living things, usually unicellular, occasionally multi-cellular. They lack cell nuclei.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142901">
    <skos:scopeNote xml:lang="en">Algae usually found as a silica skeleton. They obtain their food by photosynthesis and are used in ecological reconstruction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142902">
    <skos:scopeNote xml:lang="en">Simple organisms, mostly single celled, that move by means of two flagella (complex cellular projections). Most live as marine plankton, but some occur in fresh water. Members of the Kingdom Protista.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142903">
    <skos:scopeNote xml:lang="en">Single celled marine organisms. Some form calcareous tests (shells). They are used archaeologically to study the nature of marine environments or establish the presence of marine conditions or products (e.g. imported seaweed).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142904">
    <skos:scopeNote xml:lang="en">Kingdom of living things, lacking chlorophyll, that obtain their food from organic matter, usually by absorption. They include mushrooms, moulds and yeasts.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142906">
    <skos:scopeNote xml:lang="en">Material of unknown origin observed adhering to, or found within, an object of another material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142907">
    <skos:scopeNote xml:lang="en">Traces of food observed adhering to, or found within, an object or another material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142908">
    <skos:scopeNote xml:lang="en">Material derived from living things. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142909">
    <skos:scopeNote xml:lang="en">A simple type of plant. For most of their lifecycle they exist as haploids (i.e. only one set of genes as opposed to two). Most have clearly differentiated stems and leaves.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142910">
    <skos:scopeNote xml:lang="en">Amoebae which are partially enclosed in external shells, or tests. Found in wet soils, freshwater, decaying organic matter and on vegetation such as mosses. Used to examine environmental factors such as water acidity and moisture content.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142911">
    <skos:scopeNote xml:lang="en">Use for any soil or sediment. Sediments consist of mineral and/or organic material deposited by any process involving natural or human agencies. Soils are discrete bodies of altered mineral material (either sediment or in situ rock remains).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142912">
    <skos:scopeNote xml:lang="en">A wind-blown deposit.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142913">
    <skos:scopeNote xml:lang="en">Wind-blown sand.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142914">
    <skos:scopeNote xml:lang="en">Wind-blown silt.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142915">
    <skos:scopeNote xml:lang="en">Deposits laid down as the result of river action.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142916">
    <skos:scopeNote xml:lang="en">Deposits formed as the result of the action of ice masses during glacial periods.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142917">
    <skos:scopeNote xml:lang="en">Unsorted sediment (i.e. containing everything from clay to boulders) laid down directly by a glacier.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142919">
    <skos:scopeNote xml:lang="en">Deposits formed by the mass downward movement of surface deposits over underlying frozen ground under periglacial conditions.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142920">
    <skos:scopeNote xml:lang="en">Deposits that accumulate at the bottom of a slope, at a break in a slope, or where a barrier is encountered.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142921">
    <skos:scopeNote xml:lang="en">A soil, which may be buried or exposed, that has developed in a past landscape.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142922">
    <skos:scopeNote xml:lang="en">Material consisting of at least 90% organic matter by dry weight. Formed from plant material under damp, wet or acid conditions where the rate of accumulation is greater than the rate of decay.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142923">
    <skos:scopeNote xml:lang="en">A rock-like deposit consisting largely of calcium carbonate, formed by the precipitation of calcium carbonate out of calcium-rich water bodies such as springs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142924">
    <skos:scopeNote xml:lang="en">A residue left as the result of the burning of material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142925">
    <skos:scopeNote xml:lang="en">Volcanic ash.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142926">
    <skos:scopeNote xml:lang="en">Use for deposits formed in estuaries.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142927">
    <skos:scopeNote xml:lang="en">Use for deposits formed in lakes or ponds.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142928">
    <skos:scopeNote xml:lang="en">Fine-grained, non-humified, organic mud formed under water. Principally composed of plant material, typically of faecal origin.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142929">
    <skos:scopeNote xml:lang="en">Use for deposits formed by the action of the sea or under marine conditions.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142930">
    <skos:scopeNote xml:lang="en">Use for deposits formed in caves.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142931">
    <skos:scopeNote xml:lang="en">Use for deposits formed as a result of the modification of soils by humans for agricultural purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142932">
    <skos:scopeNote xml:lang="en">Use for deposits formed as a result of construction activities undertaken by humans or animals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142933">
    <skos:scopeNote xml:lang="en">Use for deposits representing material discarded or remaining as a result of a process or processes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142946">
    <skos:scopeNote xml:lang="en">Deposits formed under conditions present adjacent to ice masses during glacial periods.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142976">
    <skos:scopeNote xml:lang="en">One of several stones used to raise a farm building, such as a granary, above the ground surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142983">
    <skos:scopeNote xml:lang="en">The fruit or seed of a cereal plant such as wheat, corn etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/142984">
    <skos:scopeNote xml:lang="en">The fertilized ovules of a plant, often occurring in an archaeological context, in the form of small roundish bodies or grains. Seeds are dispersed naturally or collected for sowing to produce a new generation of plants.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143006">
    <skos:scopeNote xml:lang="en">A paddle blade, typically of wood, from a horizontal or vertical mill wheel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143019">
    <skos:scopeNote xml:lang="en">A sailmaker's thimble used in the sewing of canvas, consisting of a flat thimble in a canvas or leather strip with a thumb hole. The whole is worn across the palm of the hand, which gives it its name.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143020">
    <skos:scopeNote xml:lang="en">An astonomical instrument, and navigational aid, in the form of one eighth of a circle and used to measure the angular altitude of heavenly bodies. Invented in 1731 and used into the 19th Century, it was superceded by the sextant.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143023">
    <skos:scopeNote xml:lang="en">A hollow case containg explosive, incendiary, smoke-producing, poisonous or other offensive material, designed to be deposited, dropped, thrown or shot froma mortar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143024">
    <skos:scopeNote xml:lang="en">A cylindrical bomb, designed by Barnes Wallis in 1941, containing hydrostatic pistols measuring water pressure for detonation at a depth of 30 feet.  Dropped whilst fast revolving at a height of 60 feet at 240-250 mph to maximise the bouncing effect.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143026">
    <skos:scopeNote xml:lang="en">An ornamental (carved and/or painted) frieze carved into, or attached to, the planking either side of a vessel's bow carrying the vessel's name and often illustrating some aspect of the name, port/country of origin etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143027">
    <skos:scopeNote xml:lang="en">A hinged plate of brass, iron or wood inboard of a ship's scuttle or porthole which can be lowered and secured with a butterfly nut to prevent damage to glass in heavy weather or mask internal light from enemy vessels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143028">
    <skos:scopeNote xml:lang="en">A water-tight cover that closes and opening in a vessel's deck used for the ingress and egress of persons and cargo.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143029">
    <skos:scopeNote xml:lang="en">A hole or opening in a ship's hull to allow light and air to enter the vessel, or to aim a weapon through.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143030">
    <skos:scopeNote xml:lang="en">A flexible pipe, usually fixed to a pump or tap, for the conveying of water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143031">
    <skos:scopeNote xml:lang="en">A covering of thin copper plates secured, on top of a layer of tar and horsehair, to the bottom of wooden ships to protect the hull against weeds, barnacles and especially Teredo navalis, a wood-boring worm prevalent in tropical seas.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143224">
    <skos:scopeNote xml:lang="en">A piece of metal or wood, or other material used in the manufacture of an item, intended for further fabrication and therefore representing an unfinished object. Usually relates to objects manufactured in quantity such as coins, knives etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143225">
    <skos:scopeNote xml:lang="en">A flat, circular plate, usually made of iron, on which food items are baked.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143235">
    <skos:scopeNote xml:lang="en">A concave glass dish used to hold material for observation or experimentation; so named for its resemblance to the disc covering the face of a watch.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143237">
    <skos:scopeNote xml:lang="en">An object marked or shaped by the pressure of another object upon its surface, whether by deliberate process or unintentionally.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143239">
    <skos:scopeNote xml:lang="en">A device, often consisting of a cyclinder containing a piston or plunger, used to raise or move liquids or gasses by means of compression, lifting or suction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143240">
    <skos:scopeNote xml:lang="en">A tube, cyclinder or similar casing enclosing the mechanism of a pump.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143242">
    <skos:scopeNote xml:lang="en">A tool, featuring a straight, horizontal handle from which extends a metal hook halfway along its length, used by a shearman (one who shears sheep) in the handling of wool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143243">
    <skos:scopeNote xml:lang="en">The metal ornamental bedding and surround in which a gem or stone is mounted.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143244">
    <skos:scopeNote xml:lang="en">A piece of material that has been inlaid, or prepared and shaped for inlaying, in an object, decorative feature or other setting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143245">
    <skos:scopeNote xml:lang="en">A carved or moulded decorative projection adorning an object or, in the case of architectural features, the termination of a moulding or the intersection of ribs or beams.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143247">
    <skos:scopeNote xml:lang="en">A straight rod, made of glass, plastic or other materials, used  to agitate or mix chemicals, pigments, beverages or other fluids or substances.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143461">
    <skos:scopeNote xml:lang="en">A large vessel, sometimes large enough to accomodate several gallons, often made of leather and richly decorated, for storing and serving liquor.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/143949">
    <skos:scopeNote xml:lang="en">An axe with a cutting edge and a hammer head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144027">
    <skos:scopeNote xml:lang="en">A handheld lamp used to send morse code messages ship-to-ship or ship-to-shore.The lamp and its reflector can be covered/uncovered by a trigger operated shutter.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144561">
    <skos:scopeNote xml:lang="en">Any object, often made of ceramic or 'porcelain' used for the purposes of personal cleansing, especially fittings such as toilets, baths and basins. May survive as fragments in the archaeological record. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144562">
    <skos:scopeNote xml:lang="en">Loose fibres obtained by unpicking old ropes. Mainly used to caulk seams in wooden vessels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144563">
    <skos:scopeNote xml:lang="en">A conical container, usually made of earthenware, into which boiling sugar was poured and allowed to crystallize.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144591">
    <skos:scopeNote xml:lang="en">Large granite stone used as the base stone of a stamping mill against which ore was crushed. Contains distinctive striations from the crushing process.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144592">
    <skos:scopeNote xml:lang="en">A stone with a rectangular depression into which molten metal, usually tin, was poured to create ingots.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/144608">
    <skos:scopeNote xml:lang="en">A short squat gun or cannon used to test the strength of coarser blasting powders. Mainly 18th-19th centuries.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/146450">
    <skos:scopeNote xml:lang="en">A large trough or vessel commonly created from a hollowed out tree trunk for the storage of brine prior to processing for salt.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/147257">
    <skos:scopeNote xml:lang="en">A clip for marking or holding down pages in a book.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/147258">
    <skos:scopeNote xml:lang="en">A specific type of hook used in textile production, also known as a sheer board hook. Harbicks were used in pairs to secure a cloth to a cropping board so that the nap (of the cloth) could be sheared.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/147279">
    <skos:scopeNote xml:lang="en">Roughly spherical, &gt; 5 Âµm, soot particles produced from the incomplete combustion of fossil fuels. Used as an indicator of industrialisation, and can also be used as a dating tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148287">
    <skos:scopeNote xml:lang="en">Fine sand, clay, or other material carried by running water and deposited as a sediment, especially in a channel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148288">
    <skos:scopeNote xml:lang="en">Grains of rock fragment larger than coarse sand and finer than pebbles (diameter 2-4mm).</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148295">
    <skos:scopeNote xml:lang="en">An object which has been carved. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148296">
    <skos:scopeNote xml:lang="en">A jug with a sinuous profile where the rim, girth and base are of roughly equal diameter, and the neck and lower body are narrower.(Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148297">
    <skos:scopeNote xml:lang="en">A jug with little or no discernible neck and an even, convex profile form rim to base, which are roughly equal in diameter. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148298">
    <skos:scopeNote xml:lang="en">A jug with a body profile resembling two cones joined together at their widest points, producing a distinct carination. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148299">
    <skos:scopeNote xml:lang="en">A jug with more or less straight sides that flare out from a narrow rim or neck to a wider base. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148302">
    <skos:scopeNote xml:lang="en">A jug with straight vertical sides and roughly equal rim and base diameters. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148303">
    <skos:scopeNote xml:lang="en">A jug with a rounded profile and a rounded base, i.e. with no discernible basal angle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148304">
    <skos:scopeNote xml:lang="en">A jug with a maximum diameter in the lower half of the vessel and with no discernible shoulder. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148305">
    <skos:scopeNote xml:lang="en">A jug with an evenly rounded profile and a discernible basal angle; the maximum diameter is near the mid point and in the upper half of the vessel. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148306">
    <skos:scopeNote xml:lang="en">A specific form of rounded jug with a wide mouth, a large parrot-beak spout and three handles in the form of wide straps that spring from the rim to the girth.The spout may have a lug applied to the outside. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148307">
    <skos:scopeNote xml:lang="en">A jug with a roughly cylindrical or slightly flaring lower body, a pronounced inward-sloping shoulder and a marked neck/body angle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148308">
    <skos:scopeNote xml:lang="en">A jug with a constriction between the upper and lower body sections. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148310">
    <skos:scopeNote xml:lang="en">Any type of jug with decoration representing the form of a human face or figure. The shape of the vessel often forms the outline of the human face or figure. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148312">
    <skos:scopeNote xml:lang="en">A type of jug decorated with applied figures in the form of knights in armour. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148313">
    <skos:scopeNote xml:lang="en">A jug that incorporates a practical joke or conundrum into its construction. A combination of cut-outs in the body and hollow handles and tubes render conventional use impossible. The puzzle being to work out how to empty it. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148314">
    <skos:scopeNote xml:lang="en">A jug form characterized by the addition of three applied feet. The feet are usually short and stubby. Double index with the appropriate profile type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148315">
    <skos:scopeNote xml:lang="en">A jug form which usually has a short, narrow neck and rim and an applied spout. The spout is usually tubular and free standing, or attached to the rim/neck, rising from just above the high shoulder or girth. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148316">
    <skos:scopeNote xml:lang="en">A jug with a pierced bunghole just above the base. the bunghole can be made through an applied knob or disc of clay, or simply a hole in the vessel wall. In use, the hole would probably have had a tap or spigot attached. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148319">
    <skos:scopeNote xml:lang="en">A circular flask with one or two flattened faces. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148320">
    <skos:scopeNote xml:lang="en">A flask with a rounded, almost spherical shape. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148321">
    <skos:scopeNote xml:lang="en">A flask with a hollow ring-shaped form. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148322">
    <skos:scopeNote xml:lang="en">A jar whose profile resembles two truncated cones joined together at the widest point, forming a carination at the centre of the vessel. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148323">
    <skos:scopeNote xml:lang="en">A jar with vertical concave body walls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148324">
    <skos:scopeNote xml:lang="en">A concave sided jar made in tin-glazed earthenware. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148325">
    <skos:scopeNote xml:lang="en">A jar with roughly vertical body walls which in some cases may be slightly convex. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148326">
    <skos:scopeNote xml:lang="en">A jar with a profile that flares outwards from base to rim, but usually with a constriction at the neck. Squat examples, with a height less than the minimum diameter, could be classified as bowls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148329">
    <skos:scopeNote xml:lang="en">A jar with a rounded profile merging into a rounded base with no discernible basal angle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148330">
    <skos:scopeNote xml:lang="en">A specific form of globular jar with a rounded or very sagging base and an inturned, generally simple, rim. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148331">
    <skos:scopeNote xml:lang="en">A jar with a profile that slopes inwards from base to rim. Particularly shallow examples have been term Peat Pots; this is a term with a restricted distribution in northern England. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148332">
    <skos:scopeNote xml:lang="en">A jar with an evenly rounded profile. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148333">
    <skos:scopeNote xml:lang="en">A specific type of small rounded jar. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148334">
    <skos:scopeNote xml:lang="en">A jar with a roughly cylindrical or slightly flaring lower body and a rounded, inward sloping shoulder. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148335">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of a single handle. Profiles vary and should be double indexed with the appropriate JAR type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148336">
    <skos:scopeNote xml:lang="en">A jar with a single handle attached to the rim edge and looped over the top of the vessel. There may be a lip. Profiles can vary and should be double indexed with the appropriate JAR type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148337">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of two handles. Handles may be horizontal or vertical loops or horizontal or curved lugs. Handles are nearly always opposed. Profiles vary and should be double indexed with the appropriate JAR type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148338">
    <skos:scopeNote xml:lang="en">A distinctive form of jar being a flat-based, straight-sided or slightly rounded jar with two opposed, upright, rounded, tongue-shaped lugs raised from above the rim and bridged by added, internal struts used to suspend the pot over a fire. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148339">
    <skos:scopeNote xml:lang="en">A jar with one or more lips added on the outside of the vessel wall over a hole pierced through the wall. The lips do not usually rise above rim level. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148340">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of three or more vertical loop handles. They may be equally spaced, or confined to one section of the circumference. Profile vary and should be double indexed with the appropriate JAR type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148341">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of a straight handle and three feet. Profiles vary and should be double indexed with the appropriate JAR type. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148342">
    <skos:scopeNote xml:lang="en">A specific form of cauldron, generally of rounded profile made in the Low Countries. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148343">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of a pierced bunghole just above the base. The hole can be simply a hole in the wall of the vessel or made through a circular knob or disc of clay. There may be one or two vertical loop handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148344">
    <skos:scopeNote xml:lang="en">A bowl whose form resembles two cones joined together at their widest points, forming a carination.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148345">
    <skos:scopeNote xml:lang="en">A bowl with a sharp change of angle in the vessel wall, generally at the point of maximum diameter. the carination may be in the upper or lower half of the vessel. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148346">
    <skos:scopeNote xml:lang="en">A bowl with concave body walls. Wide-mouthed, narrow-based examples, particularly those in larger sizes, have been termed Pans or Pancheons. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148347">
    <skos:scopeNote xml:lang="en">A bowl with straight sides which turn outwards, forming an obtuse angle with the base, i.e. and inverted, truncated, conical shape. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148348">
    <skos:scopeNote xml:lang="en">A flared bowl of medium to deep depth, with wide horizontal everted rim. These vessels may have a single handle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148349">
    <skos:scopeNote xml:lang="en">A wide-mouthed, narrow based flared bowl associated with dairying activities. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148350">
    <skos:scopeNote xml:lang="en">A bowl with no noticeable base angle, so that the walls and base form a continuous rounded curve (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148351">
    <skos:scopeNote xml:lang="en">A bowl with convex body walls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148352">
    <skos:scopeNote xml:lang="en">A bowl with straight sides which are at an approximate right angle to the base, i.e. a roughly cylindrical shape. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148353">
    <skos:scopeNote xml:lang="en">A bowl adapted by the addition of a short tubular spout applied just below the rim.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148354">
    <skos:scopeNote xml:lang="en">A bowl adapted by having a pedestal base. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148358">
    <skos:scopeNote xml:lang="en">A bowl comprising three or more equally spaced lobes. There may be one or more moulded animals or other figures inside the base and two or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148359">
    <skos:scopeNote xml:lang="en">A bowl divided into two or more compartments by vertical slab partitions. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148361">
    <skos:scopeNote xml:lang="en">A vessel comprising of two or more bowls, generally of small size, joined together. There may be one or more handles of varying forms. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148362">
    <skos:scopeNote xml:lang="en">A bowl adapted by the addition of one or more handles. The handles may be vertical or horizontal loops, or straight, or may comprise vertical or horizontal lugs. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148363">
    <skos:scopeNote xml:lang="en">A jar adapted by the addition of one or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148364">
    <skos:scopeNote xml:lang="en">A bowl adapted by the addition of a single handle</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148365">
    <skos:scopeNote xml:lang="en">A bowl with a straight handle projecting horizontally or diagonally upwards from the rim, particularly or completely hollow, but not opening into the vessel. A jar adapted by the addition of one or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148366">
    <skos:scopeNote xml:lang="en">A bowl with a single loop handle crossing over the top of the vessel from one side of the rim to the other. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148367">
    <skos:scopeNote xml:lang="en">A bowl adapted by the addition of two handles, generally opposed. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148369">
    <skos:scopeNote xml:lang="en">A small, double-handled bowl with horizontal loop handles decorated with a cockerel motif. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148370">
    <skos:scopeNote xml:lang="en">A bowl adapted by the addition of three or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148371">
    <skos:scopeNote xml:lang="en">A dish with straight or convex sides that turn inwards, forming an acute basal angle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148372">
    <skos:scopeNote xml:lang="en">A dish adapted by the addition of a pedestal base. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148373">
    <skos:scopeNote xml:lang="en">A dish comprising three or more lobes, usually equally spaced. There may be one or more animal or other figures inside the base and two or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148374">
    <skos:scopeNote xml:lang="en">A round, oval or rectangular straight-sided dish, divided into two or more units or compartments of varying sizes by vertical slab partitions. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148377">
    <skos:scopeNote xml:lang="en">A vessel comprising two or more dishes, generally of small size, joined together. There may be one or more handles of varying forms. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148378">
    <skos:scopeNote xml:lang="en">A type of dish specifically designed to catch the juices from roasting meat. The dish may be oval, semi-circular, rectangular or wedge-shaped. Usually has one or two handles located on one long side and a lip at one or both short sides. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148381">
    <skos:scopeNote xml:lang="en">A shallow tray or dish used for baking food.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148384">
    <skos:scopeNote xml:lang="en">A beaker adapted by having a pedestal base. The upper part of the pedestal is solid and may be thrown as an integral part of the vessel, or added as a separate element.(Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148387">
    <skos:scopeNote xml:lang="en">A beaker with convex body walls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148388">
    <skos:scopeNote xml:lang="en">A beaker with a construction above the base to form a waisted profile. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148389">
    <skos:scopeNote xml:lang="en">A cup with a marked change of angle in the body wall, generally at the point of maximum girth. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148391">
    <skos:scopeNote xml:lang="en">A cup with sides falring outwards from the base towards the rim, usually with a single handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148392">
    <skos:scopeNote xml:lang="en">A cup with a rounded body beneath a deep neck. There may be a marked junction between neck and body and the angle of the neck may be inward-sloping, upright or everted. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148394">
    <skos:scopeNote xml:lang="en">A cup with convex body walls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148395">
    <skos:scopeNote xml:lang="en">A cup adapted by the addition of a pedestal base. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148396">
    <skos:scopeNote xml:lang="en">A vessel composed of three or more equally spaced lobes and usually, a waisted or pedestal base. The handles are vertical loops, generally of strap form. There may be two opposed handles, or one per lobe junction. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148397">
    <skos:scopeNote xml:lang="en">A vessel composed of three or more separate compartments, joined together and pierced to allow liquid to flow from one to another. There may be one or more handles. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148398">
    <skos:scopeNote xml:lang="en">A form of cup which incorporates a joke or conundrum, where cut-outs or holes in the body make conventional use impossible. The puzzle is how to drink from it without getting wet; usually achieved by sucking through a hollow rim or handle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148399">
    <skos:scopeNote xml:lang="en">A mug with little or no discernible neck and an even, convex profile from rim to base, which have roughly equal diameters. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148400">
    <skos:scopeNote xml:lang="en">A mug with more-or-less straight side which flare out from the rim to the wider base. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148401">
    <skos:scopeNote xml:lang="en">A German stoneware form of conical mug. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148402">
    <skos:scopeNote xml:lang="en">A mug with roughly vertical body walls. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148403">
    <skos:scopeNote xml:lang="en">A mug with straight sides flaring outwards from the base towards the rim. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148404">
    <skos:scopeNote xml:lang="en">A mug with a rounded body profile below a deep neck. There may be a marked junction between the neck and the body. The neck may be inward-sloping, upright or everted. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148405">
    <skos:scopeNote xml:lang="en">A specific German Stoneware form of rounded mug. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148406">
    <skos:scopeNote xml:lang="en">A lid with a carinated conical profile and straight vertical sides, surmounted by a conical top with and integral knob. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148407">
    <skos:scopeNote xml:lang="en">A lid with a shallow conical profile and an integral knob. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148408">
    <skos:scopeNote xml:lang="en">A simple flat-topped lid resembling an inverted dish but with no central knob or handle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148409">
    <skos:scopeNote xml:lang="en">A lid with a shallow domed profile and a central knob. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148410">
    <skos:scopeNote xml:lang="en">A simple, flat or nearly flat lid. In ceramic forms, often made by rolling out clay rather than by throwing on a wheel. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148411">
    <skos:scopeNote xml:lang="en">A lid resembling an inverted dish with a flat top and an integral or added knob or loop handle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148412">
    <skos:scopeNote xml:lang="en">A lid comprising a shallow flared dish with an integral knob rising from the centre. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148413">
    <skos:scopeNote xml:lang="en">A lid with a distinct flange, projecting upwards, horizontally or downwards, and an integral knob. Complex examples can include a simple locking device: lugs on the lower flange can be twisted into matching cut-outs in the rim to lock it. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148414">
    <skos:scopeNote xml:lang="en">A type of flanged lid where the lower flange is partly cut away to leave two projections or lugs, which can be fitted into corresponding cut-outs in the rim of the vessel beneath and secure the lid when it is rotated. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148415">
    <skos:scopeNote xml:lang="en">A complex or ornate lid which cannot be easily classified according to the main forms of lid. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148416">
    <skos:scopeNote xml:lang="en">A candlestick in which a simple socket is set in the centre of a drip tray or saucer. There may be a vertical loop handle linking the socket to the rim of the saucer. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148419">
    <skos:scopeNote xml:lang="en">A candlestick in which the socket is above a drip tray or grease tray, placed on a pedestal base which is generally hollow. There may be a vertical loop handle and one or more secondary drip trays. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148420">
    <skos:scopeNote xml:lang="en">A deep, square or rectangular, flat slab of clay, the upper surface of which has two or more cup-shaped holders cut into it. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148421">
    <skos:scopeNote xml:lang="en">A pedestal lamp with a drip-tray below the bowl. There may be a vertical loop handle linking bowl and drip-tray. Some variants have a more enclosed bowl form with a small tubular spout projecting from the bowl. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148422">
    <skos:scopeNote xml:lang="en">A small hemispherical bowl with a pinched or pulled wick lip. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148423">
    <skos:scopeNote xml:lang="en">A small bowl on a pedestal base, which may be solid or at least partly hollow. It may have a wick lip at the rim or a lug handle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148424">
    <skos:scopeNote xml:lang="en">A small bowl on a pedestal base above a drip-tray or saucer. It may have a wick lip at the rim. May have pierced lugs projecting form the rim for suspension of a handle, spout or vertical loop handle linking bowl and saucer. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148425">
    <skos:scopeNote xml:lang="en">A small hemispherical or flared bowl with a solid pointed base or spike. May include a wick lip at the rim and one or two pierced lugs for suspension. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148427">
    <skos:scopeNote xml:lang="en">A curfew with straight sides flaring outwards from the top. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148429">
    <skos:scopeNote xml:lang="en">A curfew with a rounded profile merging into a rounded top, with no discernible angle. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148431">
    <skos:scopeNote xml:lang="en">A curfew consisting of a half section of an inverted bowl. The form has been adapted for use against a wall. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/148432">
    <skos:scopeNote xml:lang="en">A curfew consisting of a half-bell shape with a raised flange around the cut-away side. A vertical loop handle joins the flange and body. The form is adapted for use against a wall and some are highly decorated. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149182">
    <skos:scopeNote xml:lang="en">An end scraper that has a retouched end which is convex in form. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149183">
    <skos:scopeNote xml:lang="en">An end scraper made on a flake that is wider than it is long. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149184">
    <skos:scopeNote xml:lang="en">An end scraper which has a retouched end that is straight in form. If the tool blank is a blade or flake, and the retouch is abrupt retouch rather than scraper retouch then use either Truncated blade or Truncated flake. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149185">
    <skos:scopeNote xml:lang="en">An end scraper which has a retouched end that is concave in form. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149186">
    <skos:scopeNote xml:lang="en">A side scraper with a short concavity retouched into an edge. This may be achieved by a single blow. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149188">
    <skos:scopeNote xml:lang="en">A microlith retouched to a point, usually with oblique retouch. They are synonymous with 'obliquely blunted points' of the English Mesolithic. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149189">
    <skos:scopeNote xml:lang="en">A microlith retouched to a half moon or crescent shape. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149190">
    <skos:scopeNote xml:lang="en">A microlith retouched to a triangular shape. They can be sub-divided into scalene and isosceles triangles. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149191">
    <skos:scopeNote xml:lang="en">A microlith retouched to a trapezium shape. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149192">
    <skos:scopeNote xml:lang="en">A microlith retouched to a rectangular shape. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149193">
    <skos:scopeNote xml:lang="en">A microlith retouched to a thomboid shape. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149194">
    <skos:scopeNote xml:lang="en">A stone axe in which the surface is fully covered by negative removals. Core axes may be made on flakes and have part of the flake's original surface but this cannot be part of the edge otherwise use FLAKED AXE. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149195">
    <skos:scopeNote xml:lang="en">A stone core with a conical form and a core platform which may or may not be prepared. Blades are removed around the circumference of the platform. The end of the core opposite the platform usually tapers to a point. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149196">
    <skos:scopeNote xml:lang="en">A small stone core with a conical form and a single core platform which may or may not be prepared. Microblades are removed form the circumference of the platform. The end opposite the platform usually tapers to a point. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149197">
    <skos:scopeNote xml:lang="en">A stone core made on a large thick flake and characterized by a distinctive, unworked or slightly-shaped handle section. The platform is plain and microblades are detached mainly form the front section of the core. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149198">
    <skos:scopeNote xml:lang="en">A core which has two opposing platforms. One end serving as the main platform for the removal of blades - the other being used to straighten the face of the core and correct knapping errors. Removals are taken from the full circumference. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149199">
    <skos:scopeNote xml:lang="en">A core used to produce flakes from a single plain platform. The base of the core, or 'keel', is often formed by alternate removal from a process resembling cresting. Often one end has a relatively unmodified section. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149200">
    <skos:scopeNote xml:lang="en">A core with more than two distinct platforms usually including one or two striking surfaces and the the traces of former platforms. Usually restricted to flake production. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149201">
    <skos:scopeNote xml:lang="en">A stone core which is irregular in shape. It can have numerous usuable or abandoned striking platforms. It is the most common core type and it is often the last attempt of a knapper to extract the final usable flakes form the core. (Source: SARC)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149205">
    <skos:scopeNote xml:lang="en">A jar-shaped vessel with pierced apertures or cut-out on an open or closed pedestal base. Herbs, spices or scented woods would be placed in the pot and a burning coal placed underneath to warm the herbs so they would release their scent.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149207">
    <skos:scopeNote xml:lang="en">A heating apparatus in which coals or embers are placed in the pedestal or base below a container in which food or liquid could be held and kept warm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149208">
    <skos:scopeNote xml:lang="en">A small, handled, open vessel, generally with a steep profile, designed to sit partially within a larger vessel and used to warm drinks. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149210">
    <skos:scopeNote xml:lang="en">A vessel used as the lower part of a distillation unit consisting of a round-bottomed vessel with walls sloping inwards towards the rim. Some examples may have an external flange to support the upper unit (ALEMBIC). (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149211">
    <skos:scopeNote xml:lang="en">A deep, rectangular or oval, straight-sided vessel with an everted, crenellated rim, used to hold either wax for dipping candles or molten sulphur for dipping matches. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149213">
    <skos:scopeNote xml:lang="en">A costrel with a barrel-shaped body and a centrally placed neck. One end is usually flat and the other domed. Two opposed strap handles or lugs join the rim or neck and shoulder. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149214">
    <skos:scopeNote xml:lang="en">A costrel with a cylindrical body and a centrally placed neck. One end is usually domed and the other flat. Two opposed strap handles or lugs may join the rim or neck and shoulder. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149215">
    <skos:scopeNote xml:lang="en">A costrel with a flattened spherical form: the back is flat and the front domed or mammiform. The base may be slightly flattened or rounded. Two opposed strap handles or lugs join the rim or neck and shoulder. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/149216">
    <skos:scopeNote xml:lang="en">A costrel with a narrow-mouth and two opposed handles or lugs on the shoulder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151831">
    <skos:scopeNote xml:lang="en">The piece of stone or flint remaining after blades have been produced.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151926">
    <skos:scopeNote xml:lang="en">A device inserted in the ear canal to protect the wearer from loud noises or the intrusion of water, foreign bodies, dust or excessive wind.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151931">
    <skos:scopeNote xml:lang="en">A type of cast chisel with a sharp, concave edge for shaping wood, stone or metal. A particular type of British Bronze Age tool.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151935">
    <skos:scopeNote xml:lang="en">A type of mace with bolster shaped stone or metal head on a wooden or metal shaft. Where the use is thought to be ceremonial, double index with ceremonial object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151937">
    <skos:scopeNote xml:lang="en">A Mesolithic type of mace head made of stone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151941">
    <skos:scopeNote xml:lang="en">A nail used for roofing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151944">
    <skos:scopeNote xml:lang="en">Metal shaped blade that flares out to a curved cutting edge, with a side loop to further assist hafting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151950">
    <skos:scopeNote xml:lang="en">A tool used to notch, line cut or scratch into a surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151953">
    <skos:scopeNote xml:lang="en">Type of leaf-shaped socketed spearhead with two small holes or loops on either side at the base of the blade. Possibly meant to assist in securing the metal spearhead to the wooden shaft, or to tie streamers of some kind to the top of the spear.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151955">
    <skos:scopeNote xml:lang="en">A spearhead with an elongated hollow cast into the base of the blade to receive the end of the wooden spear shaft. The spearhead was secured to the shaft by pegs set at right angles or by lashings fixed to loops cast at the base of the spearhead.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151957">
    <skos:scopeNote xml:lang="en">A type of spearhead with a triangular blade bevelled at the edges and with a groove(s) following the outline.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151959">
    <skos:scopeNote xml:lang="en">A device for catching eagles, falcons and hawks.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151960">
    <skos:scopeNote xml:lang="en">Style of early Bronze Age pot found widely in north-western Europe with a deep, largely plain, outwardly flared body above which is sharp carination, usually decorated and sometimes with an applied cordon, and an inwardly angled neck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151962">
    <skos:scopeNote xml:lang="en">A collared urn with a heavy rim or collar on top of a straight-sided or slightly bowed body narrowing to a small flat base. Decoration may extend for a short way below the collar, but this is rare.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151965">
    <skos:scopeNote xml:lang="en">A large vessel with raised or applied cordons running horizontally on the body of the vessel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151967">
    <skos:scopeNote xml:lang="en">A collared urn with a heavy rim or collar on top of a concave neck or cavetto zone, which may or may not be decorated, and this in turn leads down to a straight-sided but narrowing body. Decoration may extend below this cavetto zone, but this is rare.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151970">
    <skos:scopeNote xml:lang="en">Urn with a heavy rim or collar which may be vertical or slightly inverted. This may carry incised or impressed decoration, particularly herring-bone, encircling lines, hurdling or chevron decoration.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/151972">
    <skos:scopeNote xml:lang="en">The impost, or point at which a vault rests upon its support, and from which it seems to spring. Hence the term describes the bottom stone of a vault, which lies on the impost.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152434">
    <skos:scopeNote xml:lang="en">A heavy chain, usually of gold, worn as insignia of office or a mark of fealty or other association from the Middle Ages onwards.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152436">
    <skos:scopeNote xml:lang="en">A long-handled implement designed to allow the user to scratch their own back.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152458">
    <skos:scopeNote xml:lang="en">A piece of plate armour designed to protect the shoulder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152470">
    <skos:scopeNote xml:lang="en">A reinforced and padded item of clothing designed to protect the upper body in sports associated with physical contact or possible injury from sporting equipment. For military uses use BREASPLATE.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152471">
    <skos:scopeNote xml:lang="en">Clothing designed to protect the wearer from physical hazards.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152478">
    <skos:scopeNote xml:lang="en">A flag or object depicting a symbolic representation carried as part of a religious ceremony.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152579">
    <skos:scopeNote xml:lang="en">A monocular optical instrument possessing magnification for observing distant objects, especially in astronomy.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/152582">
    <skos:scopeNote xml:lang="en">A device used to gauge the speed of a vessel at sea.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/159346">
    <skos:scopeNote xml:lang="en">A tool used for splitting straw. The straw splitter would be pushed down the hollow shaft of a piece of straw to produce six flat lengths of straw ready for plaiting. Used in straw hat making.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/160138">
    <skos:scopeNote xml:lang="en">A machine that can be flown in the air, now specifically an aeroplane or helicopter.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/160139">
    <skos:scopeNote xml:lang="en">Any part of an aircraft. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/162773">
    <skos:scopeNote xml:lang="en">A mask worn over the face to protect the wearer from inhaling airborne pollutants and toxic gases. The mask forms a sealed cover over the nose and mouth, but may also cover the eyes and other vulnerable soft tissues of the face.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/163871">
    <skos:scopeNote xml:lang="en">A type of stoneware jug dating to the 16th and 17th centuries, popularly known as a Bellarmine jug, shaped in the figure of a bearded man. They were produced in the Cologne region, particularly Frechen.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/163922">
    <skos:scopeNote xml:lang="en">A fully automatic mounted or portable firearm, usually designed to fire bullets in quick succession from an ammunition belt or magazine.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/163923">
    <skos:scopeNote xml:lang="en">A muzzle loaded explosive projectile fired from a mortar. Typically they are short range and low velocity with a high arcing trajectory.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/163924">
    <skos:scopeNote xml:lang="en">Outer casing of an explosive cartridge fired from a cannon or mortar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/164112">
    <skos:scopeNote xml:lang="en">A moveable section of  light fence, traditionally made from wattle and used for herding livestock, to separate land or to act as river bank revetments.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/164177">
    <skos:scopeNote xml:lang="en">Plain clay tile suspended, loose, from the top edge of a tiling lath or batten so as to overlap two courses below. It is held in place by a small wooden peg wedged into, or passed through, one (or sometimes both) of two holes in the head of the tile.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/164355">
    <skos:scopeNote xml:lang="en">A small piece of metal used to mend ceramic, glass or metal plates and vessels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/164371">
    <skos:scopeNote xml:lang="en">Ammunition from any period found to have been expended (cannonballs, shells, bullets) which may indicate the possible site of a battle or action on land or at sea. Index where appropriate with Battlefield Debris as a Monument Type.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/166994">
    <skos:scopeNote xml:lang="en">A mould in which a sword is cast.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/166996">
    <skos:scopeNote xml:lang="en">A shallow ceramic or metal libation bowl, usually with no handles or feet. The Greeks called it a phiale, the Romans a patera. Used in religious practice. Could contain mixed wine and water but also unmixed wine, honey, oil, water, or milk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167286">
    <skos:scopeNote xml:lang="en">A human-powered, pedal-driven, single-track vehicle, having two wheels attached to a frame, one behind the other.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167287">
    <skos:scopeNote xml:lang="en">A self-propelled wheeled vehicle that does not operate on rails, such as trains or trolleys.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167289">
    <skos:scopeNote xml:lang="en">A vehicle used to transport passengers. Cars usually have four wheels and an internal combustion engine.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167291">
    <skos:scopeNote xml:lang="en">A car adapted for ease of use by people with disabilities.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167292">
    <skos:scopeNote xml:lang="en">A funerary vehicle used to carry a coffin from a church or funeral home to a cemetery.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167293">
    <skos:scopeNote xml:lang="en">A two or three wheeled motor vehicle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167294">
    <skos:scopeNote xml:lang="en">A motor vehicle designed to transport cargo.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/167296">
    <skos:scopeNote xml:lang="en">A road vehicle designed to carry many passengers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169912">
    <skos:scopeNote xml:lang="en">A pressure vessel used to store gasses at above atmospheric pressure.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169915">
    <skos:scopeNote xml:lang="en">Round object used to carry cable or wire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169916">
    <skos:scopeNote xml:lang="en">Short-range naval weapon with a low muzzle velocity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169919">
    <skos:scopeNote xml:lang="en">Molluscs found in terrestrial habitats as opposed to fresh or brackish water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169921">
    <skos:scopeNote xml:lang="en">Molluscs found in fresh or brackish water habitats.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169927">
    <skos:scopeNote xml:lang="en">Remains of barley (Hordeum sp.) grain (caryopyses). These grains are sometimes itemised separately.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169932">
    <skos:scopeNote xml:lang="en">Remains of wheat (Triticum sp.) grain (caryopyses). These grains are sometimes itemised separately.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169936">
    <skos:scopeNote xml:lang="en">Remains of any part of a nut including the nutshell. The definition of nut as used here is any woody fruit or seed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169938">
    <skos:scopeNote xml:lang="en">Remains of any part of a hazel (Corylus avellana L.) nut.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169940">
    <skos:scopeNote xml:lang="en">Remains of the wood seeds of fruits such as apples, pears, grapes or citrus.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169942">
    <skos:scopeNote xml:lang="en">Remains of the endocarp (stone) of a member of the genus Prunus which includes sloes, plums, cherries, apricots and peaches.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169944">
    <skos:scopeNote xml:lang="en">Residue resulting from the presence of sewage. While you can have a cesspit, it contains sewage not cess.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/169993">
    <skos:scopeNote xml:lang="en">A component of reciprocating engines - the moving component that is contained by a cylinder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170002">
    <skos:scopeNote xml:lang="en">A flaky or spheroidal byproduct of the iron forging process, composed of either iron oxide or magnetite.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170021">
    <skos:scopeNote xml:lang="en">A wide, shallow, straight-sided, circular DISH, with concentric divisions, formed by vertical partitions, or by concentric grooving around the base. The use is uncertain but the name implies it was designed to hold feed for domestic fowl. (Source: MPRG)</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170044">
    <skos:scopeNote xml:lang="en">Portable device that generate stable and consistent flame by combining flammable liquids or pressurised gases with a spark.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170072">
    <skos:scopeNote xml:lang="en">A portable object of stone, bone, metal or other material featuring a deliberately engraved or incised design.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170074">
    <skos:scopeNote xml:lang="en">Equipment, including specialised clothing, bats, rackets etc. used for sporting activities.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170075">
    <skos:scopeNote xml:lang="en">A device used to slow the fall of a person or an object from a great height. When open it consists of a large umberella like sheet with wires or ropes converging from the edge to a harness attached to the lower end.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170078">
    <skos:scopeNote xml:lang="en">Low-grade cast iron in the form of balls or spheres, produced in small workshops and exported across the North Sea and Baltic region. Particularly associated with 16th century Sweden. Also spelt oszemundt and other variants.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170080">
    <skos:scopeNote xml:lang="en">A small cup for holding a boiled egg upright while it is being eaten.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170082">
    <skos:scopeNote xml:lang="en">Parts which make up a maritime vessel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170083">
    <skos:scopeNote xml:lang="en">Any part of a maritime vessel. Use more specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170084">
    <skos:scopeNote xml:lang="en">Any piece of timber that makes up the body of a maritime vessel, e.g. frame, decks, masts.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170099">
    <skos:scopeNote xml:lang="en">A tool used to provide grip and mechanical advantage in applying torque to tighten or loosen objects such as nuts and bolts.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170112">
    <skos:scopeNote xml:lang="en">A curving metal band attached to the underside of the stock of a firearm, vertically enclosing the trigger to prevent accidental discharge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170628">
    <skos:scopeNote xml:lang="en">A staff with a fork at one end which would be used to hold a lighted slow match which was used to fire a canon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170673">
    <skos:scopeNote xml:lang="en">The cutting or chopping part of an adze; bifacially worked, longitudinal section symmetrical, cutting edge  parallel to the direction of the hafted tool as swung.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170675">
    <skos:scopeNote xml:lang="en">A pebble or small cobble with a small circular depression in one or both faces. The depressions, if on both faces, are usually directly opposite. These items may be unfinished pebble hammers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170677">
    <skos:scopeNote xml:lang="en">A piece with one or more surfaces with either/both slightly convex shape appropriate for use in forming metal artefacts.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170679">
    <skos:scopeNote xml:lang="en">A hammerstone but with broad groove worked around much or all of centre to enable fixing to a handle; usually associated with mining/metalworking.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170681">
    <skos:scopeNote xml:lang="en">A disc &gt;4mm with a central perforation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170683">
    <skos:scopeNote xml:lang="en">A stone/cobble/boulder with worn/smooth wear traces left by grinding/polishing axes/adzes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170689">
    <skos:scopeNote xml:lang="en">Worked or unworked block/boulder/cobble, on which grain was ground by to-and-fro motion, resulting in a deep smooth elongated hollowed area.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170745">
    <skos:scopeNote xml:lang="en">Glass fragments collected for re-melting. This includes not only worked fragments, but pieces broken from blowing irons and pontils, (moyles). All periods from the Roman onwards.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170746">
    <skos:scopeNote xml:lang="en">A roller used in the fulling process to felt cloth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170747">
    <skos:scopeNote xml:lang="en">In the glass industry, material spilled or raked from the top of the crucible during melting:important for assessing the methods of glassmaking and a common find on furnace sites. Roman period onwards.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170748">
    <skos:scopeNote xml:lang="en">The vertical recessed face of a pediment, often decorated with sculpture.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170764">
    <skos:scopeNote xml:lang="en">A container holding items associated with the period of burial. Often buried to commemorate a certain event, such as the foundation of a building.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170765">
    <skos:scopeNote xml:lang="en">An enclosed cage used in a mine shaft to transport miners from the surface to the mine workings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170766">
    <skos:scopeNote xml:lang="en">A trough for containing moulding sand for use in casting metal artefacts.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170767">
    <skos:scopeNote xml:lang="en">In the glass industry, a flat block of stone (idealy marble), cast iron, or a ceramic material, on which cylinder glass is flattened. Medieval and Post Medieval.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170769">
    <skos:scopeNote xml:lang="en">An iron striking plate used to create sparks to ignite a fire.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170816">
    <skos:scopeNote xml:lang="en">A detachable tool for mechanical diggers primarily used in demolition but also for reclamation and salvage.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170821">
    <skos:scopeNote xml:lang="en">A hooked tool, usually of metal, used to clean the hooves of a horse.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170823">
    <skos:scopeNote xml:lang="en">Perforated tiles, used to pave the drying floors of malting kilns.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170827">
    <skos:scopeNote xml:lang="en">Concreted pyre material - a fusion of seaweed, sand and human remains - deliberately included in prehistoric graves in Scotland.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170829">
    <skos:scopeNote xml:lang="en">The remains of living organisms preserved in stone over a long time period. Only use when proven to have been used as an object such as a grave good.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170831">
    <skos:scopeNote xml:lang="en">Rock fragment (diameter 4-64mm) larger than gravel and smaller than cobble. Only use when proven to have been used as an object such as a grave good.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170833">
    <skos:scopeNote xml:lang="en">Hard, protective covering made largely of calcium salts secreted by soft bodied invertebrate animals. Only use when proven to have been used as an object such as a grave good.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170835">
    <skos:scopeNote xml:lang="en">A specific Bronze Age grave good that features in rich burial assemblages.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170854">
    <skos:scopeNote xml:lang="en">A bead in the form of a circular or multi-sided cylinder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170855">
    <skos:scopeNote xml:lang="en">A bead in the form of a doughnut.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170856">
    <skos:scopeNote xml:lang="en">A bead in the form of a disc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170857">
    <skos:scopeNote xml:lang="en">A bead formed from a spiral of glass or ceramic.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170894">
    <skos:scopeNote xml:lang="en">A pin with a disc, often decorated, at the head end.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/170895">
    <skos:scopeNote xml:lang="en">Flint occurs chiefly as nodules in sedimentary rocks, such as chalks and limestones. Use term for tested or untested nodule.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171265">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the family of Hippopotamidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171266">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the family of Hyaenidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171273">
    <skos:scopeNote xml:lang="en">A species of antelope which during antiquity inhabited a vast area of the Eurasian steppe. During the Pleistocene, it ranged across the mammoth steppe from the British Isles to Beringia and the presence of Saiga remains may act as a useful chronological marker for this period.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171274">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of a Lion. When found in an archaeological context lion remains may act as a chronological marker for the sites dating to the Pleistocene</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171277">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of a Mammoth which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171278">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of Megaloceros giganteus which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171280">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the genus Rangifer which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171281">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the family of Equidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171282">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of Canis Lupus (Wolf) which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171283">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the family of Ursidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171284">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the family of Rhinocerotidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171285">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any extinct member of the family of Bovidae which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171286">
    <skos:scopeNote xml:lang="en">A kind of copper-alloy disc brooch, about 2cm in diameter and decorated with a single human face mask, usually frontal and occasionally in profile.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171294">
    <skos:scopeNote xml:lang="en">Material from trees that have been buried in peat bogs and preserved from decay by the acidic and anaerobic bog conditions. Bog wood can be useful for extending the dendrochronological record.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171328">
    <skos:scopeNote xml:lang="en">A device or implement, especially one held in the hand, used to carry out a particular function. Use more specific terms where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171338">
    <skos:scopeNote xml:lang="en">A type of handaxe that is associated with the Neanderthal Mousterian industry of the Middle Palaeolithic in Britain. The handaxes are bifacially-worked and in the shape of a rounded triangle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171378">
    <skos:scopeNote xml:lang="en">Term for undiagnostic remains of fired or burnt clay which is of uncertain origin or function.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/171400">
    <skos:scopeNote xml:lang="en">Use to record the bones and skeletal remains of any member of the genus of Bison which may act as chronological markers for sites dating to the Pleistocene.</skos:scopeNote>
  </rdf:Description>


