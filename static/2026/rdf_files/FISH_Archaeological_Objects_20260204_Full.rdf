  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100014">
    <skos:scopeNote xml:lang="en">A form of armour made up of overlapping squares of protective material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100015">
    <skos:scopeNote xml:lang="en">Armour made up segmentally, usually of bands of material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100016">
    <skos:scopeNote xml:lang="en">A gun designed to be held in one hand. It has a short barrel length compared to long guns.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100017">
    <skos:scopeNote xml:lang="en">A hand held long barrelled gun.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100018">
    <skos:scopeNote xml:lang="en">A pistol fired by use of a flintlock.A gunflint is held in the lock which on pulling the trigger pushes back the pan cover creating sparks which set off the powder in the pan causing a flame to go through and set off the charge in the barrel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100019">
    <skos:scopeNote xml:lang="en">A musket fired by a piece of burning match being held in the lock which, when the trigger was pulled, would contact with powder in the pan to set off the charge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100020">
    <skos:scopeNote xml:lang="en">A musket where a wheel on the lock is wound back and when the trigger is pulled the wheel moves dragging pieces of iron pyrites over the lock tocreate sparks and set powder in the pan off and so firing the main charge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100021">
    <skos:scopeNote xml:lang="en">A musket with a snaphance lock. This lock consisted of a flint and steel but the pan cover was separate to the steel unlike the flintlock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100026">
    <skos:scopeNote xml:lang="en">A tool used to pound, crush or beat an object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100041">
    <skos:scopeNote xml:lang="en">A weight attached to a fishing line in order to help it sink towards the bottom.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100046">
    <skos:scopeNote xml:lang="en">A bell worn by an animal, eg sheep, goats, cows and hawks, to inform the owner of the animal's position.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/100047">
