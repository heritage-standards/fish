  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96418">
    <skos:scopeNote xml:lang="en">A distinguishing emblem or mark, often worn to signify membership, achievement, employment etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96419">
    <skos:scopeNote xml:lang="en">A flag bearing a device, often carried on two poles or hanging from a cross piece. Usually used in processions.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96420">
    <skos:scopeNote xml:lang="en">A piece of fabric with a design, used as an emblem for military or naval purposes, signalling, decoration, display, propaganda etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96423">
    <skos:scopeNote xml:lang="en">The purpose of this object is unknown though it could be for surveying or it could be a charm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96424">
    <skos:scopeNote xml:lang="en">A type of bowl designed to be suspended, usually from the roof.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96426">
    <skos:scopeNote xml:lang="en">An heraldic design depicting armorial bearings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96430">
    <skos:scopeNote xml:lang="en">A form of axehead where the body is hollow allowing for insertion of the haft. Usually bronze or iron and of late Bronze Age or Iron Age date. Most examples feature a side loop to further assist hafting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96439">
    <skos:scopeNote xml:lang="en">A container, usually rectangular and having a removable or hinged lid.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96443">
    <skos:scopeNote xml:lang="en">A box used for storage or shipping.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96445">
    <skos:scopeNote xml:lang="en">A small box or chest for valuables, especially jewels.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96449">
    <skos:scopeNote xml:lang="en">Stone used as a building material which has been finished, or dressed, before use.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96450">
    <skos:scopeNote xml:lang="en">A screen used to decorate or protect an opening.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96456">
    <skos:scopeNote xml:lang="en">A shaped piece of wood that makes up a barrel, key etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96459">
    <skos:scopeNote xml:lang="en">The windlass used to wind rope around to raise and lower the bucket in a well.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96462">
    <skos:scopeNote xml:lang="en">An object, usually wood or metal used to force open or keep open another object. Often used to split timber by striking the thick end and forcing the wood apart.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96463">
    <skos:scopeNote xml:lang="en">Any by-product which cannot be reused.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96464">
    <skos:scopeNote xml:lang="en">Twin bars riveted together which can open and close allowing it to grip objects, usually to lift and move them.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96466">
    <skos:scopeNote xml:lang="en">A pattern cut out in wood or metal to help shape something accurately or to reproduce shapes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96467">
    <skos:scopeNote xml:lang="en">A tool used to sharpen another tool or object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96468">
    <skos:scopeNote xml:lang="en">Twin blades each with a sharpened edge connected together by a pivot which cut when opened and closed on an object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96469">
    <skos:scopeNote xml:lang="en">A tool for cutting substances eg wood, metal etc. Its blade has teeth down one edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96472">
    <skos:scopeNote xml:lang="en">A pattern used to create a consistent shape for an object, often hollow and reusable.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96473">
    <skos:scopeNote xml:lang="en">Use specific form where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96474">
    <skos:scopeNote xml:lang="en">A wooden hammer.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96475">
    <skos:scopeNote xml:lang="en">A stone used for sharpening edged tools, knives etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96477">
    <skos:scopeNote xml:lang="en">A blunt headed instrument used for striking objects.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96481">
    <skos:scopeNote xml:lang="en">A tool used to hit fabric, eg to remove dust or dirt.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96483">
    <skos:scopeNote xml:lang="en">Scissor like object used for cutting, clipping, shearing etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96485">
    <skos:scopeNote xml:lang="en">A flint tool for piercing holes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96486">
    <skos:scopeNote xml:lang="en">An object used to create a blast of air.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96488">
    <skos:scopeNote xml:lang="en">A small, pierced, often spherical or cylindrical, piece of glass, wood,etc, which may be strung together with others to form a necklace.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96490">
    <skos:scopeNote xml:lang="en">A sawn piece of timber, thinner than a plank and often rectangular.</skos:scopeNote>
  </rdf:Description>

