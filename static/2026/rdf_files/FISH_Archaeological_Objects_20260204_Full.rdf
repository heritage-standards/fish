  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95946">
    <skos:scopeNote xml:lang="en">A container used to hold and or pour a liquid in honour of a deity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95947">
    <skos:scopeNote xml:lang="en">A container used to hold and or pour a liquid in honour of a deity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95949">
    <skos:scopeNote xml:lang="en">A container used to hold and or pour a liquid in honour of a deity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95950">
