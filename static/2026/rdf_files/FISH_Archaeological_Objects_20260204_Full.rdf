  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96042">
    <skos:scopeNote xml:lang="en">A sheet or cloth used to lay the corpse out in for burial.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96049">
    <skos:scopeNote xml:lang="en">An object in the shape of an Egyptian dung beetle, used to symbolise the motive power of the sun. Use specific term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/96050">
