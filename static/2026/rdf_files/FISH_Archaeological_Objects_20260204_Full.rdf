  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95329">
    <skos:scopeNote xml:lang="en">An instrument for measuring the angle of slopes, usually in inches per yard, consisting of a weighted graduated wheel with movable sights.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95332">
    <skos:scopeNote xml:lang="en">A measuring rule used for cloth, with the imperial yard divided into quarters and nails (sixteenths), or using the now obsolete ell of 45 inches.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95333">
    <skos:scopeNote xml:lang="en">An instrument for determining, measuring or setting out right angles, usually consisting of two pieces or arms set at right angles to each other, but sometimes with the arms hinged or pivoted to measure any angle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95335">
    <skos:scopeNote xml:lang="en">Weight on the end of a graduated line for measuring the depth of water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95336">
    <skos:scopeNote xml:lang="en">A box with one transparent side within which a picture, jewel etc can be displayed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95337">
    <skos:scopeNote xml:lang="en">An instrument for measuring the angular distance of objects, and particularly used for navigation by noting the position of the stars.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95338">
    <skos:scopeNote xml:lang="en">Right angled triangular plate for determining, measuring or setting out set angles.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95341">
    <skos:scopeNote xml:lang="en">A reversible device for measuring time by the transfer of sand from upper to lower glass bulb.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95343">
    <skos:scopeNote xml:lang="en">A graduated length of material used for measuring distances.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95344">
    <skos:scopeNote xml:lang="en">An instrument for measuring or drawing angles, consisting of a quarter circle, graduated to 90 degrees, with a movable arm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95345">
    <skos:scopeNote xml:lang="en">An instrument for measuring angles, usually in the form of a graduated semi-circle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95346">
    <skos:scopeNote xml:lang="en">An indicator of the extent and or ownership of a property.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95347">
    <skos:scopeNote xml:lang="en">A weight hung on a piece of string or twine used to show the vertical.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95348">
    <skos:scopeNote xml:lang="en">A body suspended so as to be free to swing, especially one regulating the work of a clock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95349">
    <skos:scopeNote xml:lang="en">A dial for showing the hours of the night by the moon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95350">
    <skos:scopeNote xml:lang="en">An object used to mark each mile and to indicate distances to locations.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95351">
    <skos:scopeNote xml:lang="en">A container which holds a set quantity of a substance, can be graduated to show quantities.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95352">
    <skos:scopeNote xml:lang="en">A measuring rule not graduated in feet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95353">
    <skos:scopeNote xml:lang="en">An instrument for establishing the horizontal line of sight and used in surveying. It usually has an eyepiece and an air bubble in a glass tube or dome.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95354">
    <skos:scopeNote xml:lang="en">A weight used with letter scales for weighing letters or parcels and establishing the required postal rate.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95355">
    <skos:scopeNote xml:lang="en">A sandglass that runs for an hour.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95356">
    <skos:scopeNote xml:lang="en">A container holding a set quantity used specifically for measuring grains or cereal.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95359">
    <skos:scopeNote xml:lang="en">A pillar, rod, pin, or plate of a sundial, showing time by its shadow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95360">
    <skos:scopeNote xml:lang="en">A graduated vessel or instrument for gauging or measuring the force or quantity of a fluctuating object, such as rainfall, tide, wind etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95361">
    <skos:scopeNote xml:lang="en">A measuring rule graduated in feet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95363">
    <skos:scopeNote xml:lang="en">An instrument for taking measurements and describing circles, with two straight arms connected at one end by a movable joint.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95365">
    <skos:scopeNote xml:lang="en">A system of communication used in a house to summon servants or on board ship to transmit orders to the engine room.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95366">
    <skos:scopeNote xml:lang="en">A bound collection of paper or other materials.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95368">
    <skos:scopeNote xml:lang="en">Mountings, often decorative, attached to a book.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95371">
    <skos:scopeNote xml:lang="en">A papal document.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95372">
    <skos:scopeNote xml:lang="en">A written journal, often of a personal nature.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95374">
    <skos:scopeNote xml:lang="en">A piece of written or printed matter providing a record of events, agreements, ownership or identification.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95375">
    <skos:scopeNote xml:lang="en">A stamp used to emboss paper.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95376">
    <skos:scopeNote xml:lang="en">A coloured fluid used for writing, drawing and printing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95377">
    <skos:scopeNote xml:lang="en">A container for holding ink.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95378">
    <skos:scopeNote xml:lang="en">A pot for ink usually housed in a hole in a desk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95382">
    <skos:scopeNote xml:lang="en">Signs or badges of office, honour, membership, occupation etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95384">
    <skos:scopeNote xml:lang="en">Written or typed correspondence, usually between two or more parties.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95385">
    <skos:scopeNote xml:lang="en">A document or book written by hand.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95386">
    <skos:scopeNote xml:lang="en">A brush for applying paint.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95387">
    <skos:scopeNote xml:lang="en">A writing material prepared from the pithy stem of an aquatic plant.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95388">
    <skos:scopeNote xml:lang="en">An animal skin prepared as a writing or painting surface.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95389">
    <skos:scopeNote xml:lang="en">An object used to prick holes on each side of a manuscript page to mark the postion of the horizontal lines.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95390">
    <skos:scopeNote xml:lang="en">An instrument for writing or drawing with ink.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95391">
    <skos:scopeNote xml:lang="en">An instrument for writing or drawing, which usually consists of a thin rod of graphite surrounded by a wooden cylinder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95392">
    <skos:scopeNote xml:lang="en">A diagram or drawing made by projection onto a horizontal plane, often of a building.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95393">
    <skos:scopeNote xml:lang="en">The barrel of a feather, usually goose, used as a pen.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95396">
    <skos:scopeNote xml:lang="en">A container for sand which was used to stop ink from spreading.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95397">
    <skos:scopeNote xml:lang="en">A roll of paper or parchment, especially with writing upon it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95404">
    <skos:scopeNote xml:lang="en">A tube for conveying the voice from one room or building to another.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95405">
    <skos:scopeNote xml:lang="en">A pointed instrument for writing, usually on wax tablets.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95407">
    <skos:scopeNote xml:lang="en">A brush used in writing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95408">
    <skos:scopeNote xml:lang="en">Two or more tablets of wood attached by a string or leather thong, with a raised border one side of which was filled with wax to write upon. Thin wooden tablets with ink writing are also known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95411">
    <skos:scopeNote xml:lang="en">An instrument which creates a buzzing noise.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95412">
    <skos:scopeNote xml:lang="en">An instrument made of a hollow cylinder or hemisphere covered at one or both ends and sounded by striking.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95414">
    <skos:scopeNote xml:lang="en">A metal disk with a turned rim, giving a resonant note when struck.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95415">
    <skos:scopeNote xml:lang="en">A book of hymns.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95416">
    <skos:scopeNote xml:lang="en">A small edge blown instrument with no finger holes, producing one note.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95417">
    <skos:scopeNote xml:lang="en">Semi precious stone or glass engraved with a design and used to make an impression on wax or clay.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95418">
    <skos:scopeNote xml:lang="en">A book containing prayers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95419">
    <skos:scopeNote xml:lang="en">Official currency printed or written onto paper which can be directly exchanged for goods, services or coins.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95421">
    <skos:scopeNote xml:lang="en">A lead seal marking newly woven cloth which served as a quality control method in medieval and post medieval periods.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95425">
    <skos:scopeNote xml:lang="en">An iron bar or ingot of distinctive form with a pinched end previously thought to have been used as a medium of exchange in the Iron Age but is now believed to be a roughout for a sword.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95427">
    <skos:scopeNote xml:lang="en">A lockable box for holding money and valuables.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95428">
    <skos:scopeNote xml:lang="en">Silver rings believed to have been used in the Hebrides and Irish Sea regions during the Viking period, and derived from Hiberno-Viking arm rings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95429">
    <skos:scopeNote xml:lang="en">An unofficial, usually local, substitute for coinage, which could be exchanged directly for goods or services in certain areas or with specified retailers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95430">
    <skos:scopeNote xml:lang="en">A strong vehicle with four wheels for carrying loads, usually horse or ox drawn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95431">
    <skos:scopeNote xml:lang="en">Any non structural fitting on a vehicle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95433">
    <skos:scopeNote xml:lang="en">A vehicle on runners for carrying loads or passengers, especially over snow. Could be drawn by horses, dogs, reindeer and/or pushed or pulled by people.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95436">
    <skos:scopeNote xml:lang="en">A device on a boat's gunwale serving as a fulcrum for an oar and keeping it in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95437">
    <skos:scopeNote xml:lang="en">A short, broad bladed oar used without a rowlock.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95438">
    <skos:scopeNote xml:lang="en">A pole with a blade used for rowing or steering a boat by leverage against the water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95439">
    <skos:scopeNote xml:lang="en">A vehicle containing a couch shut in by curtains and carried by men or beasts of burden.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95440">
    <skos:scopeNote xml:lang="en">An object which perforated the axle cap, passing through the axle and so keeping the wheel in place. Usually made of metal, though can be made of wood or antler.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95444">
    <skos:scopeNote xml:lang="en">A small boat of wickerwork covered by a watertight material.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95446">
    <skos:scopeNote xml:lang="en">A vehicle used in warfare, racing or to carry passengers.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95447">
    <skos:scopeNote xml:lang="en">A mounting or fixture attached to a cart.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95448">
    <skos:scopeNote xml:lang="en">A vehicle with two wheels for carrying loads.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95451">
    <skos:scopeNote xml:lang="en">A wheeled passenger vehicle, especially one with four wheels and pulled by horses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95452">
    <skos:scopeNote xml:lang="en">A small, narrow boat with pointed ends propelled by paddling.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95453">
    <skos:scopeNote xml:lang="en">A small vessel propelled on water by an engine, oars or sails.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95455">
    <skos:scopeNote xml:lang="en">A rod or spindle, either fixed or rotating, on which a wheel or group of wheels is fixed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95456">
    <skos:scopeNote xml:lang="en">Usually made of iron, this bound the end of an axle and was perforated to allow a linch pin to pass through the axle and keep the wheel in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95457">
    <skos:scopeNote xml:lang="en">A heavy weight used to moor a ship.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95461">
    <skos:scopeNote xml:lang="en">A blade attached to a shoe to glide on ice. It can be made of bone, and examples are known from at least as early as the Bronze Age. Metal blades have progressively replaced bone skates since the sixteenth century.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95463">
    <skos:scopeNote xml:lang="en">A circular frame or disc arranged to revolve on an axle and used to facilitate the motion of a vehicle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95471">
    <skos:scopeNote xml:lang="en">A bent piece of metal or bone, often with a barb, which is tied to a line and used to catch fish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95472">
    <skos:scopeNote xml:lang="en">A small doll controlled by the operators hand either directly or with strings.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95473">
    <skos:scopeNote xml:lang="en">A staff of office or authority.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95475">
    <skos:scopeNote xml:lang="en">A small structure used to support strings on an instrument pushing them away from the body of the instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95476">
    <skos:scopeNote xml:lang="en">A piece of wood attached to a thong that makes a roaring sound when the thong is whirled.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95478">
    <skos:scopeNote xml:lang="en">A thin piece of metal which when struck vibrates to produce a sound, can be used in pairs.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95479">
    <skos:scopeNote xml:lang="en">A stringed musical instrument, usually played with a bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95480">
    <skos:scopeNote xml:lang="en">A pipe in which air is made to vibrate by blowing across an edge, including transverse flutes and recorders.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95481">
    <skos:scopeNote xml:lang="en">A stringed instrument with a fingerboard which has frets on it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95483">
    <skos:scopeNote xml:lang="en">A stringed instrument usually with a triangular frame.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95486">
    <skos:scopeNote xml:lang="en">A trumpet type of instrument made from or in imitation of an animal horn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95487">
    <skos:scopeNote xml:lang="en">Decorative mounts on horse harness</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95488">
    <skos:scopeNote xml:lang="en">An instrument consisting of a small lyre-shaped metal frame held between the teeth, with a steel tongue plucked with the finger.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95490">
    <skos:scopeNote xml:lang="en">A plucked string instrument of a specific medieval / early post medieval type.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95491">
    <skos:scopeNote xml:lang="en">A plucked string instrument in which the strings pass over the soundbox and parallel to the sides of the instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95492">
    <skos:scopeNote xml:lang="en">A stringed instrument with a very rounded body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95494">
    <skos:scopeNote xml:lang="en">A musical instrument with a toothed cylinder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95498">
    <skos:scopeNote xml:lang="en">An instrument composed of several pipes in which air is made to vibrate by blowing across the top edge.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95501">
    <skos:scopeNote xml:lang="en">Any instrument for plucking or strumming a string eg a small piece of wood or plastic used to strum a guitar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95502">
    <skos:scopeNote xml:lang="en">A hollow instrument containing material that produces sound when shaken.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95504">
    <skos:scopeNote xml:lang="en">A medieval wind instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95505">
    <skos:scopeNote xml:lang="en">A circular frame with a stretched membrane and small cymbals in the frame.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95506">
    <skos:scopeNote xml:lang="en">An instrument which has a cupped mouthpiece and may have a straight, bent or curved tube. It includes slide trumpets like the trombone.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95507">
    <skos:scopeNote xml:lang="en">The peg of a stringed instrument which, when tightened or loosened, tunes the string of the instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95508">
    <skos:scopeNote xml:lang="en">A stringed instrument usually played with a bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95509">
    <skos:scopeNote xml:lang="en">Any dome shaped metal bell struck either by an internal clapper or by a hammer.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95512">
    <skos:scopeNote xml:lang="en">A specific type of hand held  hollowed wooden clapper, known in Europe from medieval times onwards.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95513">
    <skos:scopeNote xml:lang="en">An instrument strung with metal pieces which sound when shaken.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95514">
    <skos:scopeNote xml:lang="en">A triangle of metal which, when struck, produces a note.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95515">
    <skos:scopeNote xml:lang="en">An instrument whirled to produce sound by a piece of flexible wood hitting against a ratchet wheel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95516">
    <skos:scopeNote xml:lang="en">An instrument made by inserting a stick through a membrane stretched over a hollow vessel then played by rubbing the stick.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95517">
    <skos:scopeNote xml:lang="en">Instruments of psaltery and dulcimer type.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95518">
    <skos:scopeNote xml:lang="en">A framed instrument, in which strings are plucked or hit, operated from a keyboard.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95519">
    <skos:scopeNote xml:lang="en">An instrument played mainly by plucking the strings. Use narrower term where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95521">
    <skos:scopeNote xml:lang="en">An instrument in which strings are vibrated by an internal wheel cranked by a handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95522">
    <skos:scopeNote xml:lang="en">An instrument where vibrating air is confined by a tube. Use narrower terms where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95524">
    <skos:scopeNote xml:lang="en">An instrument in which air is made to vibrate by a cane reed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95525">
    <skos:scopeNote xml:lang="en">A composite instrument in which air is forced through one or more drones and chanter from an inflated bag or bladder.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95526">
    <skos:scopeNote xml:lang="en">A wooden or metal object used to provide a rhythm by striking another object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95527">
    <skos:scopeNote xml:lang="en">A strung object used to produce sound usually from a string instrument eg a violin bow.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95529">
    <skos:scopeNote xml:lang="en">A stick used to beat a drum.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95533">
    <skos:scopeNote xml:lang="en">Use type of instrument where known.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95535">
    <skos:scopeNote xml:lang="en">A part of a musical instrument played by the feet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95538">
    <skos:scopeNote xml:lang="en">A thin board forming part of a musical instrument and placed in a position to strengthen or increase its sound.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95539">
    <skos:scopeNote xml:lang="en">The part of a musical instrument in which notes resonate and increase the sound of the instrument.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95540">
    <skos:scopeNote xml:lang="en">Part of an instrument that is used to modify or limit the sound of a note.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95542">
    <skos:scopeNote xml:lang="en">A device allowing a variable amount of air through in a single direction which varies the note produced.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95543">
    <skos:scopeNote xml:lang="en">The part of an organ or similar instrument into which air is pushed then is emitted through the pipes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95549">
    <skos:scopeNote xml:lang="en">An enclosed, round bell with a slit, sounded by a loose internal pellet.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95590">
    <skos:scopeNote xml:lang="en">A pipe designed for smoking opium.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95600">
    <skos:scopeNote xml:lang="en">Clothing worn specifically for formalised dancing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95610">
    <skos:scopeNote xml:lang="en">Line used with hooks attached to it in order to catch fish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95611">
    <skos:scopeNote xml:lang="en">A long tapered flexible pole used with a fishing line and usually with a fishing reel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95612">
    <skos:scopeNote xml:lang="en">An object that supports another in water, eg float on a fishing line or net.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95613">
    <skos:scopeNote xml:lang="en">A horn used in hunting to give signals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95614">
    <skos:scopeNote xml:lang="en">An object used to retrieve birds used in hawking. Consists of feathers tied to a rope, food is contained in the lure whilst training the birds.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95615">
    <skos:scopeNote xml:lang="en">A toy in the image of a human being.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95616">
    <skos:scopeNote xml:lang="en">A round object used in games.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95620">
    <skos:scopeNote xml:lang="en">A chequered board used to play chess.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95621">
    <skos:scopeNote xml:lang="en">A gaming piece used specifically to play chess.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95623">
    <skos:scopeNote xml:lang="en">A metal spur fitted to the leg of a fighting cock as an aid in fighting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95627">
    <skos:scopeNote xml:lang="en">A heavy disc, usually thrown.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95628">
    <skos:scopeNote xml:lang="en">A flat, oblong gaming piece marked with spots used to play dominoes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95630">
    <skos:scopeNote xml:lang="en">A board marked up to play a game upon.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95631">
    <skos:scopeNote xml:lang="en">A box in which one or more games are stored.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95635">
    <skos:scopeNote xml:lang="en">Straps fastened around the legs of a hawk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95636">
    <skos:scopeNote xml:lang="en">A small ball, usually of glass or porcelain, used in games.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95637">
    <skos:scopeNote xml:lang="en">A toy designed to exercise the ingenuity.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95638">
    <skos:scopeNote xml:lang="en">A ring, often metal, which is used to be thrown as part of a game.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95639">
    <skos:scopeNote xml:lang="en">A clay tube with a small bowl at the end used for smoking tobacco.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95642">
    <skos:scopeNote xml:lang="en">An item designed to be played with by children.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95643">
    <skos:scopeNote xml:lang="en">A cup offered as a prize in a contest.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95648">
    <skos:scopeNote xml:lang="en">A peg or upright object which is the target of a ball in skittles.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95649">
    <skos:scopeNote xml:lang="en">A circular toy which spins on a point. Can be kept spinning by whipping with a lash.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95656">
    <skos:scopeNote xml:lang="en">A receptacle used as a home for bees, traditionally made of thick straw work in the shape of a dome,but sometimes made of wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95660">
    <skos:scopeNote xml:lang="en">A bell worn by a cow to identify its location.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95661">
    <skos:scopeNote xml:lang="en">A handheld serrated device for grooming horses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95662">
    <skos:scopeNote xml:lang="en">A strap passing underneath the animal to hold saddle in place.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95663">
    <skos:scopeNote xml:lang="en">A rope, clog or fetter used to limit the movement of animals through the tying of two or more feet together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95667">
    <skos:scopeNote xml:lang="en">A strap or series of straps and or bars worn over the mouth of an animal to prevent it biting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95669">
    <skos:scopeNote xml:lang="en">A rope, cord etc used to hold or secure animals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95670">
    <skos:scopeNote xml:lang="en">Headgear for a horse, usually consisting of a series of buckled straps and a mouthpiece, bridle bit, by which the horse is controlled.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95671">
    <skos:scopeNote xml:lang="en">A metal mouth piece used to control an animal, usually used on a horse.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95672">
    <skos:scopeNote xml:lang="en">Attachments that form part of the bridle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95679">
    <skos:scopeNote xml:lang="en">Thinner and narrower than a horse shoe these are also rarer as donkeys tend to be shod less often than horses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95681">
    <skos:scopeNote xml:lang="en">A spiked stick, the spiked tip frequently of metal, used to urge livestock forward.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95682">
    <skos:scopeNote xml:lang="en">The arrangement of straps used to control an animal and/or to attach the animal to a vehicle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95686">
    <skos:scopeNote xml:lang="en">A device in the form of a loop with a flat base hung on either side of a saddle to support the rider's foot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95687">
    <skos:scopeNote xml:lang="en">A piece of equipment fastened on an animal for carrying loads, including riders, or for assisting in traction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95689">
    <skos:scopeNote xml:lang="en">An object for touching or pricking an animal's sides to increase control of it, usually used with horses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95692">
    <skos:scopeNote xml:lang="en">A perforated strip of metal for shoeing the bifurcated hoof of an ox.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95694">
    <skos:scopeNote xml:lang="en">A bag containing food hung around a horse's head.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95696">
    <skos:scopeNote xml:lang="en">A shaped piece of iron perforated for nails and used on horses.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95700">
    <skos:scopeNote xml:lang="en">A form of temporary horseshoe, of Roman date, used when unshod animals were brought onto metalled roads. Usually consists of flat plate, winged sides and hooked heel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95701">
    <skos:scopeNote xml:lang="en">A clip used to attach pieces of harness together.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95703">
    <skos:scopeNote xml:lang="en">A hook on harness to help attach items.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95704">
    <skos:scopeNote xml:lang="en">Fittings for animal harness.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95705">
    <skos:scopeNote xml:lang="en">Decorative fitting hung from harness.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95706">
    <skos:scopeNote xml:lang="en">A ring fixed to a vehicle through which the reins were passed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95711">
    <skos:scopeNote xml:lang="en">A vessel with a specially adapted mouthpiece, to assist in feeding young animals and humans.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95712">
    <skos:scopeNote xml:lang="en">A heated iron used to label, burn or mark animals, slaves, criminals etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95714">
    <skos:scopeNote xml:lang="en">A restraining ring usually linked to another.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95715">
    <skos:scopeNote xml:lang="en">A chain used to inhibit a slave's freedom.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95716">
    <skos:scopeNote xml:lang="en">An encircling ornament for the head, usually denoting sovereignty.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95717">
    <skos:scopeNote xml:lang="en">An ornamental wand or rod carried as a symbol of authority</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95718">
    <skos:scopeNote xml:lang="en">A wooden framework with holes for the feet, and occassionally hands, in which the offender was restrained.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95719">
    <skos:scopeNote xml:lang="en">A wooden framework with holes for the head and hands, in which the offender stood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95720">
    <skos:scopeNote xml:lang="en">A structure for hanging criminals, often used to suspend criminals after execution, consisting of one upright post with an arm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95721">
    <skos:scopeNote xml:lang="en">A two post structure with cross beam for hanging criminals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95722">
    <skos:scopeNote xml:lang="en">A chair fixed to the end of a plank which was pivoted to allow the incumbent of the chair to be ducked into water as a punishment.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95723">
    <skos:scopeNote xml:lang="en">A post to which the offender is tied to be whipped.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95725">
    <skos:scopeNote xml:lang="en">The heraldic bearings or shield of a person, family or corporation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95727">
    <skos:scopeNote xml:lang="en">A stone which bears an inscription commemorating an event or person.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95728">
    <skos:scopeNote xml:lang="en">An inscribed marker stone found on Hadrian's Wall.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95730">
    <skos:scopeNote xml:lang="en">A stone with the date on it, sometimes of an event, person etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95732">
    <skos:scopeNote xml:lang="en">A sculpture on top of a tomb etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95736">
    <skos:scopeNote xml:lang="en">A piece of metal, usually in the form of a disc, struck or cast with an inscription or device to commemorate an event, or awarded as a mark of distinction.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95756">
    <skos:scopeNote xml:lang="en">A tool used in etching which is the use of acid to breakdown parts of a metal plate in order to create an image.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95757">
    <skos:scopeNote xml:lang="en">A tool used to incise or ipress images.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95759">
    <skos:scopeNote xml:lang="en">Associated group of drawing implements.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95760">
    <skos:scopeNote xml:lang="en">The sculpted head, shoulders and breast of a person.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95761">
    <skos:scopeNote xml:lang="en">A carved bust, figure or representation usually fixed to the bow of a ship.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95763">
    <skos:scopeNote xml:lang="en">A light plough used to break up the earth. It does not have a mouldboard to turn the earth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95766">
    <skos:scopeNote xml:lang="en">A tool used to cut or split wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95767">
    <skos:scopeNote xml:lang="en">A missile consisting of a number of weights joined together by cord. The bolas entangles the legs of a target causing it to fall.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95768">
    <skos:scopeNote xml:lang="en">A large container with lip and handle usually for milk.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95771">
    <skos:scopeNote xml:lang="en">A storage container designed to contain corn.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95772">
    <skos:scopeNote xml:lang="en">A stick for digging up roots etc. Sometimes a stone weight is attached.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95774">
    <skos:scopeNote xml:lang="en">A long pointed weapon used to catch fish by stabbing.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95775">
    <skos:scopeNote xml:lang="en">A trap designed and used to catch fish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95776">
    <skos:scopeNote xml:lang="en">A net used in fishing to catch or land fish.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95777">
    <skos:scopeNote xml:lang="en">A tool for threshing grain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95778">
    <skos:scopeNote xml:lang="en">A pronged iron hook used in cookery.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95779">
    <skos:scopeNote xml:lang="en">A shaped stone, which could be hand held, used in combination with a saddle quern to grind or rub grain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95780">
    <skos:scopeNote xml:lang="en">A barbed spear head used to catch marine life, usually has a rope or line attached to it.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95781">
    <skos:scopeNote xml:lang="en">A frame set with teeth used to drag over ploughed fields to break down the earth clods etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95782">
    <skos:scopeNote xml:lang="en">A tool used for weeding and breaking up the ground prior to planting.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95784">
    <skos:scopeNote xml:lang="en">A long rope with a noose at one end for catching animals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95785">
    <skos:scopeNote xml:lang="en">A heavy bladed knife.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95786">
    <skos:scopeNote xml:lang="en">A tool used for digging where the blade is at right angles to the handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95791">
    <skos:scopeNote xml:lang="en">A large stone used to grind grain or similar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95792">
    <skos:scopeNote xml:lang="en">An partly-worked millstone that is still to be finished.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95793">
    <skos:scopeNote xml:lang="en">An object designed to float in water and to support a net.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95794">
    <skos:scopeNote xml:lang="en">A weight used to sink a fishing net in water.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95795">
    <skos:scopeNote xml:lang="en">A tool with a pointed head for breaking ground.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95796">
    <skos:scopeNote xml:lang="en">A pick with a point at one end and a cutting blade at the other end.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95797">
    <skos:scopeNote xml:lang="en">A long handled fork with two or three long curved tines for tossing straw or hay.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95798">
    <skos:scopeNote xml:lang="en">An agricultural implement with sharp blades for cutting or turning over the earth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95801">
    <skos:scopeNote xml:lang="en">A tool with a curved blade used for pruning.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95802">
    <skos:scopeNote xml:lang="en">A knife designed to be used for pruning plants.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95803">
    <skos:scopeNote xml:lang="en">A toothed, handled tool used to drag objects either to gather them together eg grass or hay, or to level them out eg sand or earth.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95804">
    <skos:scopeNote xml:lang="en">A machine for cutting down cereal crops.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95805">
    <skos:scopeNote xml:lang="en">A hooked blade used to cut crops. All the blade is to one side of the handle rather than being on both sides as in a sickle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95806">
    <skos:scopeNote xml:lang="en">A container for the storage of rice.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95807">
    <skos:scopeNote xml:lang="en">A mowing implement with a large curved blade and a long handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95808">
    <skos:scopeNote xml:lang="en">A small pair of shears with crossed blades, usually used for pruning.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95809">
    <skos:scopeNote xml:lang="en">Scissor like tool, usually larger than scissors, used for cutting, pruning or trimming.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95810">
    <skos:scopeNote xml:lang="en">A handled tool with a broad blade with slightly raised sides used for scooping or shovelling.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95811">
    <skos:scopeNote xml:lang="en">A tool with a curved blade and a short handle. The blade is on both sides of a line extended from the handle. If just on one side use reaping hook.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95812">
    <skos:scopeNote xml:lang="en">A tool used for digging the ground.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95815">
    <skos:scopeNote xml:lang="en">A machine for mechanically separating the grain from the straw and husks.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95816">
    <skos:scopeNote xml:lang="en">A tray used for separating the grain from husks and straw.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95817">
    <skos:scopeNote xml:lang="en">An object used to catch animals.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95818">
    <skos:scopeNote xml:lang="en">A tool with a handle and curved blade designed to cut through grass sods.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95819">
    <skos:scopeNote xml:lang="en">A small cutting hook on a long handle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95820">
    <skos:scopeNote xml:lang="en">A device for separating grain from chaff by means of a wind or current of air.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95821">
    <skos:scopeNote xml:lang="en">A large fork with wide spaces between its tines, used to throw grain etc into a breeze to separate grain from chaff.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95822">
    <skos:scopeNote xml:lang="en">A large, flattish basket used in winnowing the chaff from the grain.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95823">
    <skos:scopeNote xml:lang="en">A fan used to create an air current to separate grain from chaff.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95826">
    <skos:scopeNote xml:lang="en">A rock carving, especially a prehistoric one.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95827">
    <skos:scopeNote xml:lang="en">A three dimensional representation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95831">
    <skos:scopeNote xml:lang="en">A decorative band or feature.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95834">
    <skos:scopeNote xml:lang="en">A three panelled altar decoration that can be closed.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95835">
    <skos:scopeNote xml:lang="en">A figure, representation or image, which is itself regarded as sacred.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95836">
    <skos:scopeNote xml:lang="en">A structure consecrated for devotional purposes.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95838">
    <skos:scopeNote xml:lang="en">The forms of armour used to protect various parts of the body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95839">
    <skos:scopeNote xml:lang="en">A cross designed to be placed upon an altar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95840">
    <skos:scopeNote xml:lang="en">A vase used on the altar.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95842">
    <skos:scopeNote xml:lang="en">Use for the function that the armour is intended for, eg parades, field use, decorative etc.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95843">
    <skos:scopeNote xml:lang="en">Use for the construction style of the armour, eg plate armour.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95863">
    <skos:scopeNote xml:lang="en">Use for items of personal equipment used in a military context, eg AMMUNITION POUCH, PRIMING FLASK.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95868">
    <skos:scopeNote xml:lang="en">A vessel for keeping the ashes of the dead after cremation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95869">
    <skos:scopeNote xml:lang="en">A container for keeping the ashes of the dead after cremation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95870">
    <skos:scopeNote xml:lang="en">A covered chalice used for the Eucharist.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95872">
    <skos:scopeNote xml:lang="en">A vessel containing a religious oil or unguent.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95873">
    <skos:scopeNote xml:lang="en">A necklace holding charms or being itself a charm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95874">
    <skos:scopeNote xml:lang="en">A bracelet holding charms or being itself a charm.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95876">
    <skos:scopeNote xml:lang="en">An object which contains or is inscribed with spells against disease, witchcraft etc, or providing luck to the wearer.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95877">
    <skos:scopeNote xml:lang="en">A stemmed cup used for holding the wine during communion.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95878">
    <skos:scopeNote xml:lang="en">A staff used for ceremonial purposes, often highly decorated.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95880">
    <skos:scopeNote xml:lang="en">A vessel in which incense is burnt.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95881">
    <skos:scopeNote xml:lang="en">A carved head of Iron Age or Roman date, with uncertain use.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95890">
    <skos:scopeNote xml:lang="en">Chests connected with the burial of a body.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95891">
    <skos:scopeNote xml:lang="en">Head wear of a bride.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95892">
    <skos:scopeNote xml:lang="en">A gun designed to fire shells, etc at a high angle.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95893">
    <skos:scopeNote xml:lang="en">Movable stand for carrying a body to its grave.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95896">
    <skos:scopeNote xml:lang="en">A trinket worn as a protection against evil.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95897">
    <skos:scopeNote xml:lang="en">A miniature lead phial worn around the neck as a religious pilgrim sign, generally medieval.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95899">
    <skos:scopeNote xml:lang="en">A musket fired by use of a flintlock. A gunflint is held in the lock which on pulling the trigger pushes back the pan cover creating sparks which set off the powder in the pan causing a flame to go through and set off the charge in the barrel.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95900">
    <skos:scopeNote xml:lang="en">A long barrelled firearm. The barrel is spirally grooved on the interior, which gives the bullet a spinning motion leading to greater accuracy over a longer range.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95901">
    <skos:scopeNote xml:lang="en">A smooth bore weapon usually for firing shot as opposed to bullets.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95903">
    <skos:scopeNote xml:lang="en">A container, in the form of an urn, for keeping the ashes of the dead after cremation.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95905">
    <skos:scopeNote xml:lang="en">A container within which a body is placed for burial, usually made of lead or wood.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95910">
    <skos:scopeNote xml:lang="en">A figurative or decorative object made of corn, used as a charm for luck or to ward off evil spirits.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95912">
    <skos:scopeNote xml:lang="en">An object consisting of a vertical member with a transverse member. Usually there is a religious or ritual significance to such an object.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95918">
    <skos:scopeNote xml:lang="en">A pendant in the shape of a cross.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95919">
    <skos:scopeNote xml:lang="en">The staff or crook of a bishop or abbot.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95920">
    <skos:scopeNote xml:lang="en">Military weapon with long shaft and bill style head. For agricultural style bills use bill hook.</skos:scopeNote>
  </rdf:Description>

  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/mda_obj/concepts/95921">
