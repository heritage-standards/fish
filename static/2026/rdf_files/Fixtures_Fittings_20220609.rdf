				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Deck Plate</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A metal plate forming part of the deck.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower>
			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146598">
				<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146705"/>
				<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
