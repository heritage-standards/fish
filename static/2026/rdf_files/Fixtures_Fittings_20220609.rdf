				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Fiddle Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A single shelled block containing two sheaves carried on separate pins one on top of the other. The lower portion of the shell is narrower and the whole lies flatter to a mast than a DOUBLE BLOCK.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
