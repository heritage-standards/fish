			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146556">
				<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/147071"/>
				<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
				<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146556</dc:identifier>
				<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
				<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
				<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Centreboard</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A board which can be lowered in a shallow draught vessel to increase the vessel's lateral area and keel thus increasing the resistance to leeway.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
