				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Deadwood</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A block of timber, in both the bow and stern of a vessel, positioned just above the keel where the hull is narrow and the angle of the timbers at its most acute.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146773"/>
