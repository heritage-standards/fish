		<skos:narrower>
			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146503">
				<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146667"/>
				<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
				<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146503</dc:identifier>
				<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
				<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
				<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Bonaventure Gaff Course</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A fore and aft sail set on a gaff on the bonaventure mast in older sailing vessels.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
		<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146667</dc:identifier>
		<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
		<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
		<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
		<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
		<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
		<skos:prefLabel xml:lang="en">Fore And Aft Sail</skos:prefLabel>
		<skos:scopeNote xml:lang="en">Any sail which is rigged so that the luff of the sail abuts the mast or is attached to a stay. The sail can be extended by a boom at the foot and a gaff at the head or by a single sprit or yard.</skos:scopeNote>
	</skos:Concept>
