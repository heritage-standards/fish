		<skos:prefLabel xml:lang="en">Anchor</skos:prefLabel>
		<skos:scopeNote xml:lang="en">A heavy implement, now usually made of metal, designed to be dropped from a vessel and embedded in the seabed to hold the vessel in a desired position.</skos:scopeNote>
	</skos:Concept>
