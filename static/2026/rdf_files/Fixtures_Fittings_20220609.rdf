				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Quadruple Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A single shelled block containing four sheaves revolving on the same pin, allowing four ropes of equal thickness to be worked through it.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
