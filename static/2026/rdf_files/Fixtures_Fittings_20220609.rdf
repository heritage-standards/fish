				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Sacrificial Anode</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A terminal, usually made of zinc, attached to the iron or steel hull of a vessel, from which a charge flows to inhibit corrosion whilst the anode gradually dissolves.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
