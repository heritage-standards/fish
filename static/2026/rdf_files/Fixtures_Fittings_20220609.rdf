		<skos:prefLabel xml:lang="en">Davit</skos:prefLabel>
		<skos:scopeNote xml:lang="en">A small crane, derrick or pair of curved pillars, usually fitted on the deck close to the side of a vessel, used for raising and lowering lifeboats, anchors etc.</skos:scopeNote>
	</skos:Concept>
