				<skos:prefLabel xml:lang="en">Deck Beam Brace</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A brace used to support and strengthen a deck beam.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146776"/>
