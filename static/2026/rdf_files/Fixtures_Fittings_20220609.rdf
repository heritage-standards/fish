				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Carling</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A short piece of timber ranging fore and aft between beams to strengthen the vessel.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower>
			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146601">
