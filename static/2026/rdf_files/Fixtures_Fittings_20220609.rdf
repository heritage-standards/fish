				<skos:prefLabel xml:lang="en">Triple Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A single shelled block containing three sheaves revolving on the same pin, allowing three ropes of equal thickness to be worked through it.</skos:scopeNote>
			</skos:Concept>
