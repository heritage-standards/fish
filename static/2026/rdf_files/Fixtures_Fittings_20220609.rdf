				<skos:prefLabel xml:lang="en">Snatch Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A block with an opening on the side enabling a rope to be fixed around the sheave.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
