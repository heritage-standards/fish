		<skos:prefLabel xml:lang="en">Shoe Block</skos:prefLabel>
		<skos:scopeNote xml:lang="en">A single shelled block with two sheaves revolving on pins at right angles to each other.</skos:scopeNote>
	</skos:Concept>
	<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146496">
