				<skos:prefLabel xml:lang="en">Double Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A single shelled block containing two sheaves revolving on the same pin, allowing two ropes of equal thickness to be worked through it.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
