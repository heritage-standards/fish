				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Deadeye</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A circular block, usually made from lignum vitae, pierced with three holes and grooved around the circumference used to secure the end of a shroud to a chain plate.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
