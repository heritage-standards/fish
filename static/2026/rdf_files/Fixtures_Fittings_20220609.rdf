				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Deck Plank</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A plank forming part of the deck.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/147082"/>
