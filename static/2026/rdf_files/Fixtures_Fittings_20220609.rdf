		<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
		<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
		<skos:prefLabel xml:lang="en">External Frame</skos:prefLabel>
		<skos:scopeNote xml:lang="en">The main skeleton of a vessel to which the outer hull is attached.</skos:scopeNote>
	</skos:Concept>
