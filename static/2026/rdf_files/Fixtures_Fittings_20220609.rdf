	<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146647">
		<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146517"/>
		<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
		<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146647</dc:identifier>
		<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
		<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
		<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
		<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
		<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
		<skos:prefLabel xml:lang="en">Fiddlehead</skos:prefLabel>
		<skos:scopeNote xml:lang="en">A carved stemhead in the form of a scrollturning aft and inwards like the head of a violin. Originally adopted by small sailing vessels with no figurehead as a piece of bow decoration.</skos:scopeNote>
	</skos:Concept>
	<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146517">
		<skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146647"/>
		<skos:narrower>
			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146491">
				<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146517"/>
				<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
				<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146491</dc:identifier>
				<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
				<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
				<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Billet Head</skos:prefLabel>
				<skos:scopeNote xml:lang="en">Carved ornamentation at the bow of a vessel which does not have a figurehead.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:narrower>
			<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146648">
				<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146517"/>
				<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
				<dc:identifier>http://purl.org/heritagedata/schemes/572/concepts/146648</dc:identifier>
				<dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-06-09T09:51:32</dc:issued>
				<cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
				<cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Figurehead</skos:prefLabel>
				<skos:scopeNote xml:lang="en">An ornamental carved and painted figure erected on the bow of a vessel as a decorative emblem. Usually signifying some aspect of the vessel's name or function.</skos:scopeNote>
			</skos:Concept>
		</skos:narrower>
		<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146611"/>
		<skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/572"/>
