				<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
				<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
				<skos:prefLabel xml:lang="en">Jewel Block</skos:prefLabel>
				<skos:scopeNote xml:lang="en">A block at the end of the main and foretop yards through which the halyard of a studdingsail is run.</skos:scopeNote>
			</skos:Concept>
