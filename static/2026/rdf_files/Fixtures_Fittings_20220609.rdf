		<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
		<skos:prefLabel xml:lang="en">Bow Decoration</skos:prefLabel>
		<skos:scopeNote xml:lang="en">Ornamentation used to enhance the appearance of the front, or bow, of a vessel.</skos:scopeNote>
	</skos:Concept>
