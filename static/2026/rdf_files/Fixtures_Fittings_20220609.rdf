		<cc:attributionName xml:lang="en">Historic England</cc:attributionName>
		<dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
		<skos:prefLabel xml:lang="en">Framing Components</skos:prefLabel>
		<skos:scopeNote xml:lang="en">Parts defining the strength and shape of the structure of a vessel  and which provide the framework for the vessel's planking or plating.</skos:scopeNote>
	</skos:Concept>
	<skos:Concept rdf:about="http://purl.org/heritagedata/schemes/572/concepts/146636">
		<skos:broader rdf:resource="http://purl.org/heritagedata/schemes/572/concepts/146702"/>
