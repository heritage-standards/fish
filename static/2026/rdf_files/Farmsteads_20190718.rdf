    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:scopeNote xml:lang="en">An isolated barn, cow house or shelter shed with a hayloft. Typically found in areas where farmsteads and fields were sited at a long distance from each other.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147430">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147463"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147430</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Row Plan</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:scopeNote xml:lang="en">A farmstead where the main range of working buildings are attached in-line and form a long row often facing a series of yards.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147404">
    <skos:prefLabel xml:lang="en">Pigsty</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147468"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
