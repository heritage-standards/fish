    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A furnace or oven for burning, baking or drying. Use specific type where known.</skos:scopeNote>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147454"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
