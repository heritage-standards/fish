    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147500">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Manorial Farm</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147500</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A medieval high status farmstead, acting as the centre of the estate, directly controlled by the lord and used for the benefit of his household and dependents.</skos:scopeNote>
    <skos:altLabel xml:lang="en">Demesne Farm</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147455"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147458">
    <skos:prefLabel xml:lang="en">Courtyard Plan</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147378"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147458</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A farmstead where the working buildings are arranged around a yard.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147463"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147421">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147421</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Vaccary</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A monastic cattle farm with associated buildings, paddocks and pastures. A stock farm for cattle. Most vaccaries are of 12th or 13th century origin, and were built for ecclesiastical or lay lords. They are concentrated in the Pennines.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147455"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147462">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:prefLabel xml:lang="en">Agricultural Complexes And Buildings</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147462</dcterms:identifier>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147464"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147409">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147409</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">Room, usually part of another building and located close to the cattle yard, for storing and preparing roots and other animal feed.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Root And Fodder Store</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147466">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147467"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147466</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147425"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147433"/>
    <skos:scopeNote xml:lang="en">A structure providing shelter for animals. Use more specific type where known.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147468"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147498"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147471"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Animal Housing</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147459">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged as two linked ranges to create an L-shape. They can comprise a barn and an attached shelter shed to a cattle yard or an interlinked cattle housing and fodder range.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Regular Courtyard L Plan</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147459</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147419">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147419</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Toft</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:scopeNote xml:lang="en">The footprint of a house, sometimes raised or marked by earthworks where the house has been removed.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147471">
    <skos:prefLabel xml:lang="en">Stabling</skos:prefLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147416"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A structure providing secure housing for horses.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147471</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147466"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/159262">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147420"/>
    <skos:prefLabel xml:lang="en">Bastle (Defensive)</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147363"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147426"/>
    <skos:scopeNote xml:lang="en">A stone building with thick outer walls and small infrequent windows whose entrance and any internal stairs are capable of defence. Many contain stone vaulted ground floor ceilings although in some instances substantial timbers have been used.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/159262</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147379">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147510"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147460"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147459"/>
    <skos:prefLabel xml:lang="en">Regular Courtyard Plan</skos:prefLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147542"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147507"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A farmstead where the working buildings are carefully planned as linked ranges and are focused around one or more working yards. They often result from a single phase of building.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147379</dcterms:identifier>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147551"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147458"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147509"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147508"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147461"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147551">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged around all four sides of the yard.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Regular Courtyard Full Plan</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147551</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147418">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147418</dcterms:identifier>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Staddle Barn</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A threshing barn, usually timber framed which is raised on staddle stones.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147359"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147393">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147467"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Linhay</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:scopeNote xml:lang="en">A two storied and open fronted structure comprising a cattle or cart shelter on the ground floor with a hayloft above. Most common in South West England.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147393</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147392">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147426"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A linear range of one construction comprising a farmhouse with attached (but not internally linked) to its working buildings, usually with a large door to the barn for corn or hay and smaller doors to the cowhouse and/or stable.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147392</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Laithe House</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147359">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147381"/>
    <skos:prefLabel xml:lang="en">Barn</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147359</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147398"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147358"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147382"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147362"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147360"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147418"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building for the storage and processing of grain crops and for housing straw, farm equipment and occasionally livestock and their fodder. Use more specific type where known.</skos:scopeNote>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147386"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147361"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147434">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147434</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147467"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:altLabel xml:lang="en">Byre</skos:altLabel>
    <skos:scopeNote xml:lang="en">A building in which cattle are housed, normally tethered in stalls.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Cow House</skos:prefLabel>
    <skos:altLabel xml:lang="en">Calf House</skos:altLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Hovel</skos:altLabel>
    <skos:altLabel xml:lang="en">Shippon</skos:altLabel>
    <skos:altLabel xml:lang="en">Cattle Shed</skos:altLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147548">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147548</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:altLabel xml:lang="en">Fold Yard</skos:altLabel>
    <skos:prefLabel xml:lang="en">Sheep Yard</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147546"/>
    <skos:scopeNote xml:lang="en">A yard for sheep that typically projects from the farmstead.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147425">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Poultry Housing</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147394"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147441"/>
    <skos:scopeNote xml:lang="en">Structures providing secure housing for poultry. Use more specific type where known.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Fowl House</skos:altLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147443"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147406"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147425</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147466"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147395">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147426"/>
    <skos:altLabel xml:lang="en">Long House</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147395</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Longhouse</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building that housed humans and cattle under one roof, with a shared entrance providing access to the cattle housing (usually downslope) and the dwelling area.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147371">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Cider House</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building, or part of a building, for the milling and pressing of cider apples to produce cider (or pears for perry) and for storing the drink in barrels.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:altLabel xml:lang="en">Ciderhouse</skos:altLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147371</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147505">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147505</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:scopeNote xml:lang="en">A farmstead where mostly detached buildings have developed around three sides of an open cattle yard.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147378"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Loose Courtyard (Three Sided)</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147420">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Tower House</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/159262"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Peel Tower</skos:altLabel>
    <skos:scopeNote xml:lang="en">A fortified tower house of between two and four storeys, mostly 14th - 16th century in date and concentrated in the northern border counties.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:altLabel xml:lang="en">Pele Tower</skos:altLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147420</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147396">
    <skos:scopeNote xml:lang="en">A low ceilinged building for the malting of barley before brewing, specifically for the germination of the crop on malting floors and then drying in a kiln.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147396</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Maltings</skos:prefLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147389">
    <skos:altLabel xml:lang="en">Wheel House</skos:altLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147389</dcterms:identifier>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147360"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Horse Engine House</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:scopeNote xml:lang="en">A round or polygonal building containing a horse engine used for powering threshing, and other, machinery; typically found projecting from barns.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147496">
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Boiling House</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building, or part of a building for the boiling and preparation of animal feed, usually attached to pigsties.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147496</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147502">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A farmstead where the farmhouse and working buildings are attached and in-line. They can comprise the extension of linear farmsteads.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147502</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147463"/>
    <skos:prefLabel xml:lang="en">L Plan (House Attached)</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147507">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147507</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Regular Courtyard F Plan</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged as an F-shaped plan around one or two cattle yards. Cattle housing and stabling typically extend as two ranges from the longer main range which includes a barn or mixing house.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147499">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147499</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:scopeNote xml:lang="en">A house for farm workers and their families.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:prefLabel xml:lang="en">Workers House</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147441">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:altLabel xml:lang="en">Chicken House</skos:altLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147441</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147425"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:altLabel xml:lang="en">Hen Cote</skos:altLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Hen House</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A structure providing secure housing for Hens.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147372">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147546"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147372</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Covered Yard</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A covered yard for the shelter of cattle that is attached to a building, first used on planned and model farms of the 1850s to 1870s. It became increasingly common from the 1880s to roof over former open yards with timber or metal-framed superstructures.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147416">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:prefLabel xml:lang="en">Stable</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147471"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147416</dcterms:identifier>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A building, or part of a building, for housing horses or working oxen, storing and maintaining their tackle and sometimes housing farm workers.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147460">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147460</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged around three sides of a yard which is open to one side.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Regular Courtyard U Plan</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147410">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:altLabel xml:lang="en">Shielding</skos:altLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147464"/>
    <skos:scopeNote xml:lang="en">Summer pasture for cattle or sheep with associated temporary huts for domestic or agricultural use.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Shieling</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147410</dcterms:identifier>
    <skos:altLabel xml:lang="en">Sheiling</skos:altLabel>
    <skos:altLabel xml:lang="en">Shealing</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Shiel</skos:altLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147394">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147468"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147394</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Loose Box</skos:prefLabel>
