    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147509</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged as two ranges at right angles to each other.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147433">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147498"/>
    <skos:scopeNote xml:lang="en">Housing for sheep, in the form of a shelter shed with low eaves (very difficult to identify, but usually detached from the main farmyard and facing a detached series of yards).</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
