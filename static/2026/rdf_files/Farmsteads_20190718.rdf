    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147406"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147466"/>
    <skos:scopeNote xml:lang="en">A structure providing secure housing for pigs. Use more specific type where known.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147427">
    <skos:prefLabel xml:lang="en">Shed</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A slight structure, or a modern wide span farm building, built for shelter or storage or for use as a workshop, either attached as a lean-to to a permanent building or separate. Use more specific type where known.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147427</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147412"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147405"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147367"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147510">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:scopeNote xml:lang="en">An uncommon form of a regular courtyard farmstead where the buildings are arranged in a Z-shaped form.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147510</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Regular Courtyard Z Plan</skos:prefLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147362">
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147362</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A multi-purpose, two-storey barn, built on a hillside with entrances at both levels to a first floor threshing barn and ground floor animal housing.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147359"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Bank Barn</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147397">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147397</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Mill</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
