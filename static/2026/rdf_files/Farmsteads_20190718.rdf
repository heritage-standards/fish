    <skos:prefLabel xml:lang="en">Yard</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An area enabling general movement and access to the farmhouse and working buildings and for livestock, the storage of harvested crops, timber and other products.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147374">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
