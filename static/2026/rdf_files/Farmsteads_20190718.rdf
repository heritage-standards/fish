    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:scopeNote xml:lang="en">A factory used for processing raw materials, such as corn to flour.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147363">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147363</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/159262"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/159263"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Bastle</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A stone building with stone flagged domestic accommodation above non-domestic ground floor accommodation, typically a byre. The domestic accommodation is accessible via an external ladder or stair, the non-domestic ground floor having a separate entrance.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147426"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147414">
    <skos:prefLabel xml:lang="en">Silage Clamp</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147414</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">An airtight container for the storage of freshly cut grass and its conversion into silage.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147402">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147402</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A farmstead, often of linear plan, where the working buildings are placed opposite and parallel to the house and attached working buildings with a relatively narrow space between.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:prefLabel xml:lang="en">Parallel Plan</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147463"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147512">
    <skos:scopeNote xml:lang="en">A dispersed farmstead where buildings are arranged around scattered yards which can be loose or regular in their form.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147376"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Dispersed Multi Yard Plan</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147512</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147508">
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:prefLabel xml:lang="en">Regular Courtyard H Plan</skos:prefLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147508</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147379"/>
    <skos:scopeNote xml:lang="en">Regular courtyard farmsteads where the buildings are arranged as an H-shaped plan, commonly with cattle housing to two or more cattle yards.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147412">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147467"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">An open fronted building facing onto a yard used for the sheltering of cattle.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147427"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147412</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Shelter Shed</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147511">
    <skos:scopeNote xml:lang="en">A dispersed farmstead where buildings and yards (regular or loose courtyard in their form) are sited alongside a routeway</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
