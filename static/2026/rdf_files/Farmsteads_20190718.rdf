    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">An area within a building (usually the barn or stable) for storing husks from the grain crop (chaff) for animal feed after it has been threshed and winnowed in the barn.</skos:scopeNote>
