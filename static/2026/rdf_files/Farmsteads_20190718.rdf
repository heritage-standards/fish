  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147370">
    <skos:prefLabel xml:lang="en">Chaff House</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147370</dcterms:identifier>
