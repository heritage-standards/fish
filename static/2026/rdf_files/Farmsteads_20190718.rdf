  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147503">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:scopeNote xml:lang="en">A farmstead where mostly detached buildings have developed around one side of an open cattle yard.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147378"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Loose Courtyard (One Sided)</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147503</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/159167">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building for the drying of corn after harvesting, with a slatted drying floor set above a kiln.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/159167</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Corn Drying Kiln</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147391"/>
    <skos:altLabel xml:lang="en">Grain Drying Kiln</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147415">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:scopeNote xml:lang="en">A tower for the airtight storage of freshly cut grass and its conversion into silage.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147415</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Silage Tower</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147426">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147392"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147426</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/159263"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Farmhouse</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The main dwelling house of a farm, it can be either detatched from or attached to the working buildings. The house can either share the main elevation with the working buildings or may face in a different direction, commonly into a garden area.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147363"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147395"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/159262"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147454">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A building in which hops are dried and stored. Known as an Oasthouse or Oast in south east England.</skos:scopeNote>
    <skos:altLabel xml:lang="en">Oast House</skos:altLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147454</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147391"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Hop Kiln</skos:prefLabel>
    <skos:altLabel xml:lang="en">Grain Drying Kiln</skos:altLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147467">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147394"/>
    <skos:prefLabel xml:lang="en">Cattle Housing</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147467</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
