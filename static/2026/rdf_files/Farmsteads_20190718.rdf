  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/159263">
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147426"/>
    <skos:altLabel xml:lang="en">House Over Byre</skos:altLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:altLabel xml:lang="en">Byre House</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147363"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/159263</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Bastle House</skos:altLabel>
    <skos:altLabel xml:lang="en">Bastel House</skos:altLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Bastle (Non Defensive)</skos:prefLabel>
    <skos:altLabel xml:lang="en">Byre Dwelling</skos:altLabel>
    <skos:scopeNote xml:lang="en">A stone building with external access to the domestic accommodation via a permanent stair. The ground floor is normally used as a byre in rural contexts, but in an urban setting it may be intended for one of a number of other non domestic uses.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147367">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147367</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147427"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:altLabel xml:lang="en">Waggon Shed</skos:altLabel>
    <skos:prefLabel xml:lang="en">Cart Shed</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A building used for housing and protecting from the weather carts, waggons and farm implements, often open-fronted.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147358">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147358</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A barn in which a central space is separated from side aisles by posts and braces.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Aisled Barn</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147359"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147381">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147359"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147381</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">An iron framed, open fronted building for the shelter of hay or corn. They typically date from the late 19th to the mid 20th centuries.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Dutch Barn</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147398">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:07:02</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147456"/>
    <skos:scopeNote xml:lang="en">A building, usually part of another building and located close to the cattle yard, where grain, cake and roots for animals would be prepared for animal feed.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/573"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/573/concepts/147359"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147398</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Mixing House</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147378">
    <skos:scopeNote xml:lang="en">A farmstead where mostly detached buildings have developed around one or more sides of an open cattle yard.</skos:scopeNote>
