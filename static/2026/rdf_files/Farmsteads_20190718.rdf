    <dcterms:identifier>http://purl.org/heritagedata/schemes/573/concepts/147386</dcterms:identifier>
    <skos:scopeNote xml:lang="en">An open-fronted building for the dry and well-ventilated storage of hay.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/573/concepts/147468">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
