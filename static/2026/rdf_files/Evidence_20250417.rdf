        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Unstratified Find</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Monument whose presence is inferred by discovery of unstratified artefacts, for instance in plough soil.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/135585">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82791"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/135585</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Artefact Scatter</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A distribution of artefacts indicating the presence, or former presence, of a monument.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/170672">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82791"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/170672</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Destroyed Artefact</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Any portable artefact of any material which does not qualify as a monument or structure in its own right, and which has been destroyed accidentally or deliberately, either by natural processes or by human agency, such as the explosion of ordnance.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/82791</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Find</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Monument whose existence is indicated by the discovery of isolated artefacts or an artefact scatter. Eg a scatter of roofing tiles indicating the presence of a building. Use narrow terms where circumstances of discovery are known.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/82792">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97293"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/171220">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82792"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/171220</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Magnetometer Reading</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A potential monument identified as a ferrous object detected using geophysical surveying equipment that detects localised anomalies in the Earth's magnetic field.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/82792</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Geophysical Evidence</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A monument visible as a trace on geophysical survey equipment</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/82796">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82797"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/82796</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Side Scan Sonar Contact</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An object projecting out of the sea bed detected by marine survey equipment that emits and receives high frequency sound waves projected sideways from a boat or towed array.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/82797">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82796"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/99976"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/82797</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Sonar Contact</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An object lying on the sea bed detected by marine survey equipment that emits and receives high frequency sound waves.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/82790">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82798"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/84565"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97293"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97294"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/82790</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Evidence</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Do not use</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/84564">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97294"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/87962"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97291"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/100510"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/141908"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/84564</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Building</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Monument with a roof and walls or evidence of these.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/100512">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/82791"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/100512</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Stratified Find</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/84569"/>
    <skos:scopeNote xml:lang="en">A Monument whose presence is inferred from artefacts found in stratified below ground deposits, as distinct from surface collection or chance find.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/141908">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/84564"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/141909"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/141908</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Moved Building</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A building which has been moved from its original site either through active human intervention or natural processes such as erosion. For structures or objects such as gravestones use MOVED STRUCTURE.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/141909">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/141908"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/84570"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/141909</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Moved Structure</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A manmade construction or object (such as a gravestone) which has been moved from its original site either through active human intervention or natural processes such as erosion. For buildings which have been moved use MOVED BUILDING.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/151454">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97294"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/151454</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Burial</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/84569"/>
    <skos:scopeNote xml:lang="en">The deliberate deposit of a body in the ground, usually located in a special area set aside for the purpose of burial, such as a graveyard or cemetery.</skos:scopeNote>
  </skos:Concept>

</rdf:RDF>