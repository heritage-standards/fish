        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Marine Magnetometer Reading</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Maritime monument identified as a ferrous object lying on the sea bed detected using marine surveying equipment that detects localised anomalies in the Earth's magnetic field.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/143438">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/99976"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/143438</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Multibeam Survey</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A marine survey in which a multielement transducer provides many (30150) individual soundings of the water depth and echo strength for each ping.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97293"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_evd"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_evd/concepts/99976</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-04-17T09:16:24</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Marine Geophysical Evidence</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/99975"/>
    <skos:scopeNote xml:lang="en">A monument visible as a trace on marine survey equipment</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_evd/concepts/82791">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_evd/concepts/97294"/>
