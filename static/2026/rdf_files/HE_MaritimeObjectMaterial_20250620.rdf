        <skos:prefLabel xml:lang="en">Paper</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A thin, flexible material made from the pulp of wood or other fibrous matter which is then pressed and dried to form sheets.</skos:scopeNote>
      </skos:Concept>
