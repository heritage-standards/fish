        <skos:prefLabel xml:lang="en">Shell</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, protective covering made largely of calcium salts secreted by soft bodied invertebrate animals.</skos:scopeNote>
      </skos:Concept>
