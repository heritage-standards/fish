    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Jade</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75371"/>
    <skos:scopeNote xml:lang="en">An ornamental green stone of the mineral nephrite.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/160192">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170818">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/160192"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170818</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Totternhoe Clunch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A relatively hard type of chalk that is sufficiently strong for use as a building stone. Quarried at Totternhoe, Bedfordshire.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/160192</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Chalk</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Soft, white, porous sedimentary rock, a form of limestone composed of the mineral calcite.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/164110">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/164111">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/164110"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/164111</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hertfordshire Puddingstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A conglomerate rock comprising well rounded flint pebbles in a very hard matrix of fine pale coloured sand, bound together by hard natural silica cement. The pebbles are usually coloured ochre or red and have black rims.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/164110</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Puddingstone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Conglomerate consisting of rounded flint pebbles held together in a natural silica and sand cement.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170838">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75385"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171272">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/170838"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171272</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Plastic</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Any of large class of polymers based on synthetic resins or modified natural polymers which may be moulded, extruded or cast while soft or liquid, which then set rigidly or slightly elastic in form.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170838</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Hydrocarbon</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An organic chemical compound composed exclusively of hydrogen and carbon atoms.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170896">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/171257"/>
