    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Bone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any of the pieces of hard tissue consisting largely of calcium phosphate that make up the skeleton of a vertebrate animal.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75345">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171262">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75345"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171262</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Mortar</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A mixture of lime or more recently cement with sand and water used for bonding stones or bricks.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75345</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Cement</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Originally obtained by burning limestone to produce quicklime. Now a fine grey powder made from a mixture of limestone and clay used with water and sand to make mortar or with water, sand and aggregate to make concrete.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75353">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75394"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75353</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Earthenware</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A claybased ceramic fired at low kiln temperatures (c.8001200 degrees). Essentially, earthenwares are porous and require glazing for most applications. This term has been used interchangeably with TERRACOTTA and with POTTERY</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75394">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75353"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75408">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75394"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75408</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Terracotta</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, unglazed, brown, versatile earthenware which can be used as a tile or moulded into statuary.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171210">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75394"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171210</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Porcelain</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard semitranslucent ceramic material made out of kaolin, quartz and feldspar which is biscuit fired at around 1000 degrees Celsius and glaze fired at around 1300 degrees Celsius.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75394</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pottery</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A ceramic made from clay and fired in a kiln or oven. This term has been used interchangeably with EARTHENWARE and with TERRACOTTA</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75361">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75361</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Glass</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/151858"/>
    <skos:scopeNote xml:lang="en">Transparent, hard substance made by fusing sodasilica which solidifies from a molten state.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75363">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75363</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Granite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A hard, coarse grained, durable igneous rock. Can be used decoratively or as a main material. Found throughout the country.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75405">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75363"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75364">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75364</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Greenstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Geologist's term for any dark coloured, slightly metamorphosed igneous rock. Index with specific stone type where given.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75371"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75373">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75373</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Lava</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hard, igneous rock formed from the cooling of molten volcanic magma.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75377">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75377</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Limestone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Sedimentary rock consisting mainly of calcium carbonate. Varying in grain size, colour and hardness, quarried and used throughout the country.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75379">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75379</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Marble</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Collective name for, in a true geological sense, a metamorphosed limestone, eg. Carrara marble, and, in the British sense any decorative stone that will take a polish, eg. Purbeck marble. In the latter's case index with specific stone type where given</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75396">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75396</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Sandstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Geologically sandstone consists of particles of quartz naturally cemented together by either silica, calcium or iron. It is this geological composition that accounts for the varying colours and grain sizes found in the many building sandstones.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75398">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75398</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Shale</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Soft, very fine grained, dark coloured, sedimentary rock which splits easily.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75403">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75403</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Slate</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Collective term for a hard, fine grained, dark coloured metamorphic rock, which splits easily; hence its common use as a roofing and flooring material, and a functional description for any rectangular, sheet, roofing material.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/142973">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/142973</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Dolerite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Coarse basaltic rock.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/143453">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/143453</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Schist</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Medium to coarse grained metamorphic rock, colour being determined by its dominant mineral. Often used for floor and wall claddin</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/146351"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/160192"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/164110"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/166986"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170068">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170068</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Amphibolite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A coarse grained metamorphic rock that is composed maily of green, brown or black amphibole minerals and plagioclase feldspar. Amphiboles are usually members of the hornblende group.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170069">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170069</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Siltstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A sedimentary rock primarily composed of silt sized particles.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170070">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170070</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Mudstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A sedimantary rock composed of fine grained clay particles. Flaky mudstone is called shale.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170837">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170837</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Argillite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A finegrained sedimentary rock composed mainly of indurated clay particles which is not as fissile as shale.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170892">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170892</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Soapstone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A talcshist and type of metamorphic rock commonly used for carved stone objects. Also known as Steatite.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170893">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170893</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Andesite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An extrusive igneous, volcanic rock, of intermediate composition, with aphanitic to porphyritic texture. In a general sense, it is the intermediate type between basalt and dacite.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/171257"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171268">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171268</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Gritstone (Sandstone)</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Carboniferous sandstone varying in grain size from coarse to fine and in colour from white, yellow, pink to brown. When only Gritstone is mentioned, unless otherwise specified, assume it to be Gritstone (Sandstone), as this is the more common usage.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75405</dc:identifier>
