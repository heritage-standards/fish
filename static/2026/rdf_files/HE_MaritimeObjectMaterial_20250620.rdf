    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:title xml:lang="en">Historic England Maritime Object Material</dc:title>
    <dc:description xml:lang="en">Originally used for recording the construction materials of maritime vessels and, where appropriate, their cargoes. Now generally used for recording the material of an object</dc:description>
    <skos:hasTopConcept rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75385"/>
  </skos:ConceptScheme>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/151858">
    <skos:altLabel xml:lang="en">Glass Fibre</skos:altLabel>
    <skos:altLabel xml:lang="en">Fiberglass</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75385"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/151858</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Fibreglass</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75361"/>
    <skos:scopeNote xml:lang="en">A material made from extremely fine fibres of glass and is used as a reinforcing agent for many polymer products.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/166986">
    <skos:altLabel xml:lang="en">Cornelian</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/166986</dc:identifier>
