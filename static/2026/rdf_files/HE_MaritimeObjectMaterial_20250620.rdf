        <skos:prefLabel xml:lang="en">Leather</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Animal skin that has been hardened or treated by a tanning process.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
