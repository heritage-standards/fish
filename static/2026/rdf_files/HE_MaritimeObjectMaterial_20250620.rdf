        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Silver</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A precious metal of lustrous white colour with great malleability and ductility.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75410">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75380"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75410</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Tin</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A soft, lustrous lowmelting crystalline metallic element that is malleable and ductile at ordinary temperatures and that is used as a protective coating, in tinfoil, and in soft solders and alloys.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/143865"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/143960">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75380"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/143960</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Zinc</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Bluewhite metal, obtained from ore, and used commercially for roofing, galvanizing iron, or in alloys. Also used in the 19th century as sheathing for ship's hulls.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/159154"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171269">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75380"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171269</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Slag</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Waste material or dross separated from metals during smelting or refining.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75385"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75380</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Metal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Class of elements and alloys that are characteristically lustrous,ductile, fusible and malleable. These are extracted from ore minerals originally existing in nature and processed before becoming a recognisable metal.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75337">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75337</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Amber</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A semiprecious, fossilised resin usually used for ornamentation and jewellery.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75381">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75337"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75345"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75346">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75346</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Chert</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hard silica rich rock, black or brown coloured, commonly found in nodular form.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75348">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75348</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Clay</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A fine grained earth which becomes more plastic when water is added and can be moulded and dried to make bricks, tile, pottery, etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75349">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75349</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Concrete</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Composed of sand, stones or other aggregate and cement mixed with water which sets in a hard mass. The material is usually associated with modern building but was developed by Romans where cement was obtained from quicklime.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75357">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75357</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Enamel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A coloured, glasslike substance (opaque or partially opaque) that is fused to the surface of metal or glass or pottery for decorative or protective purposes.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75358">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75358</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Faience</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A glasslike compound first made in ancient Egypt. It involves coating a core material of powdered quartz with a vitreous alkaline glaze. Also the name given to a tinglazed earthenware.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75359">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75359</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Flint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, durable, dark grey stone, the purest native form of silica, which can either be used decoratively or as a main material. Predominantly found in East Anglia and the South East.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75361"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75372">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75372</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Jet</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hard, black form of lignite that takes a brilliant polish. It is used in jewellery and for ornamentation.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75386">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75386</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Obsidian</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A form of volcanic glass with similar properties to FLINT and often used in the manufacture of sharpedged tools.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75394"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75395"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/142972">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/142972</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Graphite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Crystalline allotropic form of carbon used in pencils, as a lubricant etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/146408">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/146408</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Alabaster</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Alabaster is a name applied to varieties of two distinct minerals: gypsum and calcite. The finer kinds of alabaster are employed as an ornamental stone, especially for internal decoration as it's softness allows it to be carved into elaborate forms.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/163222">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/163222</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Coal</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Use for objects made from coal or for stray finds of coal where the association with a wreck site is not proven and thus cannot be stated as either cargo or bunkers.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/166988">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/166988</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
