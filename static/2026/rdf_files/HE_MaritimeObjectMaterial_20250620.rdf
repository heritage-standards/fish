    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Jadeite</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/146351"/>
    <skos:scopeNote xml:lang="en">A hard, translucent variety of jade which is rarer than the other varieties of nephrite as a result considered to be the best and very desirable.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75384">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75384</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Oak</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A native hardwood of the Beech family with hard and durable characteristics which traditionally made it appropriate for structural work.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75414">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75384"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/140448">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
