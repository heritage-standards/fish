    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Variscite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A brownishred mineral commonly used as a semiprecious gemstone. A variety of the silica mineral chalcedony coloured by impurities of iron oxide.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/159154">
