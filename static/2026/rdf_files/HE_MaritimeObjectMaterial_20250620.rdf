        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Fir</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The wood of the evergreen coniferous tree characterized by single needlelike leaves and errect cones.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/141284">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/141284</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Elm</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hard, durable wood obtained from trees of the genus Ulmus.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/141340">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/141340</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Pine</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A straightgrained, durable and often resinous timber obtained from trees of the genus Pinus.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/141973">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/141973</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Spruce</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A light, soft, moderatelystrong wood obtained from trees of the genus Picea.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/141974">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/141974</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Tamarac</skos:prefLabel>
        <skos:scopeNote xml:lang="en">North American wood, the name being applied either to the American Larch; or to the Black or Ridgepole Pine of inland areas; and the Scrub Pine of maritime regions.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/144473">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/144473</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Beech</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A deciduous tree in the family Fagaceae, native to temperate Europe, Asia, and North America.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/147357">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/147357</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Birch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The timber from genus Betula, found in Europe and North America, particularly in northern regions.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/152383">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/152383</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Teak</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A strong durable wood originating in India and southeast Asia.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/160444">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/160444</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Ebony</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Dark and dense hardwood timber which may be sourced from various species of true ebony from southern Asia and Africa, but the name may also be given to dark hardwoods from elsewhere, e.g. the Americas.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/164107">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/164107</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hazel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A commonly coppiced wood from the genus Corylus.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/164394">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/164394</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Larch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A deciduous conifer native to Britain and Europe supplying durable and waterproof timber suitable for shipbuilding features such as masts.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/170819">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/170819</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Ash</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A native, broadleaf tree of the Fraxinus species, native to Europe.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171271">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171271</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Alder</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Wood from trees of the genus Alnus in the birch family Betulaceae.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/171264"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75414</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Wood</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A hard, compact, unprocessed, fibrous cellulose substance. The roots, trunks and branches of trees and shrubs consist of this tissue.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75395">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/146359">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75395"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/146359</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Onyx</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Onyx is a cryptocrystalline form of quartz. It is a semiprecious stone that is usually cut as a cabochon, or into beads, and is also used for intaglios and cameos.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/166991">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75395"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/166991</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Amethyst</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A purple or violet variety of quartz often used in jewelry. Amethyst is a semiprecious stone which owes its violet colour to irridation, iron impurities, and the presence of  trace elements, which result in complex crystal lattice substitutions.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/75395</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Quartz</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Hard, transparent, often coloured mineral. Can be found on its own as crystals and veins but also as a major constituent of rocks such as granite. Often used decoratively.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171264">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75414"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171270">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/171264"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171270</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Flax</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The fibrous stalks of the plant, Linum usitatissimum, which can be processed and used to manufacture linen.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/171263"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/171264</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Plant</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any material derived from a tree, shrub or herb of cellulose form, normally subsisting in soil and producing its food through photosynthesis.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/143865">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75380"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/143865</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Antimony</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75335"/>
    <skos:scopeNote xml:lang="en">A metallic element often used in alloys and historically used in pottery and glassmaking, paints, enamelling, and in cosmetics and medicine. Often derived from its sulphite ore, stibnite.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/144479">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75385"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/144480">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/144479"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/144480</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Felt</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fabric of fibrous materials consolidated by heat and mechanical action so that the fibres are matted together.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/73/concepts/144479</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T15:12:56</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Textile</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A woven or bonded fabric or cloth.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/146351">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75405"/>
