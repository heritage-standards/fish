    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Aluminium</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A white ductile metal used, for example, in alloys, for instruments, and in aircraft construction.</skos:scopeNote>
  </skos:Concept>

