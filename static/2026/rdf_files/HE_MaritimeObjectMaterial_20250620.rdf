        <skos:prefLabel xml:lang="en">Horn</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Horn is a hollow, bonelike projection consisting mainly of keratin, found on certain animals (sheep, cows, goats etc.)</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/75376">
