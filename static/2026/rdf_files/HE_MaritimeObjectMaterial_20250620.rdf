        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Plaster</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A building material used for coating walls and ceilings. Plaster can refer to gypsum plaster (also known as plaster of Paris), lime plaster, or cement plaster.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/166989"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/166992">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/75381"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/73"/>
