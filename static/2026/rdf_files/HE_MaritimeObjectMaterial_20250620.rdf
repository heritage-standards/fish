    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Picrite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A type of basalt rich in the mineral olivine.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/73/concepts/171257">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/73/concepts/170896"/>
