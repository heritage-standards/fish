        <skos:prefLabel xml:lang="en">Halved Lap Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which one timber is reduced in thickness.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

