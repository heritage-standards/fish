    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137278"/>
    <skos:scopeNote xml:lang="en">A grave or sepulchre enlosed or covered by a memorial.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138349">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138852">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138349"/>
