    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tracery</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An arrangement by which panels, screens, vaults or windows are divided into parts of different shapes or sizes by means of moulded stone bars or ribs, called form-pieces or forms in the Medieval period.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138355">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137632"/>
