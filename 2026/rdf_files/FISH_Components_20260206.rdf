        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Guard Chamber</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room frequently in a military building where sentries guard and protect the premises.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

