        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Elliptical Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch which is half an ellipse.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137746">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
