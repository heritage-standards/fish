        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Sexpartite Vault</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A vault whose bay is divided by diagonal and transverse ribs into six compartments or cells.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

