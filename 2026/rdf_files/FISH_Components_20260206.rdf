    <skos:prefLabel xml:lang="en">Flying Buttress</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137347"/>
    <skos:scopeNote xml:lang="en">A buttress set away from the structure it supports, joined to it by an arch.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137788">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137774"/>
