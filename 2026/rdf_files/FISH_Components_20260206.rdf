    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Aureole</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Circular or almond-shaped halo surrounding the figure of Christ, the Virgin or a saint.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137390">
    <skos:altLabel xml:lang="en">Baldachin</skos:altLabel>
    <skos:altLabel xml:lang="en">Baldaquin</skos:altLabel>
