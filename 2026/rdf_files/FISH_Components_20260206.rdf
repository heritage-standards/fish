    <skos:scopeNote xml:lang="en">A bay in a two storeyed house open to the roof to allow smoke to escape.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138258">
