        <skos:prefLabel xml:lang="en">Water Tank</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A tank used for the storage of water, usually found as part of an institution like a workhouse or hospital complex</skos:scopeNote>
      </skos:Concept>
