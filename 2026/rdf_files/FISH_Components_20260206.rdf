    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Gutter</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A trough or watercourse constructed to collect rainwater from a roof and channel it towards a drain or pipe.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137360">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137358"/>
