        <skos:prefLabel xml:lang="en">Fairbairns Lever</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A mechanical testing machine used to carry out pioneering tests on various materials, particularly cast-iron beams, to determine practical data on their strength and other properties.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

