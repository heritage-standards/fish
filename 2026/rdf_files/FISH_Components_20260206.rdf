        <skos:prefLabel xml:lang="en">Kneeler</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A large approximately triangular stone at the foot of a gable, cut to have a horizontal bed and a top conforming, wholly or in part, to the slope of the gable.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
