    <skos:prefLabel xml:lang="en">Travelling Crane</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A crane, usually used in engineering workshops, that can be moved from place to place, often by means of rails.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138364">
