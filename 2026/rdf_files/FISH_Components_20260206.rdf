    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Ribbed Vault</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A vault with a ceiling or undersurface subdivided by ribs into bays or webs.</skos:scopeNote>
  </skos:Concept>

