    <skos:prefLabel xml:lang="en">Broach Spire</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An octagonal spire atop a square tower, the transition between structures effected by partially pyramidical masonry forms called broaches.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138271">
