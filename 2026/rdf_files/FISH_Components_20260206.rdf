    <skos:prefLabel xml:lang="en">Steeple</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A collective term embracing a church tower's entire structure, including its spire.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137680">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137994"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
