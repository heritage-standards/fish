    <skos:prefLabel xml:lang="en">Gas Engine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An internal combustion heat engine which uses gas as its fuel, and acts as a prime mover or power source for driving other machinery.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137889">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137817"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138027">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137889"/>
