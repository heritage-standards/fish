        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Wall Passage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A passage constructed within the thickness of a wall.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/159278">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138063"/>
