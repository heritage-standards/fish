    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Inclined Plane</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A slope, usually with rails, along which a vehicle can be moved between two relatively flat stretches of railway, or by which a boat can be transferred from one level of waterway to another.</skos:scopeNote>
  </skos:Concept>

