    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Floral Feature</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A decorative feature in the style of a flower or plant. Use more specific term.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137674">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137249"/>
