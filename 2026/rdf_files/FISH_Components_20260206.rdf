    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Astragal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A moulding which is small, convex and circular.</skos:scopeNote>
  </skos:Concept>

