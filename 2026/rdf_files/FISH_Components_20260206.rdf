    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Head Race</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A channel, usually placed upstream of a mill, that carries water from a river or other water source to a waterwheel.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139618">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137774"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137971"/>
