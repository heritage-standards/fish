    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Springer</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The point or block from which an arch or vault starts. The block generally has a horizontal base and sloped top.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137365">
    <skos:altLabel xml:lang="en">Telamone</skos:altLabel>
    <skos:altLabel xml:lang="en">Atlas</skos:altLabel>
