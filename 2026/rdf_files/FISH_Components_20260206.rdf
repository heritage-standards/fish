        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Skew Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch with jambs that do not stand at an angle of ninety degrees to its face.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
