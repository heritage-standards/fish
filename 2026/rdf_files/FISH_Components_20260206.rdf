    <skos:scopeNote xml:lang="en">A small opening built into a stone wall or hedge to allow small animals through.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137553">
    <skos:altLabel xml:lang="en">Quire</skos:altLabel>
