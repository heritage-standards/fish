    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Parlour</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Originally a reception room where visitors come come to talk especially in a closed establishment such as a monastery or school. Later used to refer to any room used for entertaining guests.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137714">
    <skos:altLabel xml:lang="en">Withdrawing Chamber</skos:altLabel>
