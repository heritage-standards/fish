        <skos:prefLabel xml:lang="en">Westwork</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The west end of a church made up of a tower, entrance hall and upper room, usually with an altar.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

