        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Arabesque</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A style of decorative design consisting of intertwined, geommetrical patterns of leaves, branches, tendrils etc. Often defined as being devoid of human or animal figures.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137394">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
