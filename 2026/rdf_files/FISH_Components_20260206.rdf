    <skos:prefLabel xml:lang="en">Entrance</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A place of entry into a site, monument or building.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137253">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138234"/>
