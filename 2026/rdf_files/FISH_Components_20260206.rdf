    <skos:prefLabel xml:lang="en">Turbine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A motor in which rotary motion is produced by motive power, usually of water, steam or gas, impinging directly on a series of vanes upon the circumference of a revolving cylinder or disc.</skos:scopeNote>
  </skos:Concept>

