    <skos:scopeNote xml:lang="en">A diagonally set modillion placed at a cornice's external corner.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137987">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137297"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137478"/>
