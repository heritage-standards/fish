        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Garderobe (Toilet)</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A latrine built into, or projecting beyond, the wall of a medieval castle featuring a stone or wooden seat situated above a pit or the castle moat.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137878">
