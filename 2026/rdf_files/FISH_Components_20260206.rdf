    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/151925"/>
    <skos:scopeNote xml:lang="en">A first-floor chamber, often serving as a parlour, bedchamber or private room, in a medieval house. Also a loft, rood-loft or garret.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138286">
