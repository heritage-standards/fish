        <skos:prefLabel xml:lang="en">Fleuron</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Decorative ornamentation of a flower or leaf.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138184">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
