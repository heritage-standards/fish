    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Reading Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A room set aside for the purpose of reading, such as in a library or a club.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139393">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137952"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140476">
