    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Assembly Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A large room for large numbers of people, eg for balls, meetings etc.</skos:scopeNote>
  </skos:Concept>

