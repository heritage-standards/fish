    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Clerestory</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The upper parts of walls carried on arcades or colonnades in the nave, choir or transepts of a church or hall, rising higher than the lean-to roofs of the aisles and pierced with windows to allow light to penetrate.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138218">
    <skos:altLabel xml:lang="en">Intermediate Truss</skos:altLabel>
