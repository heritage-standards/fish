    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Angular Niche</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A niche in the corner of a structure.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138009">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137306"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137516">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138009"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
