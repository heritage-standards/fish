        <skos:prefLabel xml:lang="en">Day Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A communal living room.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137673">
