        <skos:prefLabel xml:lang="en">Shingle</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A thin wooden slab or tile used in quantity as a roof or wall covering.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139007">
