        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cheese Press</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A device used in the production of hard cheeses that exerts pressure upon fresh curds in order to remove and drain away excess whey.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/141878">
