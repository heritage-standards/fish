        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Dressing Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room, particularly in a house or theatre, intended for dressing or changing one's clothes and furnished with wardrobes, dressing tables and other facilities for the application of make-up, styling of hair etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137718"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137789"/>
