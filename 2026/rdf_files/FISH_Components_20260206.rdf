    <skos:scopeNote xml:lang="en">A decorative S-shaped moulding, usually placed at the top of a cornice, with a convex lower half and a concave upper half.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138162">
    <skos:altLabel xml:lang="en">Frater</skos:altLabel>
