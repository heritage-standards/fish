        <skos:prefLabel xml:lang="en">Pinnacle</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Small ornamental pyramid or cone, often decorated, crowning a spire, turret, buttress etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139508"/>
