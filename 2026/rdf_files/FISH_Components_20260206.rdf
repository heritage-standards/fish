        <skos:prefLabel xml:lang="en">Vestry</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room used in a church to store vestments and for the clergy to dress in.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138414"/>
