    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Truss</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A combination of timbers to form a frame placed at intervals and carrying the purlins.</skos:scopeNote>
  </skos:Concept>

