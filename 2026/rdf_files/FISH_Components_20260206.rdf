        <skos:prefLabel xml:lang="en">Overmantel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An ornamental panel or decorative structure situated above a mantelpiece</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/143474">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
