    <skos:prefLabel xml:lang="en">Bracket</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A small support designed to help support a weight, such as that of a projecting member.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137295">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137545"/>
