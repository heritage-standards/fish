    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Gargoyle</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A projecting spout to throw water from a gutter away from the wall, frequently decorated with grotesque figures to spew out evil away from the House of God.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137817">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137889"/>
