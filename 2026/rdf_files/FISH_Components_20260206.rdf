        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Enterclose</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A passage between two rooms in a house or leading from the door to the hall.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138211">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138063"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138211</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Screens Passage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A passage that runs axially across the end of a hall with a screen between it and the hall and doorways to service rooms on the other side.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139829"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140111"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/159275">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138063"/>
