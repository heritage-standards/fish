        <skos:prefLabel xml:lang="en">Scalloped Capital</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A type of cushion capital with the lunette on each face cut into a series of truncated cones to form a scallop shell-like decoration.</skos:scopeNote>
