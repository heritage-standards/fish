        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Travelling Roof Crane</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A crane, usually used in engineering workshops that can be moved from place to place by means of overhead rails..</skos:scopeNote>
      </skos:Concept>
