    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Structural Component</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A part of a building or structure that is an element of the construction.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137246">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
