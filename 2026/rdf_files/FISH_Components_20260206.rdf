    <skos:prefLabel xml:lang="en">Facade</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The external face or elevation of a building, especially the principal front.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138901">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137371"/>
