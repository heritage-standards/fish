        <skos:prefLabel xml:lang="en">Cloakroom</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room in which cloaks, coats, hats etc may be left and often including coathooks, hat boxes and similar fixtures and fittings.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137601">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138182"/>
