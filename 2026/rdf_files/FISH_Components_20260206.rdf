    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Ionic Capital</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A Capital with a rolled up cushion-like form on either side creating distinctive volutes.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137436">
