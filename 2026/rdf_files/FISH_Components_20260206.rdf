        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Water Filtration Unit</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A plant used to sterilize water for use in public bathing establishments, not to be confused with desaliation or  purification units for drinking water.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
