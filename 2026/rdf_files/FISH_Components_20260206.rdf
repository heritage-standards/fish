    <skos:prefLabel xml:lang="en">Anta</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A pilaster terminating the side walls of a temple whose capital and base differ from those of its associated columns. Such an arrangement, where the columns do not project beyond the faces of the antae, is said to be 'in antis'.</skos:scopeNote>
  </skos:Concept>

