    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Internal Combustion Engine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An engine or prime mover, in which a mixture of air and fuel is ignited inside a closed cylinder, and the resulting explosion drives a piston to the opposite end of the cylinder, its movement turning a crankshaft via suitable mechanical parts.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137818">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138374"/>
