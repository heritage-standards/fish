    <skos:prefLabel xml:lang="en">Drawing Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A room to withdraw to from the dining room.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137377">
    <skos:altLabel xml:lang="en">Glory</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
