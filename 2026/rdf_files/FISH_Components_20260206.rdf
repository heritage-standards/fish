        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Two Centred Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch formed around two arcs whose radii are each equal to the span of the arch.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138920">
