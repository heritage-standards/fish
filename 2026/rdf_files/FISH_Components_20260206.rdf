    <skos:scopeNote xml:lang="en">A sleeping apartment usually containing a number of beds and sometimes partitioned into cubicles.A room for sleeping in, usually for a number of beds.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137497">
    <skos:altLabel xml:lang="en">Double Suntrap Plan</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138312"/>
