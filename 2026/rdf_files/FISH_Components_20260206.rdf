        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Thatched Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof featuring a covering of straw, reeds, rushes etc. used extensively during the medieval period but also popular in rural or rustic architecture.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/143336">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138180"/>
