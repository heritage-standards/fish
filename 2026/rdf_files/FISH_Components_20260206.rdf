        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Lap Dovetail Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which the dovetailed member is proud of the receiving member and is not finished flush with it.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

