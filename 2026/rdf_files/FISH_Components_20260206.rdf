    <skos:prefLabel xml:lang="en">Blind Arcade</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140111"/>
    <skos:scopeNote xml:lang="en">A succession of arches on shafts with no openings, attached to and used to enliven a wall.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138409">
    <skos:altLabel xml:lang="en">Jigger</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137632"/>
