    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Auditorium</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A room or hall designed for an audience to listen and view, as in a theatre, concert hall, lecture hall etc..</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137378">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138145"/>
