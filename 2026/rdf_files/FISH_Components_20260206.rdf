    <skos:prefLabel xml:lang="en">Bullseye Window</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An oval window placed with its long axis horizontal. The term is often applied to similar round windows.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138044">
    <skos:altLabel xml:lang="en">Outshut</skos:altLabel>
