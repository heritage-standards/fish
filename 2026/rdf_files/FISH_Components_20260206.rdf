    <skos:prefLabel xml:lang="en">Gate</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137821"/>
    <skos:scopeNote xml:lang="en">A movable barrier, usually external, within an opening in a wall, fence, hedge or similar.</skos:scopeNote>
