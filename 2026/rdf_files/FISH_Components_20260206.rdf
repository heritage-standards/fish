        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Stone Carving</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An inscription or illustration carved into the surface of a stone wall or other architectural element.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
