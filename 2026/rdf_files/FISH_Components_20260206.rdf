    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Beam</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A main load-bearing horizontal member.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137292">
