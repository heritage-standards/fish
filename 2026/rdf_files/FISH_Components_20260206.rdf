    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Casement Window</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A window where the sash is hung vertically and the window opens outwards or inwards.</skos:scopeNote>
  </skos:Concept>

