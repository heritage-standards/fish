    <skos:prefLabel xml:lang="en">Disk Engine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A hydraulic engine patented in 1830 comprising a large specially shaped cast-iron outer casing enclosing a close-fitting but separate solid globe.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137872">
