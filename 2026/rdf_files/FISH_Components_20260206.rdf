        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Chancel Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch at the liturgical east of the nave, carrying a gabled wall above, separating nave from chancel.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137732">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
