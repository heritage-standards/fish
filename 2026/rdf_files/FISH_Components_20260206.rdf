    <skos:prefLabel xml:lang="en">Bar</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139400"/>
    <skos:scopeNote xml:lang="en">A counter from which beverages are served in a bar room.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139778">
