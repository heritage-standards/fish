    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Conference Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A room where organizations and associations meet for the undertaking of presentations and consultation.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139400">
