    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Quoin</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A stone or brick used on a corner to reinforce it and also as decoration.</skos:scopeNote>
  </skos:Concept>

