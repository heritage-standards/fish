    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Crown Steeple</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A steeple in which the spire resembles a crown.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138295">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137650"/>
