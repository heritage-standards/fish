    <skos:scopeNote xml:lang="en">An opening or shrine, usually containing a statue, framed by a pair of pilasters or columns supporting an entablature and pediment.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138234">
