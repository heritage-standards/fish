        <skos:prefLabel xml:lang="en">Three Centred Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A depressed arch formed around three arcs: two struck from the springing line with one centrally placed arc struck from below it.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

