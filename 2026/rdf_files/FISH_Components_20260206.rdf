    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Drop Arch</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A pointed, two centred, arch whose span is greater than its height.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138099">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137716"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137935"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138025"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138099</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pointed Arch</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An arch produced by two curves, usually each with a radius equal to the span, which meet at a point.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137717">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138341"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137717</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Dropped Tiebeam</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A transverse ceiling beam set below wall-plate level in order to increase head room within the roof space; it carries knee principals, or the struts or braces of an interrupted tiebeam truss.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138341">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137717"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137890">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138341"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137890</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Interrupted Tiebeam</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A tiebeam whose central section is omitted to increase head room; its inner ends are held by a slip-braces or struts rising from a dropped tiebeam and can be used in end frames.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138314">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138341"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138314</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Stub Tiebeam</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A block in the position of a tiebeam.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137434"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138904"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138341</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tiebeam</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A major horizontal timber spanning a roof space to connect a pair of principal rafters and prevent them spreading.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137718">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138182"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138042">
