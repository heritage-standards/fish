        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Equilateral Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch whose height is equal to its span.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137754">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
