        <skos:scopeNote xml:lang="en">A vertical timber in a truss, descending from the ridge, and projecting below the lower transverse timber, normally used  with scissor beams.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137928">
