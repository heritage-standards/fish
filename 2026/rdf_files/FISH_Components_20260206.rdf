        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Sluice</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A gate or valve that controls the flow of water from a reservoir, harbour, etc..</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139535"/>
