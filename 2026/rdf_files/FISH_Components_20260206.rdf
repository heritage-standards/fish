    <skos:prefLabel xml:lang="en">Wall Crane</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A wall mounted, hydraulically operated crane or winch, sometimes used to operate lifts.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137536">
    <skos:altLabel xml:lang="en">Rag And Chain Pump</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138130"/>
