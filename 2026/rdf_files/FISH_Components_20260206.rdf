        <skos:prefLabel xml:lang="en">Needle Spire</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A steeply pitched spire whose base is significantly narrower than the tower on which it sits.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

