    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Chain Pump</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An early design of pump featuring a series of pistons, or sometimes bundles of rags, passing through a barrel on a continuous chain, forcing water upwards.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137867">
    <skos:altLabel xml:lang="en">Horse Gin</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137971"/>
