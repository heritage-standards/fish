        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Spiral Fluting</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative feature, usually Norman, in which fluting takes a spiral rather than vertical form.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

