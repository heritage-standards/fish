    <skos:prefLabel xml:lang="en">Angle Bracket</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A bracket that is shaped to form an angle.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137478">
