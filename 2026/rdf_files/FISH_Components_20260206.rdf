        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Balcony</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A platform projecting from the surface of a wall of a building carried on brackets, consoles or columns, usually placed before windows or openings, and protected by a railing or balustrade. It can also be a gallery in an auditorium.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137422">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137489"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
