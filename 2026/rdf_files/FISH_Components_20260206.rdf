        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hydraulic Press</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A machine that uses liquid pressure to exert a large force on two platens so that items placed between them are pressed to a shape, compressed, or forced together.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137876">
