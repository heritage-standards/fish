        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Picture Frame</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A case or border, usually wood or metal, enclosing a picture, painting or photograph.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/141862">
