        <skos:prefLabel xml:lang="en">Courtroom</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The place, hall or chamber in which justice is administered.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

