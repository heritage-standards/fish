    <skos:prefLabel xml:lang="en">Ventilation Shaft</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A shaft constructed to allow the circulation of fresh air, into a mine, building etc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137750">
