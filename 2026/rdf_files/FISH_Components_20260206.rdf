    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Ashlaring</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Short vertical timbers which go from the rafters to the inner plate on a thick wall.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137361">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137897"/>
