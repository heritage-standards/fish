    <skos:scopeNote xml:lang="en">A passageway or corridor beteen two areas which is covered.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137961">
    <skos:altLabel xml:lang="en">Aleois</skos:altLabel>
    <skos:altLabel xml:lang="en">Balistraria</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
