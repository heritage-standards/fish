    <skos:scopeNote xml:lang="en">An arch built into a wall above another arch or lintel to relieve it of some of the weight of the structure above.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137701">
    <skos:altLabel xml:lang="en">Dorter</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138169"/>
