    <skos:prefLabel xml:lang="en">Ionic Order</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A classical order with an Attic base and fluted column. The cornice has dentils and the capital volutes.</skos:scopeNote>
  </skos:Concept>

