    <skos:prefLabel xml:lang="en">Metope</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A thin, rectangular panel, sometimes enriched with sculptural relief, placed between the triglyphs in a Doric Order frieze.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137986">
