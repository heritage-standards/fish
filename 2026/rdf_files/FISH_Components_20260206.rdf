        <skos:prefLabel xml:lang="en">Pulpitum</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A stone screen, usually found in a monastic or collegiate church, that separates the choir from the nave.</skos:scopeNote>
      </skos:Concept>
