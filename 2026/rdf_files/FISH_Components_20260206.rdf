        <skos:prefLabel xml:lang="en">Camouflage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The application of colour and other materials to a structure to either conceal it from identification or to make it look like something else.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

