        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Halved Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which both timbers are reduced in thickness.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
