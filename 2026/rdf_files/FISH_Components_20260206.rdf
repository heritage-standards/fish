    <skos:scopeNote xml:lang="en">A room or group of rooms for healing the sick. Where it is a monument use the Thesaurus of Monument Types.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137358">
