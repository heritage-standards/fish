        <skos:prefLabel xml:lang="en">Tabernacle</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A recess for holding the Holy Sacrament.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138853"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138856"/>
    <skos:narrower>
