    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Agrafe</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A keystone decorated with a relief sculpture, usually a cartouche</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138395">
    <skos:altLabel xml:lang="en">Air Shaft</skos:altLabel>
