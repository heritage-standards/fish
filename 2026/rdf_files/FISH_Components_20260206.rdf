    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Doric Capital</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A capital with an abacus, ovolo, neck and astragal.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137696">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137698"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137582"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137696</dc:identifier>
