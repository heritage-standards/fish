        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Double Courtyard Plan</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Two linked quadrangular open areas surrounded by walls or buildings.</skos:scopeNote>
