    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Grotesque</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A classical ornamentation featuring foliage, fruits and, unlike Arabesque, human and animal figures, sometimes fantastic or mythological in nature. The term may have originated from the fact that many examples of such ornamentation were found in grottoes.</skos:scopeNote>
  </skos:Concept>

