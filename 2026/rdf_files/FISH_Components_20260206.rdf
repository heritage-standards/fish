    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Steps</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A series of flat-topped structures, usually wooden or stone, on which a person places their feet when ascending or descending, facilitating movement from one level to another.</skos:scopeNote>
  </skos:Concept>

