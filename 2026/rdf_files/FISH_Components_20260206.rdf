    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Diamond Mullion</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A mullion of square section set diagonally.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137994">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137680"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137921">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137994"/>
