        <skos:prefLabel xml:lang="en">Flat Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch which is formed by keystones but is flat like a lintel</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/159284">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
