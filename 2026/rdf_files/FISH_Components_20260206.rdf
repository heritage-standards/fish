        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Coupled Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof in which pairs of rafters are fixed to the ridge piece and the wall plates without any collars or tiebeams.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137723"/>
    <skos:narrower>
