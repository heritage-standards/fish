        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Windshaft</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The main axle projecting through the front of a windmill on which the sails are mounted.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139549"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139551">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139551</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Crown Tree</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The main vertical beam standing at the centre of a post mill carrying the bearing upon which the body of the mill rotates.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139555">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139555</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cap</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The rotating top section of a tower or smock mill.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139561">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139561</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Brake Wheel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The main gear wheel, which is engaged by a brake to halt or slow the machinery, mounted on the windshaft of a windmill.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139565"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139567">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139567</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Bridge Tree</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An adjustable, horizontal beam, supporting the vertical stone spindle in a water or windmill, which allows the gap between the grinding stones to be varied.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139592"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139630">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139630</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Masons Mark</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A device, monogram or symbol incised in stonework by a mason as a means of identifying his work. Particularly common in Romanesque and Gothic buildings.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139634"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139636">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139636</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Stonework</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A structure, part of a structure or area consisting of plain masonry.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139775">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139775</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Foundation</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The lowest part, or base, of a structure, sometimes built into the ground, on which the weight of the whole rests.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139778"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139782">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139782</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Water Spout</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A pipe or channel to carry water outwards from a gutter or behind a parapet. If decorated with grotesque heads it is called a gargoyle.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139784">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139784</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Glazing Bar</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A moulded bar or baton dividing the panes of glass within a window light.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139825"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139828"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139829"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139838">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139838</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Grating</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A framework of crossed or parallel wooden or metal bars placed over an opening to prevent access but allow the passage of air, light, water etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139849"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140089"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140119">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140119</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Fan Carriage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A wheeled device supporting a windmill's fantail that moves around a trackway thus turning the windmill into the wind.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140125">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140125</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Striking Gear</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A mechanism within a windmill, attached to the striking rod, allowing the opening and closing of the shutters or vanes of patent sails.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140135">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140135</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Spider</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A four-armed metal coupling, positioned at the centre of a windmill's sails,  connected to the front of the striking rod and the shutter bars of all the sails, causing the shutters to open and close.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140136"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140306"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140342">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140342</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Salt Pan</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A large shallow pan, usually metal, in which seawater or brine is evaporated for the extraction of salt. The name is also often applied to the exterior pits or ponds used for the same purpose (see Thesaurus of Monument Types).</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140403">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140403</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Striking Rod</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An iron bar or rod running through the core of a windmill's windshaft that causes the opening and shutting of the vanes on patent sails.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140407">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/140407</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Foundation Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A stone, usually inscribed, laid during a ceremony to commemorate the founding of a new building</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140564">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
