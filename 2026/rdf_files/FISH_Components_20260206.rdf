        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Half Hipped Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof whose ends are partly gabled and partly sloped.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

