        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Brine Tank</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A tank within a salt works used for storing brine after is has been pumped from underground. The brine is then fed by gravity into the evaporating pans in the Pan House.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140399">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137971"/>
