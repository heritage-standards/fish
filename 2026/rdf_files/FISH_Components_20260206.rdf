        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Ball Flower</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Decorative ornamentation in the form of a ball enclosed within petals.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137429">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
