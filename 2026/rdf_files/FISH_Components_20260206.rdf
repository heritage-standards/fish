        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Bay Leaf</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Bay-leaf shaped decorative ornamentation, usually adorning mouldings or friezes, often depicted in a garland arrangement.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137524">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
