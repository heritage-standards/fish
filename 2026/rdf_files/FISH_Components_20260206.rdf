        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Bolection Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A moulding which projects beyond the face of a panel or frame, usually found in panelling or in doors.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137479">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137479</dc:identifier>
