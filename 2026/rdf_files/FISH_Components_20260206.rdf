        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cross Passage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Entry to a hall through opposing doors with a partition screening the hall and forming a passageway.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137742">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138063"/>
