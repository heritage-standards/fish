        <skos:prefLabel xml:lang="en">Splayed Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An arch which has a larger radius on the front face of a wall than on the back.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

