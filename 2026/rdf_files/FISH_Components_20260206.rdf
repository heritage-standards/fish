        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Four Centred Arch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A pointed arch which, on a plan, is shown to be constructed around four arcs: two centred below and two centred upon the springing line, which is the level at which the vertical sides of the arch begin to curve.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137868">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137343"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
