        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Palmette</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative motif representing a palm leaf. Often painted, incised or applied in relief, can occur singly or as a repeating pattern.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
