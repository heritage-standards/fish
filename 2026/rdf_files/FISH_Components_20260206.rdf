        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Gabled Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The commonest type of roof with sloping sides meeting at a ridge and with a gable at each end.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137839">
