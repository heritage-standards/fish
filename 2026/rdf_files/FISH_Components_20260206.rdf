    <skos:scopeNote xml:lang="en">A component part that is designed deliberately for decorative purposes.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137250">
