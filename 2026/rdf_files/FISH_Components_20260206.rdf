        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Display Case</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An enclosed structure, usually glass fronted, designed to contain, and facilitate the viewing of, objects or notices. May be built into the fabric of a room, affixed to an exterior or exterior wall or free standing.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139618"/>
