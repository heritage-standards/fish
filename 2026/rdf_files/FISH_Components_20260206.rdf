    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Principal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A structural member that supports a purlin. Use PRINCIPAL RAFTER where the principal is also a common rafter.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137685">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137872"/>
