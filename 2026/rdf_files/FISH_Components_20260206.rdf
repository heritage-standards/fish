        <skos:prefLabel xml:lang="en">Eaves Board</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A board on the lower edge of a sloping roof which protects the top of the external wall.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

