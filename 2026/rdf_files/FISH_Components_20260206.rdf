        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Bracket Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative moulding cosisting of two ogee-forms with joined faces.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137501">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137501</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cable Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative moulding shaped to resemble a length of cable or twisted rope.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137520">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137520</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Casement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hollow moulding, often enriched, similar to a scotia or cavetto, used in Gothic jambs and cornices.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137522">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137522</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cats Head Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative moulding depicting an animal or bird head, similar to a beak head moulding but with a shorter, cone-like tongue or beak overlapping the moulding set beneath it.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137525">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137525</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cavetto</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A concave moulding where the profile is a quarter of a circle.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137535">
