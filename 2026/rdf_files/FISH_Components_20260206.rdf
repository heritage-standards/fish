        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Knee Principal</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A principal that has a short, angled section, resembling a knee-joint, at one end.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138120">
