        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hammerbeam Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof consisting of trusses that have a pair of brackets supporting the hammer posts that in turn support the rafters.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/144997">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138180"/>
