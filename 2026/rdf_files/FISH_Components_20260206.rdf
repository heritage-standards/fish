    <skos:prefLabel xml:lang="en">Fireplace Surround</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137771"/>
    <skos:scopeNote xml:lang="en">The architectural element made of brick, tile, stone or certain woods which surrounds a fireplace to provide aesthetic and safety benefits.</skos:scopeNote>
  </skos:Concept>

