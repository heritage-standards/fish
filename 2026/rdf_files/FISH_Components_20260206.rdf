        <skos:prefLabel xml:lang="en">Painting</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fine art depiction in oil, watercolour or other media on wood panels, canvas or paper</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139783">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
