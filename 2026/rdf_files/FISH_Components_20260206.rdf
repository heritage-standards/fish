        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Great Chamber</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An apartment for the use of people of high status, often the owner of the building. Also a room adjoining, or close to, a hall and used as a drawing room or venue for private functions.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137827">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138182"/>
