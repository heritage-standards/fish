        <skos:prefLabel xml:lang="en">Committee Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room where a committee meets to discuss matters put before them.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

