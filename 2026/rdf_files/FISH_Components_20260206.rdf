    <skos:scopeNote xml:lang="en">A vault where the bay is divided by diagonal and transverse ribs into four cells or webs.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/140246">
