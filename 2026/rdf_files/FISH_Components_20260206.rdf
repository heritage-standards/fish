    <skos:prefLabel xml:lang="en">Canal Inclined Plane</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A slope, usually with rails, by which a boat can be transferred from one level of waterway to another.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137883">
