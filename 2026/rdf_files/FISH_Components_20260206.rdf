        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Face Halved Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which the side, or face, of a timber has been squarely cut away to fit into a corresponding cut-away in the side of another member.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137843">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137908"/>
