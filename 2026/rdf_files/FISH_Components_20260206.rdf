    <skos:prefLabel xml:lang="en">Basket Arch</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An arch consisting of a segment of a circle connected to other segments with smaller radii.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137323">
    <skos:altLabel xml:lang="en">Antechamber</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138182"/>
