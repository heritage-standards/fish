    <skos:prefLabel xml:lang="en">Waterwheel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A wheel turned by water to generate mechanical power.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137487">
