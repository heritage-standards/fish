    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Corinthian Order</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A classical order having a bell shaped capital that is decorated with laurel, olive or acanthus leaves from which CAULICOLI emerge. The shaft is usually fluted and the base is often an Attic base.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137376">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138182"/>
