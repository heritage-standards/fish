    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Attic Base</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A column base featuring a hollow, concave - or scotia - moulding between two tori, which are projecting, convex mouldings.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137611">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137372"/>
