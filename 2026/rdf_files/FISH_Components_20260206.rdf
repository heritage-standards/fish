    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Undershot Wheel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A waterwheel where the inflow of water strikes the paddles, or floatboards, below the axis of the wheel.</skos:scopeNote>
  </skos:Concept>

