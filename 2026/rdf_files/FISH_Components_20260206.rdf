    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Oven</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An enclosed structure of brick, stone or metal in which material is heated or burned, or, in a domestic context, food is cooked, through the continuous radiation of heat from its floor, walls or ceiling.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139622">
