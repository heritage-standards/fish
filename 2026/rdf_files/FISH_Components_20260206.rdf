    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139856"/>
    <skos:scopeNote xml:lang="en">A barrier, usually in the form of a small wall, set to prevent people falling over the side of a bridge, balcony, roof etc.</skos:scopeNote>
  </skos:Concept>

