        <skos:prefLabel xml:lang="en">Sconce</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A type of light fixture affixed to a wall in such a way that it uses only the wall for support, and the light is usually directed upwards.</skos:scopeNote>
      </skos:Concept>
