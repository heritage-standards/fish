        <skos:prefLabel xml:lang="en">Bare Faced Tenon Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which the tenon retains one or more of the original sides of the timber.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137454">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137908"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
