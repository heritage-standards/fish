    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138919"/>
    <skos:scopeNote xml:lang="en">A flight of steps leading from one level to another.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138275">
    <skos:altLabel xml:lang="en">Tas De Charge</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
