    <skos:prefLabel xml:lang="en">Astylar</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Describes a Classical interior, exterior or facade without pilasters or columns.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137755">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137364"/>
