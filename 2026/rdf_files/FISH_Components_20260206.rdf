        <skos:prefLabel xml:lang="en">Dovecote</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A shelter for doves or pigeons, often containing nesting boxes, either free-standing or built into other structures (barns, towers etc.). If a dedicated,  free-standing structure, index with MONUMENT TYPE: DOVECOTE.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139763">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137489"/>
