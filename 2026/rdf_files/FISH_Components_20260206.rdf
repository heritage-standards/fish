    <skos:prefLabel xml:lang="en">Louvre</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An opening in the ridge of a roof intended to provide ventilation or an outlet for smoke; also the hood on such an opening that prevents rain entering.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137981">
