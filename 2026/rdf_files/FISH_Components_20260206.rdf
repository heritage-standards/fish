        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cornish Engine</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A beam steam engine originating in Cornwall, first used for raising water from mines.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138006">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137436"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
