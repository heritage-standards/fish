    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Adytum</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Originally, the inner sanctuary of a Greek temple from where the oracle was delivered. Now used for any private chamber or sanctuary.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137256">
