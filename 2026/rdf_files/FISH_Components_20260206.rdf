    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Batten</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A small timber fixed to a wall to support items such as cladding. Also a strip of timber fixed across two or more parallel boards to join them together or conceal their join.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137431">
