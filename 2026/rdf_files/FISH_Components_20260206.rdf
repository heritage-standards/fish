    <skos:prefLabel xml:lang="en">Roof</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The exterior upper covering, and its supporting structure, of a building.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137482">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138420"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137482</dc:identifier>
