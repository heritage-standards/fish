        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Immersion Font</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A structure, usually sunk into the ground, for the purpose of allowing total bodily immersion as part of a baptismal ceremony.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137788</dc:identifier>
