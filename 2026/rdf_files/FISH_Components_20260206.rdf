    <skos:prefLabel xml:lang="en">Galilee</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138000"/>
    <skos:scopeNote xml:lang="en">A lobby or chapel at the western entrance of a church. Sometimes a place of burial, an area reserved for women, or a place where monks could meet female relatives.</skos:scopeNote>
  </skos:Concept>

