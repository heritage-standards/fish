        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Fleur De Lys</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Decorative ornamentation of a formalized lily.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137778">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137782"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
