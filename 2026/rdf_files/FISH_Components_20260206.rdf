        <skos:prefLabel xml:lang="en">Bridled Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint consisting of a projecting tongue fitting into an open housing in a scarf joint or the apex of a rafter.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

