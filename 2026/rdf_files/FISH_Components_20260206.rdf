    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pipe</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A hollow, cylindrical structure or tube made of clay, lead, steel, wood etc. through which gas, oil, water or other liquids can be conveyed.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139467">
