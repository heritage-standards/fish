    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Font</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A receptacle to hold water used in baptism usually found in a baptistery or nave of a church.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137795">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138419"/>
