        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Dogtooth Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative moulding featuring a repeating star-like motif carved in relief.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137726">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
