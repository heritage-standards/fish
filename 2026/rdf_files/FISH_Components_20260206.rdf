    <skos:prefLabel xml:lang="en">Block Cornice</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An Italian cornice consisting of a bed moulding, a row of plain block corbels or modillions, and a corona or cornice.</skos:scopeNote>
  </skos:Concept>

