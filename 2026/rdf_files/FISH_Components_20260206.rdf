    <skos:prefLabel xml:lang="en">Organ Blowing Chamber</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138037"/>
    <skos:scopeNote xml:lang="en">A dedicated room for housing the organ feeder bellows, can be an underground chamber or a free-standing building.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/170627">
