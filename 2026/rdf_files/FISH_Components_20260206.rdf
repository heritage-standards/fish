    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Horse Whim</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A timber, horse-powered device consisting of a large, rotating drum around which a rope would be wound, hoisting material from a quarry pit, mine shaft etc..</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137562">
    <skos:altLabel xml:lang="en">Clearstory</skos:altLabel>
    <skos:altLabel xml:lang="en">Clearstorey</skos:altLabel>
    <skos:altLabel xml:lang="en">Clerestorey</skos:altLabel>
    <skos:altLabel xml:lang="en">Overstorey</skos:altLabel>
