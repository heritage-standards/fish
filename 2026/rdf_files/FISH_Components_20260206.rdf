    <skos:prefLabel xml:lang="en">Bare Faced Dovetail Joint</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A joint in which a dovetailed timber's surface is proud of the receiving member on one side.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137908">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137407"/>
