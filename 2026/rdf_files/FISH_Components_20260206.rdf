        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Oil Engine</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An oil-fuelled internal combustion engine, developed in the late 19th century, and usually made as a stationary, horizontal unit.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138079">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137889"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
