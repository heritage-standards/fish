        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Chapter House</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A building, sometimes polygonal in plan, attached to a cathedral, church, abbey etc. and used for the assembly of chapter or brethren, often to address official business.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

