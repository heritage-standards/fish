    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Doric Order</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A classical order with metopes and triglyphs in the frieze. Greek Doric has no base and a fluted column but Roman Doric does have a base and may or may not have a fluted column.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137695">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137514"/>
