    <skos:prefLabel xml:lang="en">Baldacchino</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A canopy suspended, or on pillars, over a throne or altar.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137425">
    <skos:altLabel xml:lang="en">Cover Slip</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
