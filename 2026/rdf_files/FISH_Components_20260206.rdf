        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Strapwork</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A decorative feature of wood, plaster or carved masonry, often used in low relief on ceilings, panels or screens and resembling interlacing leather straps. Popular in the late 16th and early 17th centuries.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139797">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
