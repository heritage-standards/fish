    <skos:prefLabel xml:lang="en">Asiatic Base</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An Ionic base with a lower disc with horizontal fluting or reeding, above which is a torus, also reeded.</skos:scopeNote>
  </skos:Concept>

