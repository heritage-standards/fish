        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Stall</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A fixed seat, often enclosed, usually found within an ecclesiastical building and frequently arranged in series to accommodate a congregation, choir or clergy.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

