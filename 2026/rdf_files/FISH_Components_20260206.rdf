    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Doric Column</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A column that is equidistant, with intercolumniations, even at the corners, with two or more triglyphs over each  intercolumniation.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137697">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137698"/>
