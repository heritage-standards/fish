        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Verge Rafter</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A rafter set outside a gable to carry the roof beyond the wall face.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138975">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138145"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
