        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Picture Gallery</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room within a house or building used to exhibit artworks, often decorated and lit accordingly.</skos:scopeNote>
      </skos:Concept>
