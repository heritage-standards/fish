        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Easter Sepulchre</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A recess, usually situated in the north wall of a chancel,  often canopied, containing a decorated tomb chest representing the burial and resurrection of Christ.</skos:scopeNote>
      </skos:Concept>
