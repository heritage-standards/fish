    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138014"/>
    <skos:scopeNote xml:lang="en">A roof design, common to weaving sheds, featuring a sawtooth profile with unequal slopes forming each ridge and  lights on its northern side.</skos:scopeNote>
  </skos:Concept>

