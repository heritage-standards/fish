        <skos:prefLabel xml:lang="en">Duplex Pump</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A type of direct-acting, twin cylinder steam driven water pump.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138292">
