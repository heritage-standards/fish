    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Acanthus</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A long much indented leaf usually curled over at the tip which is a standard form of foliage in classical decoration.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137782">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137246"/>
