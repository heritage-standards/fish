        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Basement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The bottom storey of a building, often below or partially below ground level.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137982">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138901"/>
