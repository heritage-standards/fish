        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Curtain Wall</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A wall connecting two pavilions, bastions, towers etc..</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138098"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139017"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139629">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138407"/>
