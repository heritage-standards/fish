        <skos:prefLabel xml:lang="en">Brickwork</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A structure, part of a structure or area constructed from plain bricks.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139511"/>
