    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Barring Engine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A small auxiliary engine to help start up a large steam engine - invented 1866.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137740">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137412"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137465">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137740"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
