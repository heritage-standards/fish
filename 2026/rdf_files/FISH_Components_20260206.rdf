    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Doric Base</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A base of the Roman Doric order with a torus, an astragal and a fillet.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137698">
