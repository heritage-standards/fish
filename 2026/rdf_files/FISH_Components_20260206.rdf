    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Shoe</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An inclined wooden trough which channels grain evenly from the feed hopper into the eye of the stones in a corn mill.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139526">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
