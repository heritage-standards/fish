        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Common Rafter Roof</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof consisting entirely of common rafters, without the use of principals, in pairs but not connected by collar-beams.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137623">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138180"/>
