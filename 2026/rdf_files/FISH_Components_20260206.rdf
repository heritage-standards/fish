        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Grinding Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room where usually materials or consumables are processed into tools or meal, for example in a workshop or mill.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
