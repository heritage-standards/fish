        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Spere Truss</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The structure across the lower end of a medieval hall containing the spere, its supporting posts and tie-beam.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138845"/>
