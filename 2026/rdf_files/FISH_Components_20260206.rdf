    <skos:prefLabel xml:lang="en">Ashlar Piece</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An inclined timber running from a rafter to the inner face of a wall, forming a triangle.</skos:scopeNote>
  </skos:Concept>

