        <skos:prefLabel xml:lang="en">Bleeding Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room dedicated to the drawing or letting of blood, a procedure once thought to possess medicinal properties.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

