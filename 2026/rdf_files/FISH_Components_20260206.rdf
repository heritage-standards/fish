        <skos:prefLabel xml:lang="en">Long Gallery</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A long, high-ceilinged room, usually extending the full length of an Elizabethan or Jacobean house and often occupying an upper floor, used as a promenade, place of entertainment etc..</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138948"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139397">
