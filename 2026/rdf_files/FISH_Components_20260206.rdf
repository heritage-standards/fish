        <skos:prefLabel xml:lang="en">Newel Staircase</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A staircase where the vertical members are placed at the ends of flights to support the strings, handrails, trimmers and bearers.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
