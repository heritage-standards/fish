        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Flushwork</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The use of knapped flint applied to a wall to form a decorative pattern.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137833">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137674"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
