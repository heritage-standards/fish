    <skos:prefLabel xml:lang="en">Sheela Na Gig</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A carved stone female figure often found on castles and churches.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137459">
    <skos:altLabel xml:lang="en">Wall Arcade</skos:altLabel>
