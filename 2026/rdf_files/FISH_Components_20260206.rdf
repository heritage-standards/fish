    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Breastshot Wheel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A waterwheel in which the incoming water is directed onto the periphery at approximately the same level as the axle, the water being kept in contact with the floats, or buckets, by breastwork of masonry, timber or iron.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138420">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137482"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138046">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138420"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138046</dc:identifier>
