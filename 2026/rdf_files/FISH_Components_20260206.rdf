    <skos:prefLabel xml:lang="en">Band (Moulding)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A continuous series of ornaments within a horizontal moulding.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137407">
