        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Upright Shaft</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The main vertical axle running through the centre of a mill.</skos:scopeNote>
      </skos:Concept>
