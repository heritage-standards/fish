        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Control Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room in which actions are checked, verified and approved.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

