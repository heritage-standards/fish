        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Tudor Flower</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Decorative ornamentation in the form of an upright, stalked trefoil used in Tudor architecture.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138372">
