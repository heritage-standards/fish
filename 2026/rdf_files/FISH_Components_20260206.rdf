        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Birdmouthed Joint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A joint in which the end of one timber is cut in V- form and rests on the edge of another timber, frequently found between common rafters and wall plates.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137486">
