        <skos:prefLabel xml:lang="en">Oriel Window</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A bay window, supported by corbelling, cills or brackets, projecting from an upper storey of a building.</skos:scopeNote>
      </skos:Concept>
