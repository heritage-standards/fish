        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hydraulic Ram</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A device in which a large quantity of low pressure water is made to pump a small proportion of itself to a greater height than its source or to a higher pressure; achieved by using the pressure rise resulting from suddenly interrupting the flow</skos:scopeNote>
      </skos:Concept>
