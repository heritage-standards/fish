    <skos:prefLabel xml:lang="en">Shaft</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The part of a column between the capital and the base.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138254">
