    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Buttress</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A mass of stone or brick built against or as part of a wall to provide additional strength to it.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138407">
    <skos:altLabel xml:lang="en">Analemma</skos:altLabel>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137661">
