    <skos:prefLabel xml:lang="en">Steam Turbine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A steam motor in which rotory motion is produced by steam impinging directly upon a series of vanes upon the circumference of a revolving cylinder or disc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138297">
