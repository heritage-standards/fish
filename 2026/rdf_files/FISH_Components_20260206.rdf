    <skos:prefLabel xml:lang="en">Exercise Yard</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A yard intended for the purpose of taking exercise, for example within the grounds of a prison.</skos:scopeNote>
  </skos:Concept>

