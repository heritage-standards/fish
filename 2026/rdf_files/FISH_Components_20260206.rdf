    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Sitting Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Originally a room in a house where a family would gather, usually in the evening, to sit and read, write, sew, play music etc. This term has become commonly used as an alternative to living room.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139398">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137376"/>
