        <skos:prefLabel xml:lang="en">Wallpaper</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Paper, often decorated with a printed pattern, painted or embossed design, and usually provided in rolls and used to line the interior walls of a building for decorative purposes.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
