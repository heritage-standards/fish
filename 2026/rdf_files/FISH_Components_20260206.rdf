        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Yoke</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A short timber linking two pieces of timber.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138549">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
