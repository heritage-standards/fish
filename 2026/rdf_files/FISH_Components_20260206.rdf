        <skos:prefLabel xml:lang="en">Revetment</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A thin masonry facing or cladding employed to conceal the surface or structure behind it.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139020">
