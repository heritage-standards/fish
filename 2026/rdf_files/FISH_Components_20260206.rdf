    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Treadmill Crane</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A crane operated by a treadmill turned by the walking action of men placed within it.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137682">
    <skos:altLabel xml:lang="en">Tearoom</skos:altLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137404"/>
