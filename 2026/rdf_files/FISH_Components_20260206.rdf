        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Keeping Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room that serves as a combined living-room, kitchen and workshop.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
