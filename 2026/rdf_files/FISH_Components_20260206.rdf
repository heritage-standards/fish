    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Gas Turbine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A heat engine prime mover in which hot gases or hot air expand as they pass through and rotate vanes attached to a central shaft, enclosed in a chamber.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138374">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137818"/>
