    <skos:prefLabel xml:lang="en">Bar Room</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139622"/>
    <skos:scopeNote xml:lang="en">A room in a public house, hotel, club etc. containing a bar from which alcoholic drinks are served.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139427">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
