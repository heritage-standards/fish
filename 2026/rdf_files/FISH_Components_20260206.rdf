    <skos:scopeNote xml:lang="en">A two dimensional image using paint applied to the surface of a wall.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137801">
