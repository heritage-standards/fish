    <skos:scopeNote xml:lang="en">Decorative ornamentation consisting of alternating oval and V-shaped motifs, used to enrich ovolo mouldings.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137427">
    <skos:altLabel xml:lang="en">Embattlement</skos:altLabel>
