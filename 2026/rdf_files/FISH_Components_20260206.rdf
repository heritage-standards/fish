    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Living Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A room for general daily use, usually in a family dwelling.</skos:scopeNote>
  </skos:Concept>

