        <skos:prefLabel xml:lang="en">Graffito</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An inscription on illustration applied to a wall by carving into its plaster to reveal a different colour beneath.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/140089"/>
