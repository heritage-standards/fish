        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Portcullis</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A large, movable barrier, usually an iron or wooden grating with pointed bars along its bottom edge, with its sides set in vertical grooves above a castle's gateway enabling it to be dropped to bar entry.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

