        <skos:prefLabel xml:lang="en">Fleche</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A spire, or spirelet surmounting a roof, especially over the crossing of a French Gothic Cathedral.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
