        <skos:prefLabel xml:lang="en">Narthex (Classical)</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A transverse vestibule at the west end of a church.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138044"/>
