        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Stoup</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A fixed basin, containing Holy Water, positioned near the entrance of a church, usually placed within a niche, on a wall or pier, or freestanding upon a pedestal.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138320">
