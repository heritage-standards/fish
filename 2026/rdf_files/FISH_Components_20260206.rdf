    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pump</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A power driven machine or device for raising a liquid or forcing it along a pipe, or for compressing a gas.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137263">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138063"/>
