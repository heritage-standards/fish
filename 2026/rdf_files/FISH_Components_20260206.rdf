        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hammer Post</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A vertical timber resting on a hammer beam and forming a triangle between it and a principal.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137923">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138106"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/137923</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">King Post</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An upright post set on a tiebeam or collar and used to support a ridge piece.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138007"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138140">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138106"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138140</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Queen Post</skos:prefLabel>
        <skos:scopeNote xml:lang="en">One of a pair of posts, placed symmetrically on a tie beam,  supporting a collar purlin or plate.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138412">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138106"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138412</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Wall Post</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A post, usually carrying a tiebeam, which forms part of a wall in a timber framed building.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138311"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138106</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Post</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A substantial vertical member, usually a component of a main framework.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137650">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138295"/>
