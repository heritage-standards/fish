    <skos:prefLabel xml:lang="en">Hydraulic Engine</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An engine, introduced in Germany 1748 for use in mines, worked by high pressure water.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137691">
