        <skos:prefLabel xml:lang="en">Railway Inclined Plane</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A slope, usually with rails, along which a vehicle can be moved between two relatively flat stretches of railway.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137971"/>
