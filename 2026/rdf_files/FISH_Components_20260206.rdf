        <skos:prefLabel xml:lang="en">Common Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room in general use for persons to meet, often found at institutions such as colleges.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
