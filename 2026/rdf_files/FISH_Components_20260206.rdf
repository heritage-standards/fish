    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tiling</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An area or series of tiles applied, usually to an interior floor or wall's surface, for practical or decorative effect.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139825">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139432"/>
