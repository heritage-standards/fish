    <skos:prefLabel xml:lang="en">Baluster</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An upright member supporting a coping or handrail in a balustrade or staircase.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137398">
