        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Chandelier</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A branched, hanging light fitting, often ornate in design, provifding illumination from a number of candles or lightbulbs.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139379">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137774"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/139379</dc:identifier>
