    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Bead And Reel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Decorative ornamentation consisting of alternating bead shapes with small, elliptical forms resembling reels</skos:scopeNote>
  </skos:Concept>

