    <skos:scopeNote xml:lang="en">A horizontal timber set in the plane of a roof's slope and supporting common rafters.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138134">
