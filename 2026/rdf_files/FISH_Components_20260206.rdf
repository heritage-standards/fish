        <skos:prefLabel xml:lang="en">Saw Tooth Truss</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A roof truss used for small spans with a saw-tooth overall shape braced by vertical and diagonal members.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138204">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138370"/>
