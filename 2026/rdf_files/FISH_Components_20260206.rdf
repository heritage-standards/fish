        <skos:prefLabel xml:lang="en">French Window</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A casement  window, carried down to floor level, and opening like two-leafed glazed doors to a garden, veranda or terrace.</skos:scopeNote>
