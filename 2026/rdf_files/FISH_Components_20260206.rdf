        <skos:prefLabel xml:lang="en">Trapdoor</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A horizontal door within, and usually flush with surface of, a floor, ceiling or roof.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

