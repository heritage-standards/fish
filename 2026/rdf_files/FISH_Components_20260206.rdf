        <skos:prefLabel xml:lang="en">Dais</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A raised platform at the end of a hall on which the high table sat, though sometimes used to describe the table itself.</skos:scopeNote>
      </skos:Concept>
