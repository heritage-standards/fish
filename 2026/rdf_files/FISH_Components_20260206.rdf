        <skos:prefLabel xml:lang="en">Chinese Room</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A room decorated, and furnished, in the style of the Chinese.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137563">
