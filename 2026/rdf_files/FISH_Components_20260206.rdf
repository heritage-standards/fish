    <skos:prefLabel xml:lang="en">Tie</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any member that connects two bodies, such as the sloping sides of a roof, to prevent them pulling apart.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138345">
