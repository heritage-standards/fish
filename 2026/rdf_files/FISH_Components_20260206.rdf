        <skos:scopeNote xml:lang="en">The area or platform at the top of a staircase.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/139424"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139503">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137489"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
