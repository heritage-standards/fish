    <skos:prefLabel xml:lang="en">Neck Moulding</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A moulding on the neck of a column.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137491">
