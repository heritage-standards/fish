        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Bed Moulding</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A moulding on an entablature that is between the frieze and the corona.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137467">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
