    <skos:scopeNote xml:lang="en">A figurative or abstract design in the round or in relief and can be of various materials. For freestanding sculptures see also Monument Types Thesaurus.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137510">
