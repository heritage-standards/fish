        <skos:prefLabel xml:lang="en">Cabinet</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A small room used as a study for the preservation of papers etc. Generally use for any small room appended to a larger one.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

