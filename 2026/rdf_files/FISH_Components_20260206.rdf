    <skos:prefLabel xml:lang="en">Base</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The lowest part of a structure, such as a pier, or the section of an order on which the shaft of a column sits.</skos:scopeNote>
  </skos:Concept>

