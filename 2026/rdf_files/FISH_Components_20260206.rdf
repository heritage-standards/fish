    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Bay Window</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A window that forms a projection from the body of a building, extending down to ground level, forming a bay in the wall's interior.</skos:scopeNote>
  </skos:Concept>

