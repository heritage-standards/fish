        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Arch Band</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The part of a rib or arch visible below the general surface of the vault.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137346"/>
