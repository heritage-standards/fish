    <skos:prefLabel xml:lang="en">Diminished Principal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A principal that has been reduced to the same thickness as a common rafter where the roof has clasped purlins.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138116">
