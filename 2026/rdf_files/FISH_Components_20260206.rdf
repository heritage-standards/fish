        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Casemate</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A chamber built into a wall in a defensive structure.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

