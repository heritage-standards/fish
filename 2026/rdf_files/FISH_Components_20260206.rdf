        <skos:prefLabel xml:lang="en">Steam Pump</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A pump driven by steam power generated by solid fuels.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138417"/>
