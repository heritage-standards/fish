    <skos:scopeNote xml:lang="en">A roof with one side longer than the other, continuing at the same pitch over an extension to a building. Commonly found in New England Colonial architecture.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138076">
