    <skos:prefLabel xml:lang="en">Outshot</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An extension to a building, though sometimes contemporary with it, housed under a lean-to roof.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138063">
    <skos:altLabel xml:lang="en">Passageway</skos:altLabel>
    <skos:altLabel xml:lang="en">Transyte</skos:altLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137263"/>
