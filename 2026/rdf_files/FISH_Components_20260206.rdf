        <skos:prefLabel xml:lang="en">External Staircase</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A flight of stairs, situated on a building's exterior, extending to an upper storey.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

