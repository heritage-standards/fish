    <skos:prefLabel xml:lang="en">Pier</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A solid support of masonry to sustain vertical pressure and frequently each of the pillars from which an arch springs.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137821">
