    <skos:prefLabel xml:lang="en">Ball Finial</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A decorative ball usually used to ornament a bench end, canopy, gable, pinnacle or spire.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137769">
