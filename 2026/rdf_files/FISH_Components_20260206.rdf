        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cinquefoil</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An ornamental foliation in panels or tracery so called because it is arranged around five intervals, known as foils or cusps, that describe the outlines of five leaves or petals.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138349</dc:identifier>
