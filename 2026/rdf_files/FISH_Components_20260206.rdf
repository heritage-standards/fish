    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Auxiliary Rafter</skos:prefLabel>
    <skos:scopeNote xml:lang="en">In a truss, a rafter used to stiffen the principal rafter by doubling it.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138145">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137378"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137586">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138145"/>
