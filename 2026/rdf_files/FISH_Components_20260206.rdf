        <skos:prefLabel xml:lang="en">Annex</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A structure, or building, forming a supplementary and subsidiary part of a main complex.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137317"/>
