        <skos:prefLabel xml:lang="en">Confessio</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A recess or chamber near the altar which holds a relic. A feature of medieval churches.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137605">
