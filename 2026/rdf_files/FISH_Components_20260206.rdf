        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Lamp</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A light, usually encased and mounted upon brackets, often used outdoors.  It may be powered by gas, electricity or house a candle.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/139844">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137774"/>
