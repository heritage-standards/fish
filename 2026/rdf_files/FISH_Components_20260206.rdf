    <skos:scopeNote xml:lang="en">The post at the centre of a winding staircase from which the steps radiate; or the post, supporting the handrail and string, at the angle of a square staircase.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/138014">
