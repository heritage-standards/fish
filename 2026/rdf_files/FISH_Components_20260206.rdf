    <skos:scopeNote xml:lang="en">A small turret that projects from the top of a tower or parapet.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137432">
    <skos:altLabel xml:lang="en">Birds Head Moulding</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137990"/>
