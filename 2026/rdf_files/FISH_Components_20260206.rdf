        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Cupola</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A small dome on top of a larger dome, roof etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137722">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/137489"/>
