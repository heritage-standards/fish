    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138379"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138380"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138036"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_com/concepts/138381</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-06T16:13:07</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tuscan Order</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A biggest and plainest of the classical architectural orders, based upon a simplified version of the Doric Order. Sometimes called the Gigantic order, though not to be confused with the Colossal or Giant Order.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/137664">
    <skos:altLabel xml:lang="en">Ogee Moulding</skos:altLabel>
