        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Long And Short Work</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A Saxon quoin consisting of alternating horizontally and vertically laid stones.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_com/concepts/143478">
        <skos:altLabel xml:lang="en">Hollow Quoin</skos:altLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138143"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_com"/>
