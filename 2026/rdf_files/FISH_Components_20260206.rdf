        <skos:prefLabel xml:lang="en">Pulpit</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A raised structure from which a priest can preach.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_com/concepts/138148"/>
