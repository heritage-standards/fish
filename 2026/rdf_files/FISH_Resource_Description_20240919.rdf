        <skos:prefLabel xml:lang="en">Stratigraphic Matrix</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A schematic diagram showing the relationships of the composition and strata of layers identified during excavation or intervention.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138807">
