        <skos:scopeNote xml:lang="en">An outline of the circumstances to be addressed, with an indication of the scope of work which will be required (Scottish term)</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139573">
