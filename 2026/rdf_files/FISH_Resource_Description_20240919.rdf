    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Index</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A structured set of data taken from a larger work to assist in location of particular subject matter.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138779">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138709"/>
    <skos:narrower>
