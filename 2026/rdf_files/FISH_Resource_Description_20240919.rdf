        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Card Index</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Cards, often printed with forms, for the recording and sorting of information in a structured manner.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138768</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
