    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Dendrochronology Report</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A report that primarily details the results of attempts to assign a date to wooden structures or objects by the comparative study of the growth rings in trees and aged wood.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138810">
