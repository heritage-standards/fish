        <skos:prefLabel xml:lang="en">Field Survey Report</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A report detailing the results of a field survey. Usually restricted to a survey of a small or specific area or site.</skos:scopeNote>
      </skos:Concept>
