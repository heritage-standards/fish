        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Picture Postcard</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Card printed with an image, often a photograph on one side, and space for a short message and a postal address on the other.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138738">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138736"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138738</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Illustration</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An image used to convey information, often as part of a larger publication or exhibition.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138740"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138741">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138736"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
