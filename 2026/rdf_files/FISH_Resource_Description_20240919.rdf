        <skos:prefLabel xml:lang="en">Section Drawing</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Drawing of the vertical face of an excavated feature or features depicting the vertical extent and stratigraphic relationship between identified layers or deposits.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139019">
