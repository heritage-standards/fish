        <skos:prefLabel xml:lang="en">Measured Survey Drawing</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A drawing which depicts to scale a feature within the landscape. For drawings of selected features of a site use SCALE DRAWING..</skos:scopeNote>
      </skos:Concept>
