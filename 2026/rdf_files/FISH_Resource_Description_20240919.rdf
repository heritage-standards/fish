        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Chart</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A depiction of land, coastal or sea areas intended to aid navigation, usually using latitude and longitude co-ordinates.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138734">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138732"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138734</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Sketch Map</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A map generally produced manually to indicate main features of an area quickly, for example to assist location of a particular place.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138732</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Map</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A pictoral depiction of an area of landscape.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138736">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138705"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138737">
