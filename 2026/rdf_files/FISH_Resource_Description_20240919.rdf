        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Overlay</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A drawing, generally on a transparent sheet, which can be placed on top of another image to combine information from both.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138749">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139037"/>
