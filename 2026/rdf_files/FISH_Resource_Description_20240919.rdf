        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Floorplan</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Plan showing a horizontal section, size and arrangement of rooms within a building, may include location of doors, windows and other features.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138748">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139037"/>
