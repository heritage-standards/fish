        <skos:scopeNote xml:lang="en">A report on the archaeology of an area, based primarily on existing records and resources.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138777">
