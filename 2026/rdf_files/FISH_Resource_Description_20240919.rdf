    <skos:scopeNote xml:lang="en">Optical discs on which programs, data, or music are digitally encoded for a laser beam to scan, decode and transmit to a playback system, computer monitor or television set. [AAT]</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138811">
