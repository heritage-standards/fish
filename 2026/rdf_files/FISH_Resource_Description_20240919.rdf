        <skos:prefLabel xml:lang="en">Aerial Photograph Transcription</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The process of transcribing the features on an aerial photograph onto a map or plan.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138798"/>
    <skos:narrower>
