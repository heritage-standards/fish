        <skos:prefLabel xml:lang="en">Infrared Film</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Photographic film responsive to infrared radiation. Used to record temperature variations in the subject, indicative of hidden archaeological or architectural features.</skos:scopeNote>
      </skos:Concept>
