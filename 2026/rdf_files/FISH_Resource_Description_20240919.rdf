    <skos:prefLabel xml:lang="en">Diary</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A chronological journal, generally showing appointments, or recording memories and impressions of a days events over a period of time.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138768">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138709"/>
