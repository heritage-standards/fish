    <skos:prefLabel xml:lang="en">Catalogue</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Structured descriptions of an archive or collection used to assist retrieval and management, or presentation to the public.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138724">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138705"/>
