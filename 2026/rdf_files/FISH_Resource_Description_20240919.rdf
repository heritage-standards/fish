        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Scale Drawing</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A scaled drawing based on measurements taken from life.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138747">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139037"/>
