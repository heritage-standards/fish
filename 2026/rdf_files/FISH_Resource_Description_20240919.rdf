    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Record Form</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A paper form used to record specific information in a systematic way.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138798">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139037"/>
