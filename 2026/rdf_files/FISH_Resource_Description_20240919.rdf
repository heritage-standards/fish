        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Video Clip</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An extract from a longer video film, used as an illustration.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139050">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138724"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
