        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Context Sheet</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A form used to record the details of a feature identified by archaeological investigation, generally including location, depth, colour, texture, inclusions and stratigraphic relationship to other contexts.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138781">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138779"/>
