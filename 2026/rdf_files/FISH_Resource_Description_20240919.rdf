    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Picture</skos:prefLabel>
    <skos:scopeNote xml:lang="en">General term for images used to represent a particular place or item, or convey information.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138739">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138740"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
