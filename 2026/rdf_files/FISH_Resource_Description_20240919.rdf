        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Topographical Drawing</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A drawing used to convey information about the arrangement and size of features in a defined location under study.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138797">
