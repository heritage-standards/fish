        <skos:prefLabel xml:lang="en">Plan</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Used for orthographic drawings in the horizontal plane, generally from above generally depicts localised areas.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138746">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139037"/>
