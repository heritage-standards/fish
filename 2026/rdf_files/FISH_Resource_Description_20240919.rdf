        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Context Plan</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Scale drawing showing the horizontal extent, height and arrangement of an excavated layer or feature on an archaeological site.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

