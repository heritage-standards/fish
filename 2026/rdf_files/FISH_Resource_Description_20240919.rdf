        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Colour Negative</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A photographic frame of developed colour film which can be used to print a photographic image.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138827">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138817"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138827</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Black And White Negative</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A photographic frame of developed black and white film from which a positive print can be produced.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/141680"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138817</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Photographic Medium</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The class or material that a photograph is produced upon. [AAT] Use a specific term or terms as appropriate.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138828">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/141680"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138828</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Microfiche</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A flexible, transparent sheet of film bearing a number of reduced images.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/141680">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138828"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/138829">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/141680"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/138829</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Microfilm</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A film strip or roll containing reduced images.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138817"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/141680</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Microform</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A medium containing microphotographic images, usually reproduced on film, requiring magnification to render them readable.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139576">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138709"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139577"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139578"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139576</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Official Designation Notification</skos:prefLabel>
    <skos:scopeNote xml:lang="en">This term is appropriate to official notifications of a monument or area whether they are statutory or purely advisory. Where possible the specific document type should be indexed for example Scheduled Monument Notification.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139577">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139576"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139580">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139577"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139580</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Scheduled Monument Notification</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Any notification, update or amendment relating to the scheduling of a monument. Usually includes description and a map showing the limit of the scheduling. It confers a statutory status and receipt is an acknowledgement of the scheduling.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139583">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139577"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139583</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">List Of Buildings</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A list of buildings of special architectural or historic interest. This list confers a statutory level of protection status to the buildings contained within it and usually includes a description of each building.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139577</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Statutory Designation Notification</skos:prefLabel>
    <skos:scopeNote xml:lang="en">This class of documents confers statutory designation on the monuments listed within them. It usually is restricted to legally defined national or local notifications of designation.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139578">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139576"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139581">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139578"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139581</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Battlefields Register</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A list of English battlefields maintained by English Heritage. Inclusion in the document does not confer any statutory status. It lists and records the details of battlefields to preserve their nature and survival.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/139582">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/139578"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139582</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Register Of Parks And Gardens</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A register which including sites retaining any evidence of pre-1750 layouts; significant evidence of pre-1820 layouts; good examples of the best gardens from 1820 to 1880; are good examples of the best gardens laid out after 1880 but before 1970.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/139578</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Advisory Designation Notification</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The contents of these documents do not confer any statutory designation on the monuments listed, they are purely advisory notifications for use within preserving the historic environment.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/164072">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/170847"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/164073"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/164074"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/164072</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Scientific Dating Report</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A report that primarily details the results of attempts to assign a date to materials or deposits using scientific methods such as Palaeomagnetism, Dendrochronology or Radiocarbon Dating.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/547/concepts/170847">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/164072"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/547/concepts/138773"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/547"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/547/concepts/170847</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-09-19T12:28:53</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Archaeological Science Report</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A report detailing the results of the application of scientific techniques to the analysis of archaeological materials.</skos:scopeNote>
  </skos:Concept>

</rdf:RDF>