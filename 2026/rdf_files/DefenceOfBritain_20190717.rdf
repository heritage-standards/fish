    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/151401">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A site where a cable was fired into the air, with parachutes attached to either end, to present an aerial obstruction to bring down, through contact, fouling and general drag, or obstruct the passage of an aircraft. Usually found as one of a group.</skos:scopeNote>
    <skos:altLabel xml:lang="en">Parachute And Cable Projecter</skos:altLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
