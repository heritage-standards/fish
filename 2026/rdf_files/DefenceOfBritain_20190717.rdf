    <skos:scopeNote xml:lang="en">A building used for the storage and distribution of civilian respirators and Air Raid Precautions equipment.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Air Raid Precautions Store</skos:prefLabel>
