    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140689"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:prefLabel xml:lang="en">Photo Interpretation Centre</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A building in which photographers, taken for aerial reconnaissance purposes, are analysed and interpreted to provide intelligence on enemy activities.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140767">
