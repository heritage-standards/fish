    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123450">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A building or site used for the exercise and training of military personnel.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Drill Hall</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123450</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123539"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123481">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123411"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123481</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">K Site</skos:prefLabel>
    <skos:altLabel xml:lang="en">Dummy Landing Ground (Day)</skos:altLabel>
    <skos:scopeNote xml:lang="en">A decoy site designed to replicate the layout of an RAF satellite airfield, complete with dummy aircraft, simulated runways and simple structures intended to fool enemy aircraft during daylight raids.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140711">
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Military Building</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A building of unknown purpose found at a military site. Use more specific type where known.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140711</dcterms:identifier>
