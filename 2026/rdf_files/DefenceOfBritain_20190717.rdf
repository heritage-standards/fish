    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123445"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123380"/>
    <skos:prefLabel xml:lang="en">Anti Tank Obstacle</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
