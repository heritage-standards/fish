    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123375"/>
    <skos:prefLabel xml:lang="en">Petroleum Warfare Site</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A site, usually including fuel tanks, pipeworks and control buildings, where flaming petroleum was intended to be used as a weapon against a hostile invasion.</skos:scopeNote>
