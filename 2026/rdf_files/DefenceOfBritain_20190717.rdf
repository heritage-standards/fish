    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123531</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A decoy fire positioned close to a legitimate target which would be lit in the event of an incendiary attack in the hope that subsequent bombs would be drawn to the area of the decoy.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Qf Site</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123568">
