    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">An airfield building housing a turret gunnery trainer used to teach air gunners how to report the correct position of enemy aircraft by practising shooting against projected moving images of enemy aircraft displayed on a target screen (WWII).</skos:scopeNote>
