  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123510">
    <skos:altLabel xml:lang="en">Norcon Pillbox</skos:altLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123510</dcterms:identifier>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Pillbox (Type CP/6/40/111)</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A circular pillbox, usually consisting of a concrete pipe with a timber and corrugated iron roof, surrounded and covered by earth and sandbags. Built to a design by Norcon Ltd, a company dealing in concrete pipes.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123501"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/148458">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Aircraft Compass Platform</skos:prefLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A circular concrete platform onto which aircraft would be taxied allowing the ground crew to calibrate, check and adjust the accuracy of the aircrafts compass, usually by rotating the platform.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131133"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/148458</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131258">
    <skos:prefLabel xml:lang="en">Seagull Trench</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/131258</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A trench in the form of a flattened 'W' with a flat concrete roof covered in turf, supported on concrete pillars. The name derives from the resemblance to a child's drawing of a seagull in flight.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123362"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135708">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A small transportable hangar built by the Teesdie Bridge and Engineering Company. Mainly used on RNAS airfields for folding wing aircraft.</skos:scopeNote>
