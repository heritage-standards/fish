    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A protected building used for the storage of explosives and other pyrotechnic equipment and designed to Air Ministry drawing number 2647/37.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131236">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123395"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
