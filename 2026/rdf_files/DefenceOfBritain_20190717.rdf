    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135705</dcterms:identifier>
    <skos:scopeNote xml:lang="en">An aircraft hangar designed by T. Bedford Consulting Engineers usually erected on aircraft factory sites rather than operational airfields.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Aircraft Hangar (Type B2)</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
