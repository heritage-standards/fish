    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A reinforced wall designed to reflect the blast from an explosion. Often found associated with powder magazines, pillboxes and air raid shelters.</skos:scopeNote>
