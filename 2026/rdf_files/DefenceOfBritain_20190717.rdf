    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123440"/>
    <skos:prefLabel xml:lang="en">Barbed Wire Entanglement</skos:prefLabel>
    <skos:scopeNote xml:lang="en">One or more coils of barbed wire intended to impede the advance of hostile troops.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135683">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135683</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Aircraft Storage Shed (Type E)</skos:altLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
    <skos:scopeNote xml:lang="en">A military storage aircraft hangar designed in 1937. It has a curved profile and is constructed from steel ribs supporting a concrete skin. The roof is covered with earth and turf.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Aircraft Hangar (Type E)</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/134582">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A bridge which has had mines placed within its structure to enable it to be destroyed in the event of an invasion.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/134582</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Mined Bridge</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
