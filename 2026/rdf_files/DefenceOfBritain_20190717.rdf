    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131276"/>
    <skos:scopeNote xml:lang="en">An area of land, with associated buildings and targets, used for practicing the dropping of bombs and other aspects of air warfare.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140750"/>
