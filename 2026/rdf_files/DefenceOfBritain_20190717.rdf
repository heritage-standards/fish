    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Watch Office (1959/34)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A two-storey watch office, built to Air Ministry drawing number 1959/34. It became the standard design for watch offices with a large, almost square, ground plan with a central observation tower.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
