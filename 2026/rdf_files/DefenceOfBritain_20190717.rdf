    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123497"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Radar Station</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A building or site incorporating equipment used for detecting the presence of enemy aircraft or ships.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123534</dcterms:identifier>
