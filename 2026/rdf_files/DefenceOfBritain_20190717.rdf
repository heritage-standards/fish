  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135712">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135712</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A steel aircraft hangar evolved from the German "Lamellendach", a segmental roof design of the 1920s using a diamond shaped web of pressed steel producing a hangar with a shallow curving profile. Used for both military and civil purposes.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
