    <skos:scopeNote xml:lang="en">A site associated with Operation PLUTO (Pipe Line Under The Ocean) the operation to supply the allies with fuel following the invasion of Normandy.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/130353">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Water Tower (1178/25)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A large, circular, reinforced-concrete tank supported on concrete staging built to Air Ministry drawing number 1178/25 and designed to hold 30,000 gallons of water. The height of the tower varied according to local site requirements.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/130353</dcterms:identifier>
