    <skos:scopeNote xml:lang="en">A ditch designed to obstruct the progress of a tank or armoured vehicle. Use more specific type where known.</skos:scopeNote>
    <skos:altLabel xml:lang="en">Anti Tank Trap</skos:altLabel>
