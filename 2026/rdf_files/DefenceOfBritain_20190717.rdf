    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123501"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A machine gun post designed by James Ruck constructed from hollow concrete blocks and prefabricated concrete sheeting with loopholes allowing for a garrison of eight.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135509">
    <skos:prefLabel xml:lang="en">Night Fighter Station Watch Office</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135509</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
