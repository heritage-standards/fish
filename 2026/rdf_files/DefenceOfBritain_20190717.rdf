  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131376">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/131376</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Caltrop</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">Blocks of concrete with four protruding arms so that, whichever way up the caltrop is placed, one arm will always point upward. Used in imitation of the iron caltrops thrown on the ground to impede cavalry.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123380"/>
