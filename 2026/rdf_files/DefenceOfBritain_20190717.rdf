    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">An all timber constructed watch office with meterological section. Similar in design to 2328/39 and 5845/39. There were only two known examples built in the UK at Wick and St.Eval.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131273">
