  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135670">
    <skos:scopeNote xml:lang="en">A side-opening steel framed shed. A smaller version of the SEAPLANE SHED (TYPE F) they were built from 1916 on RNAS seaplane bases.</skos:scopeNote>
