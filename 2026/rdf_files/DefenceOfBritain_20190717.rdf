  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123377">
    <skos:scopeNote xml:lang="en">A purpose built trench designed to prevent the successful landing of enemy glider-borne and airborne forces.</skos:scopeNote>
