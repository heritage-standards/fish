    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">A chamber built into a structure, such as a bridge, in which an explosive, demolition charge could be placed. The charge could then be inserted in the event of an invasion.</skos:scopeNote>
