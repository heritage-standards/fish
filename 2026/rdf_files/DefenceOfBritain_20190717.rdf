    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Very Heavy Bomber Station Control Tower (294/45)</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135487"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:prefLabel xml:lang="en">Bomber Station Control Tower (294/45)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A control tower designed for use on Very Heavy Bomber Station Airfields. Designed to Air Ministry drawing number 294/45 they were the first to be have a Visual Control Room .</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140791">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140791</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130253"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Signal Square</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A signalling structure used on WWII airfields, comprising a concrete square base with a kerbed border into which concrete signal symbols could be placed to advise pilots in the air of current airfield state e.g. directions of landing and airfield circuit.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
