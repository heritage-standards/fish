    <skos:prefLabel xml:lang="en">Anti Aircraft Gun Post</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123482"/>
    <skos:scopeNote xml:lang="en">A light anti aircraft position, usually open-walled and built of concrete, brick or sandbags used to emplace one or more machine guns mounted on pintels.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123516">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123501"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
