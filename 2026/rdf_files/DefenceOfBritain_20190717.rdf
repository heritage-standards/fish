    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123408"/>
    <skos:scopeNote xml:lang="en">Obstacles, including scaffolding and anti tank blocks designed to impede an enemy's attempts to land forces onto open beaches.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Anti Boat Landing Obstacle</skos:prefLabel>
  </rdf:Description>
