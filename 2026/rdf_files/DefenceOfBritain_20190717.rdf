    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123526"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123428"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
