    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
    <skos:scopeNote xml:lang="en">A curved military aircraft hangar produced in 1939. The frame is steel which is then clad with steel sheeting and reinforced concrete and typically covered with a thin layer of concrete, earth and turf.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Aircraft Hangar (Type L)</skos:prefLabel>
