    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A siren used to warn of an impending attack by enemy aircraft.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123548">
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123548</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Ruck Machine Gun Post</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
