  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135488">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135487"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Chief Instructors Block (5740/36)</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135488</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A central tower with a single-storey wing either side. The tower contained the watch office on the ground floor, observation room on the second with each wing containing an office for the Chief Flying Instructor or the officer commanding and their aides.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140727">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Bombing Teacher Building</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140727</dcterms:identifier>
    <skos:scopeNote xml:lang="en">A building equipped with instruments and a flight simulator used to teach members of bomber crews how to correctly identify targets for bombing.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130233"/>
  </rdf:Description>
