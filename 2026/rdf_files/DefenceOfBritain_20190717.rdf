    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A type of temporary military aircraft hangar introduced in 1940; of steel welded and bolted construction typically clad in galvanized corrugated iron sheets. The T2 became the standard temporary hangar for the RAF in World War Two.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
