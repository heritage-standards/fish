    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A pass, vulnerable to attack from the enemy but essential for the movement of troops and which, if captured, could divide a defending force. As a result such passes are defended with anti invasion defences such as pillboxes.</skos:scopeNote>
  </rdf:Description>
