    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131234"/>
    <skos:altLabel xml:lang="en">Auxiliary Unit Hideout</skos:altLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
