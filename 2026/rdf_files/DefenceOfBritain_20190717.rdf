    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123359"/>
    <skos:scopeNote xml:lang="en">Sites and buildings used in the coordination of the defence of the civilian population during times of war. Could also be used during times of national emergency.</skos:scopeNote>
