    <skos:prefLabel xml:lang="en">Auxiliary Unit Control Station</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An underground hideout containing radio equipment to be used by the Auxiliary Units to relay information gained from the various out-stations back to headquarters.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
