    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A range marker allowing bombers to locate the bombing range.</skos:scopeNote>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140740"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140748</dcterms:identifier>
