    <skos:scopeNote xml:lang="en">An aircraft hangar built to Air Ministry design number 454/43. Mainly constructed on aircraft factory aerodromes</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123572">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123421"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">War Room</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A reinforced concrete structure, which may be sited above ground or semi-sunken, from where it was intended to conduct the business of government from, in the event of nuclear war. Date specific to the early-mid 1950's.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123572</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135469">
