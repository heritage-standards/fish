  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135687">
    <skos:scopeNote xml:lang="en">A type of large permanent military aircraft hangar with a curved steel frame and storage annexes on its side used in World War II. It was intended for storage purposes on Aircraft Storage Unit stations.</skos:scopeNote>
