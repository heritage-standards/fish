    <skos:scopeNote xml:lang="en">A purpose-built building with a brick tower constructed on one end, based on drawing number (9294/42). Used for the drying of parachutes.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/130284</dcterms:identifier>
