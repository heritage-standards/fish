    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123561"/>
    <skos:scopeNote xml:lang="en">Obstacles, usually constructed of concrete and/or metal, designed to prevent the advance of enemy armoured divisions in the event of a successful invasion.</skos:scopeNote>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123388"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123537"/>
