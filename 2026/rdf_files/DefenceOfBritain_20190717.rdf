    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130233"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A building of varying designs intended for directing military aviation operations. Normally associated with military airfields.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135510">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Watch Office (15684/41)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A night fighter station watch office based on the standard design for Bomber Satellite Station watch offices.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135509"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135510</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140638">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:altLabel xml:lang="en">Aircraft Landing Ground</skos:altLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140638</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131133"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140799"/>
    <skos:scopeNote xml:lang="en">An area or site used for the landing and take-off of aircraft, often including associated buildings, equipment and other installations.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Airfield</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140758">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140805"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140758</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A building used for the daily administration of an organisation or military force.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123488"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140798"/>
    <skos:prefLabel xml:lang="en">Headquarters</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/143545">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Callender Hamilton Hangar</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Similar in design to the Callender Hangar but with a reduced height of 17ft. Built to Air Ministry drawing number 17346/40.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/143545</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135696"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140696">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123366"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A prefabricated structure of a steel frame clad in corrugated iron. Semi-circular in section they were used as accommodation for the armed forces and, during WWII, as emergency housing for bombed out civilians. Also used for storage.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140696</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Nissen Hut</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140649">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123357"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140649</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">An observation post used by Air Raid Precautions wardens to watch for aircraft and bomb strikes.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Air Raid Precautions Observation Post</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/133135">
    <skos:scopeNote xml:lang="en">A site which is known, or believed to be, where an aircraft crashed. It is an offence to interfere with the wreckage of crashed military aircraft without a licence (Protection of Military Remains Act 1986).</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Aircraft Crash Site</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/133135</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123488"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/130279">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/130279</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130293"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Parachute Store (6351/37)</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A protected parachute store built with permanent brick cavity walls and a roof of reinforced concrete slabs in two heights separated by lantern lights.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123370">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123372"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140747"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123369"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123370</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Sites, buildings and structures for the control and mounting of anti aircraft artillery. Also, structures for passive or indirect defence against enemy aircraft.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123400"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123354"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123549"/>
    <skos:prefLabel xml:lang="en">Anti Aircraft Defence Site</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123438">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123438</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">Cubes of solid concrete, usually with sides of 3 feet 6 inches or 5 feet which when placed in rows were intended to form a substantial barrier to enemy armoured divisions in the event of invasion.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Cube</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123380"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135703">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135703</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Super Robins</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An aircraft hangar designed to Air Ministry specification (drawing number 6910/43). Similar in design to the ROBINS AIRCRAFT HANGAR but larger.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123527">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123527</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Pole</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A telegraph pole, tree trunk or similar erected on the side of a road, or in an open space, to prevent the landing of hostile aircraft.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123376"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140799">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140799</dcterms:identifier>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Emergency Landing Ground</skos:prefLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A prepared area of cleared ground on which an aircraft could make an emergency landing.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140638"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123419">
    <skos:prefLabel xml:lang="en">Chain Home Low Station</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A radar station with sets operating on a wavelength of 1.5m. Chain Home Low Stations were intended for use in locating low-flying aircraft but was also capable of detecting high-flying aircraft.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123419</dcterms:identifier>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123420"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140741">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140730"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140741</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Garage</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A building used for the storage and maintenance of motor vehicles.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123476">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">A plinth or pedestal, usually of concrete, to which an anti aircraft or coastal battery gun was fitted. Holdfasts are often the only evidence for a weapon which survive.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123476</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Holdfast</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123465"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123383">
    <skos:scopeNote xml:lang="en">A natural ditch the depth and/or width of which has been increased so as to prevent the progress of a tank or armoured vehicle.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Anti Tank Ditch (Natural Improved)</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123383</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123381"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123421">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
