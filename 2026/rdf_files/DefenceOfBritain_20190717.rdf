    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">An anti aircraft battery usually mounting smaller, faster weapons such as Bofors guns, intended to engage fast low flying aircraft.</skos:scopeNote>
