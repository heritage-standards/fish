  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123436">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A coastal battery used for delivering fire at long distance thus forcing a warship threatening or bombarding shore installations to withdraw out of range.</skos:scopeNote>
