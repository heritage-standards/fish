    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A radar station using equipment based upon apparatus developed for ionospheric research. Chain Home was the backbone of British radar provision in the Second World War.</skos:scopeNote>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123419"/>
