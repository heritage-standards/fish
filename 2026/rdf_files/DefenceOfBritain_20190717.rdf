    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A site, usually consisting of a simple open area of land or hardstanding and used for the storage of vehicles.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135707">
