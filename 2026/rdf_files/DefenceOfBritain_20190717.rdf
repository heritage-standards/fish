  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140708">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140698"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A building or site used for the storage and distribution of fuel.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Fuel Depot</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
