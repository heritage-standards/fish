  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140701">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140701</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123411"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A system of lights, controlled fires or dummy constructions, used to simulate a railway yard or sidings and thus confuse enemy aircraft into bombing these counterfeit targets.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Decoy Railway Site</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
