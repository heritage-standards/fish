    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">An air raid shelter, designed to be placed in the garden. Made from prefabricated components, they were often semi-sunken and the structure then covered with soil for added protection.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Anderson Shelter</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
