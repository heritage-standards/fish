    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135710</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Aircraft Hangar (Type VR2)</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123559">
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123559</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
