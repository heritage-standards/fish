    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A designated area, usually sited at a strategic crossroads, with fixed defences such as pillboxes, anti tank ditches and gun emplacements, designed to act as a rallying point for defenders.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
