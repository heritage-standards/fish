    <skos:scopeNote xml:lang="en">A complex of buildings used as a headquarters and training base for Royal Navy personnel. Even though they are buildings on land shore establishments are deemed to be shipsand are designated 'HMS' eg. HMS Dolphin in Portsmouth.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
