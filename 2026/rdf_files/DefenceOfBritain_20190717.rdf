    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123565</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Tetrahedron</skos:prefLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">Triangular concrete pyramids with 6 feet long sides and 5 feet high, intended to impede enemy movement in the event of invasion. Thought to be confined geogaphically to Southern Command.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140786">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140786</dcterms:identifier>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140821"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Target Range</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An area of ground used for the testing of, and practicing with, weapons against fixed and moveable targets.</skos:scopeNote>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140676"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135710">
    <skos:scopeNote xml:lang="en">A double-span aircraft hangar designed by Boulton &amp; Paul of London and Norwich. Mainly used on aircraft factory sites and at Armament Training Schools.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
