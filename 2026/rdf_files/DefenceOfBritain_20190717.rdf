  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135674">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135674</dcterms:identifier>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135672"/>
    <skos:altLabel xml:lang="en">Aeroplane Shed (Type A)</skos:altLabel>
    <skos:scopeNote xml:lang="en">A permanent military RAF aircraft hangar type, designed in 1924. It features a steel frame (with longitudinal ridge and valley trusses for the roof) reinforced concrete and brick infilling for the walls. Typically 122 foot span by 249 foot in length.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Aircraft Hangar (Type A)</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140773">
    <skos:prefLabel xml:lang="en">Tank Park</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140768"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A site where tanks and armoured fighting vehicles can be stored.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140773</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123500">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123500</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Pickett Hamilton Fort</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123501"/>
    <skos:altLabel xml:lang="en">Counter Balance Fort</skos:altLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123362"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A sunken, circular, concrete pillbox used on airfields. They remained flush with the surface to permit the free movement of aircraft, but if attack threatened, could be raised, hydraulically or by a counterbalance, and manned to give covering fire.</skos:scopeNote>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140757">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130253"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
