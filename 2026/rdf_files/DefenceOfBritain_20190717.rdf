    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Demolition Charge Site</skos:prefLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/134583"/>
    <skos:scopeNote xml:lang="en">A site used for the placing of an explosive, demolition charge. Many types of structures were prepared for demolition in the event of an invasion in order to cause the maximum disruption to the advance of hostile forces. Use more specifc type where known.</skos:scopeNote>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123445"/>
  </rdf:Description>
