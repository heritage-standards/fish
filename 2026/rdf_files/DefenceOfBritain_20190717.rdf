  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135696">
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135696</dcterms:identifier>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A transportable hangar designed by Callender Cable and Construction to Air Ministry drawing number 6633/37. A steel box-girder framework with corrugated iron cladding and canvas doors it had a clear door height of 25ft.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Callender Hangar</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
