  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140805">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/140758"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">An underground structure from which operations covering the whole, or part, of the country could be directed in the event of a nuclear attack. Usually equipped with air filtration equipment and supplies for several months.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140805</dcterms:identifier>
