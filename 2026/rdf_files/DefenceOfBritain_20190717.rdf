    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">A barracks comprising eight barrack blocks accessed via a central corridor. With four blocks on either side of the corridor the whole structure resembled a spider in plan.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Spider Billet</skos:prefLabel>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131173">
    <skos:scopeNote xml:lang="en">A building, originally used as a shelter for the duty pilot or officer on watch on an airfield, and later used to direct air traffic. Use more specific type where known.</skos:scopeNote>
