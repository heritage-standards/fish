    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123567">
    <skos:scopeNote xml:lang="en">A missile base armed with the Thor Intermediate Range Ballistic Missile. Thor Missiles were deployed in Britain under joint British/US control between 1959 and 1964.</skos:scopeNote>
