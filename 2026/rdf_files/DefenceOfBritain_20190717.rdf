  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135695">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135694"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:prefLabel xml:lang="en">Bellman Hangar</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A type of temporary transportable aircraft hangar designed in 1936 by N.S. Bellman. It was designed for ease of installation, and was composed of light rolled steel sections.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135695</dcterms:identifier>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131233">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123445"/>
    <skos:scopeNote xml:lang="en">An existing building which has been designated as the last point of defence in a defended locality, nodal point or centre of resistance. If all else failed the keep would be used as a last ditch defences.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/131233</dcterms:identifier>
