    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131138"/>
    <skos:scopeNote xml:lang="en">A power house built to Air Ministry drawing number 207/17 and comprising four rooms; a driver's room, workshop and store, battery room and engine room containing 2 generator sets.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
