    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123496">
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123547"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Orlit Post</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123496</dcterms:identifier>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:scopeNote xml:lang="en">A small prefabricated, reinforced concrete structure manufactured by Messrs Orlit Ltd for the Royal Observer Corps. The first were ordered in 1951, most were redundant by 1955, a few remained in use in eastern England until 1965.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/131154">
