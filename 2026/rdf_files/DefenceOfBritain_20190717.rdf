    <skos:prefLabel xml:lang="en">Coast Defence Chain Home Low Station</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A radar station with sets operating on a wavelenght of 1.5m established to provide radar plotting of both shipping and aircraft movements.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123420"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123492">
