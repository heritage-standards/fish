    <skos:scopeNote xml:lang="en">A command centre used to co-ordinate information received from Royal Observer Corps observation and monitoring posts.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140642</dcterms:identifier>
