    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135699">
    <skos:scopeNote xml:lang="en">A type of transportable aircraft hangar patented by Miskins and Sons in 1939. The arched hangar was constructed of steel or wooden ribs and generally clad in steel sheets. The hangar did not require any foundations and could be anchored by iron stakes.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135699</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Blister Hangar</skos:prefLabel>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
