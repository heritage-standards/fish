    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:scopeNote xml:lang="en">A pillbox which has been modified from a standard Directorate of Fortifications and Works design. Double index with specific type where known.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123503</dcterms:identifier>
