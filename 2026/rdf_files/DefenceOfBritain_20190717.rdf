    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/130276</dcterms:identifier>
    <skos:prefLabel xml:lang="en">Parachute Store (10825/42)</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/130293"/>
    <skos:scopeNote xml:lang="en">A distinctive, clerestory-roofed building of three 10ft and two 12ft bays, used for the drying, storage and packing of military parachutes and built to Air Ministry drawing number 10825/42.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/140728">
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
