    <skos:scopeNote xml:lang="en">A small, steel shelter designed for use as a firewatchers post during an air raid.</skos:scopeNote>
    <skos:prefLabel xml:lang="en">Consol Shelter</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123359"/>
