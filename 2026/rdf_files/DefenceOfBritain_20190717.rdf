  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123405">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123405</dcterms:identifier>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123403"/>
    <skos:scopeNote xml:lang="en">A structure, based on drawing number (3329/41), intended to be the headquarters for the coordination of an airfield's defences. Constructed above ground this design was found to be vulnerable and was superceded by the (11008/41).</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Battle Headquarters (3329/41)</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123423">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123423</dcterms:identifier>
