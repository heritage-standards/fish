    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:altLabel xml:lang="en">Lamella Aircraft Storage Shed</skos:altLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
  </rdf:Description>
