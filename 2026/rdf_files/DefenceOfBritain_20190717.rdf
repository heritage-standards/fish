    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:scopeNote xml:lang="en">A large steelframed military aircraft hangar designed in 1939, intended for aircraft maintenance on operational stations. It includes side annexes for workshops and offices, provided with a large number of windows. The annexes are of brick or concrete.</skos:scopeNote>
