    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123478"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:scopeNote xml:lang="en">A building used as the headquarters for the Home Guard during the Second World War.</skos:scopeNote>
  </rdf:Description>
