    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123366"/>
    <skos:scopeNote xml:lang="en">A structure, often concrete or brick, used as a shelter by members of the British citizen army during watch or patrol duties, or air raids, in wartime.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/123478</dcterms:identifier>
