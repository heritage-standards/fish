    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135671"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/135512">
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/131173"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Watch Office (12779/41)</skos:prefLabel>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A two-storey, structure with a brick ground floor and a reinforced concrete upper floor with balcony and large windows to the watch office and control room. This became the most common building design for air traffic control in the Second World War.</skos:scopeNote>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/135512</dcterms:identifier>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123440">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:prefLabel xml:lang="en">Dannert Wire</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Barbed wire in the form of a coil which could be extended concertina-like to form a barrier to impede the movement of hostile troops.</skos:scopeNote>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123427"/>
