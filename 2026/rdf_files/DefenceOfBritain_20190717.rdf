    <skos:altLabel xml:lang="en">Resistance Hideout</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:prefLabel xml:lang="en">Auxiliary Unit Operational Base</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A well concealed structure, usually constructed undergound, intended for use by members of the British Resistance Organization in the event of invasion.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
