    <skos:altLabel xml:lang="en">Watch Office With Meteorological Section (2423/39)</skos:altLabel>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Watch Office With Met Section (2423/39)</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/143572</dcterms:identifier>
