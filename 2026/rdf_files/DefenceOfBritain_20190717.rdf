    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <skos:prefLabel xml:lang="en">Decoy Airfield</skos:prefLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/123411"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/140674</dcterms:identifier>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">A system of lights, controlled fires or dummy constructions, used to simulate an airfield and thus confuse enemy aircraft into bombing these counterfeit targets.</skos:scopeNote>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/123526">
    <skos:prefLabel xml:lang="en">Pimple</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <skos:scopeNote xml:lang="en">Blocks of solid concrete,in the form of truncated pyramids usually 3 feet square x 2 feet high which could be placed in rows to impede enemy movement in the event of invasion. Pimples were recommended for use on soft ground.</skos:scopeNote>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/365"/>
    <skos:altLabel xml:lang="en">Sharks Teeth</skos:altLabel>
