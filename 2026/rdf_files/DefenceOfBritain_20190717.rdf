  <rdf:Description rdf:about="http://purl.org/heritagedata/schemes/365/concepts/143571">
    <skos:scopeNote xml:lang="en">Based on the previous all-timber design 2423/39 and the temporary brick and timber design 518/40, the 8936/40 was built with pre-cast concrete slabs replacing the timber floors and staircases with only the balcony and watch office roof in timber.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-17T10:53:31</dcterms:issued>
    <skos:altLabel xml:lang="en">Watch Office With Meteorological Section (8936/40)</skos:altLabel>
    <skos:prefLabel xml:lang="en">Watch Office With Met Section (8936/40)</skos:prefLabel>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/365/concepts/143571</dcterms:identifier>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/365/concepts/135489"/>
