        <skos:prefLabel xml:lang="en">Oak</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A native hardwood of the Beech family with hard and durable characteristics which traditionally made it appropriate for structural work.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

