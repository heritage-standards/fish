        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Gritstone (Limestone)</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Specific English quarryman's term for any limestone abundant in shell fragments. Use this term with care. When only Gritstone is mentioned, unless otherwise specified, assume it to be Gritstone (Sandstone), since this is the most common usage.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

