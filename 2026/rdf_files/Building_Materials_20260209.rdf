    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Daub</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98018"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98276"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98110"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98026"/>
    <skos:scopeNote xml:lang="en">Application of earth based plaster to a backing of lath or wattle used in internal or external walls. Composite mixture which may include clay soil, dung, straw, lime putty, sand or horsehair.</skos:scopeNote>
  </skos:Concept>

