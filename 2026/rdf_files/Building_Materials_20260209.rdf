    <skos:altLabel xml:lang="en">Walling Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Yeovil Marble</skos:altLabel>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97956">
