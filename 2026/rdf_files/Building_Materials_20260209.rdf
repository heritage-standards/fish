        <skos:scopeNote xml:lang="en">Cornish miner's term for slates formed during the Carboniferous and Devonian periods.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98013"/>
