    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pargeting</skos:prefLabel>
    <skos:scopeNote xml:lang="en">External decorative plasterwork often incised or modelled with ornamental patterns. Usually applied to timber-framed houses, especially during 16th and 17th centuries.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98087">
    <skos:altLabel xml:lang="en">Peat Brick</skos:altLabel>
