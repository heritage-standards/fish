    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97944"/>
    <skos:scopeNote xml:lang="en">Miner's term for fine grained, often light grey/fawn coloured porphyritic rocks. Commonly found in Devon and Cornwall.</skos:scopeNote>
  </skos:Concept>

