    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Forest Stone (Leicestershire)</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98229"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/102688"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98194"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98179"/>
    <skos:scopeNote xml:lang="en">Collective name for a series of rocks (granite, syenite, porphry and slate) found in the Charnwood Forest of Leicestershire. Index with specific stone type where given.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97827">
    <skos:altLabel xml:lang="en">Clay Tile</skos:altLabel>
