        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Beer Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Coarse, hard Chalkstone, light grey to white coloured, containing shell fragments.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97833">
        <skos:altLabel xml:lang="en">Burwell Stone</skos:altLabel>
        <skos:altLabel xml:lang="en">Totternhoe Stone</skos:altLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97814"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
