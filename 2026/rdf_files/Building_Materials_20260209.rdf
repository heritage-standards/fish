  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98184">
    <skos:altLabel xml:lang="en">Adamelite</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97944"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98184</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Shap Granite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Hard, coarse grained, grey to red/brown coloured granite. Used predominantly for tombstones becasuse of its ability to take a polish, but it is also in demand for underwater construction.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97940">
    <skos:altLabel xml:lang="en">Alps Grey Granite</skos:altLabel>
    <skos:altLabel xml:lang="en">Ematita Granite</skos:altLabel>
    <skos:altLabel xml:lang="en">Madreperla</skos:altLabel>
    <skos:altLabel xml:lang="en">Verde Ematita</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
