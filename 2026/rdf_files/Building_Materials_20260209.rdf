        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Anodized Aluminium</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Aluminium coated by a protective film of oxides created by electrolysis.</skos:scopeNote>
      </skos:Concept>
