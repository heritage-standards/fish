    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Devonian Limestone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Limestone formed during the Devonian period, and found predominantly between the Exe and Tamar rivers in Devon. Varying in colour from black/grey to pink/white it was often polished to imitate, and be used as, marble.</skos:scopeNote>
  </skos:Concept>

