        <skos:prefLabel xml:lang="en">Portland Cement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A form of cement originally named since it was said to be like Portland Stone in appearance.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
