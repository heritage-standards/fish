    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Bath Stone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Even grained, poorly fossiliferous, light brown/cream coloured, oolitic limestone. Quarried in the Bath area.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97717">
    <skos:altLabel xml:lang="en">Bradstone</skos:altLabel>
    <skos:altLabel xml:lang="en">Empire Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Imitation Stone</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97834">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97717"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97834</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Coade Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Durable artificial stone consisting of china clay, sand and finely ground stoneware cast from moulds and fired in a kiln. Commonly used for architectural ornament and facings.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98128">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97717"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98128</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Pulhamite Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A patented manmade rock invented by James Pulham and Son of Broxbourne. Pulhamite was used to join natural rocks together or crafted to simulate natural stone features. It is an artificial form of sandstone.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

