    <skos:prefLabel xml:lang="en">Aluminium</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Lightweight, strong metal with good corrosive resistance, normally used as an alloy.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97992">
    <skos:altLabel xml:lang="en">Corrugated Iron</skos:altLabel>
