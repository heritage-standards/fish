        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Polyvinyl Chloride</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A type of thermoplastic polymer which is versatile and cheap, often referred to as PVC. This includes plasticized PVC and unplasticized PVC (uPVC).</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
