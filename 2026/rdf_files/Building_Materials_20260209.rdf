        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Majolica</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fine earthenware with raised patterns of coloured decoration in the form of an enamel or coloured opaque glaze. Use for decorative wall facings.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98235"/>
