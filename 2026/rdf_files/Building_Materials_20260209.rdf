    <skos:altLabel xml:lang="en">Elterwater Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Kirkstone Green</skos:altLabel>
    <skos:altLabel xml:lang="en">Lakeland Green</skos:altLabel>
    <skos:altLabel xml:lang="en">Moss Rigg Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Skiddaw Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Spoutcrag</skos:altLabel>
    <skos:altLabel xml:lang="en">Westmoorland Green</skos:altLabel>
    <skos:altLabel xml:lang="en">Westmoorland Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Greenslate</skos:altLabel>
