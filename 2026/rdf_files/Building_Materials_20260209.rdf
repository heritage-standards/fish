    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tertiary Limestone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Hard, fossil rich, white to deep red coloured limestone, laid down during the Tertiary period. Used since Roman times because of its good durability and weathering properties.</skos:scopeNote>
  </skos:Concept>

