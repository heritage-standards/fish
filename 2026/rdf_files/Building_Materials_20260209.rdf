    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98026"/>
    <skos:scopeNote xml:lang="en">Lime plaster, consisting of lime and sand, is the oldest type of render. Applied externally to walls or onto laths for infill panels and usually limewashed.</skos:scopeNote>
  </skos:Concept>

