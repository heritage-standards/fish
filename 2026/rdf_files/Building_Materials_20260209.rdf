    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Earth Mix</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Unbaked clays and/or soil material often mixed with, or performing the function of an aggregate or binder. See EARTH MIX Class List for narrow terms.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97836">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
