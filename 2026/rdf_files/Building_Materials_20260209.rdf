    <skos:prefLabel xml:lang="en">Plastic</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98164"/>
    <skos:scopeNote xml:lang="en">Any of large class of polymers based on synthetic resins or modified natural polymers which may be moulded, extruded or cast while soft or liquid, which then set rigidly or slightly elastic in form.</skos:scopeNote>
  </skos:Concept>

