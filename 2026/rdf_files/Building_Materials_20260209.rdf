    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Purbeck Stone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98044"/>
    <skos:scopeNote xml:lang="en">Collective name for the oolitic limestone quarried in the Isle of Purbeck region, geologically classified into two main groups. Firstly, a fine grained whitish variety, Purbeck Portland, secondly a fossil-rich cream/gold to grey variety, Swanage Stone etc</skos:scopeNote>
  </skos:Concept>

