    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Fossil</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98058"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:scopeNote xml:lang="en">The remains of living organisms preserved in stone over a long time period. This may be the internal or external moulds of, usually, the hard parts of an organism (shells, bones, etc.).</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98029">
    <skos:altLabel xml:lang="en">Ancaster Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Barnack Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Casterton Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Clipsham Stone</skos:altLabel>
