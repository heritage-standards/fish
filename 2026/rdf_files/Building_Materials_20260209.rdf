    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:scopeNote xml:lang="en">Naturally occurring glacial rock fragments (diameter 64-256mm) larger than pebble and smaller than boulder.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97844">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98044"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
