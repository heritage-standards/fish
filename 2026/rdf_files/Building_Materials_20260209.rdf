    <skos:altLabel xml:lang="en">Barge Quartzite</skos:altLabel>
    <skos:altLabel xml:lang="en">Italian Quartzite</skos:altLabel>
    <skos:altLabel xml:lang="en">Otta Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Pillaguri Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Rembrandt Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Sanfront Stone</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98175</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Schist</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Medium to coarse grained metamorphic rock, colour being determined by its dominant mineral. Often used for floor and wall cladding.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97814">
    <skos:altLabel xml:lang="en">Amberley Stone</skos:altLabel>
