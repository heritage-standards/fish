        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Hornblende</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Medium hard, green/black coloured. Found in many igneous and metamorphic rocks.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

