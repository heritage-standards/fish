    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Lake District Slate</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98183"/>
    <skos:scopeNote xml:lang="en">Collective term for the Burlington (Silurian period) and Borrowdale (Ordovician period) groups of slates from the Lake District and parts of Cumbria, Lancashire. Hard, fine grained metamorphic rock, varying in colour from green/olive to black/blue black.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97737">
