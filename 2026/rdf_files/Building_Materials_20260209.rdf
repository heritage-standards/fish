    <skos:altLabel xml:lang="en">Granolithic Concrete</skos:altLabel>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97776"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98025">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97840"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
