    <skos:prefLabel xml:lang="en">Terracotta</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:scopeNote xml:lang="en">Hard, unglazed, brown, versatile earthenware which can be used as a tile or moulded into statuary. Used in a structural or semi-structural context as a moulded hollow block.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98181">
