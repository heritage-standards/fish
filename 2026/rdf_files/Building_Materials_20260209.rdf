        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Tar</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Thick, viscid liquid, obtained by the distillation of wood, coal or other organic substances, chemically a mixture of hydrocarbons with resins.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98232">
