        <skos:prefLabel xml:lang="en">Feldspar</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, often coloured, can be transparent. Found on its own as crystals and veins but also as a major constituent of all three geological rock types.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97923"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97980">
