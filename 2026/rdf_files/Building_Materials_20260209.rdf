    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Jurassic Limestone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Limestone formed during the Jurassic period. Provides many widely used building stones.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98287">
