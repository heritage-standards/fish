    <skos:altLabel xml:lang="en">Bradford Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Combe Down Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Corsham Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Hartham Park Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Hazlebury Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Monks Park Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">St Aldhelm Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Stoke Ground Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Westwood Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Winsley Ground</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98075"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
