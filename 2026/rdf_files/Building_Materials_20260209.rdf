    <skos:prefLabel xml:lang="en">Cotswold Stone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Sandy, light brown (cream to golden) coloured limestone, easily worked and readily available.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97999">
    <skos:altLabel xml:lang="en">Bletchingdon Marble</skos:altLabel>
