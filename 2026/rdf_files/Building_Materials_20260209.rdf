    <skos:prefLabel xml:lang="en">Bungaroosh</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Composed of a wide variety of substances and materials such as whole or broken bricks, cobblestones, flints, pebbles and sand which are set into hydraulic lime. Used most often to form external walls and is commonly found in the Brighton/Lewes region.</skos:scopeNote>
  </skos:Concept>

