        <skos:prefLabel xml:lang="en">Cast Iron</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Dating from the 15th century, it is a hard alloy of iron and carbon, melted and shaped into various moulded forms.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98305">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97992"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
