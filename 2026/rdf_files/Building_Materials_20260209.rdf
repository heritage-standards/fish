    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:scopeNote xml:lang="en">Designating or pertaining to hard, brittle substances produced by strong heating of clay.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97827"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97828">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97828</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Clay Lump</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Large, moulded, unburnt blocks of clay type soil laid in a similar way to brick, but bedded in lime and clay 'mortar'. The walls produced are characteristically thinner than those of cob and pise.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97835"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97873"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97902"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98069">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98069</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Mud</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Wet soil, sand or other earthy matter combined with ballast and bonded with straw or other binding material. Walls are built in the absence of shuttering by the simple process of pitching in layers.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98107"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98170"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/140229">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/140229</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Marl</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A mixed earthy substance consisting principally of clay mixed with calcium carbonate and sand in very variable proportions.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/142988">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
