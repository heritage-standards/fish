    <skos:prefLabel xml:lang="en">Carrara Marble</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Imported Italian marble varying in colour from green, blue, purple to white.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97716">
    <skos:altLabel xml:lang="en">Asbestos Slate</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97716</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Artificial Slate</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A rectangular sheet of roofing material created by a man made process (eg. asbestos cement slate) and made to look like, and used in the same way as, natural slate.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97719">
    <skos:altLabel xml:lang="en">Asbestos Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Corrugated Asbestos</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97719</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Asbestos</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A mineral crystal of thin, tough fibres which can be woven. Used for high temperature insulation or as reinforcement in asbestos cement building board and corrugated roofing. If used to imitate slate, use artificial slate also.</skos:scopeNote>
  </skos:Concept>

