    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Portland Stone</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Fine to coarse grained, cream to green/grey coloured oolitic limestone. Quarried since Roman times, it is one of Britain's best building stones, hence its use throughout the country.</skos:scopeNote>
  </skos:Concept>

