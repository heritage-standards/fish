    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98170"/>
    <skos:scopeNote xml:lang="en">A mixture of lime or more recently cement with sand and water used for bonding stones or bricks.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98194">
