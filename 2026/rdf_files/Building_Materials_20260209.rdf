    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97774"/>
    <skos:scopeNote xml:lang="en">Sedimentary rock consisting of rounded pebbles naturally cemented together.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98028">
