        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Polycarbonate</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Very tough transparent sheeting often used for security glazing.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98119">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98111"/>
