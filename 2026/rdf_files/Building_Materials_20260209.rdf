        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Seaweed</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Multicellular marine alga, which grows on the seashore, in salt marshes, in brackish water or submerged in the ocean.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/140464">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98109"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/140464</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Grass</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Ground-covering herbage, some varieties of which can be used, especially when dried and in large quantities, as a construction material.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98265"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98109</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Plant</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any tree, shrub or herb of cellulose form, normally subsisting in soil and producing its food through photosynthesis.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97947">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97947</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Gravel</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98170"/>
    <skos:scopeNote xml:lang="en">Grains of rock fragment larger than coarse sand and finer than pebbles (diameter 2-4mm).</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97952">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97952</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Greenstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97734"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97891"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97944"/>
    <skos:scopeNote xml:lang="en">Geologist's term for any dark coloured, slightly metamorphosed igneous rock. Index with specific stone type where given.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97974">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98109"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97974</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Heather</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98239"/>
    <skos:scopeNote xml:lang="en">A dwarf shrub of the heath family used as an alternative to straw as a roof covering in moorland regions. Cut while in bloom and laid with the roots carefully entwined. The covering turns a characteristic black colour with age.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98018">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98242"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98018</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Lath</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97873"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98110"/>
    <skos:scopeNote xml:lang="en">Narrow strips of wood which can form the groundwork for slates, panels or plaster work.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98022">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98053"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/143234">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98022"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/143234</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Sheet Lead</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Lead which has been rolled into a sheet and often used as a roof covering.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98022</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Lead</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Metal used primarily for roof coverings and window fittings. It is easy to work, can be worked cold and does not rust which makes it suitable for holding or repelling water.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98031">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98219"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98031</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Long Straw</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98239"/>
    <skos:scopeNote xml:lang="en">Composed of loose uncombed lengths of harvested wheat which are formed into bundles for laying. Distinctive appearance with both ears and butts visible on the surface traditionally using hazel spars which hold the straw in place.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98219">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98031"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/139757">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98219"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/139757</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Combed Wheat Reed</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A form of thatching straw composed of stems that have been combed mechanically to remove grain and extraneous waste material without crushing the stem.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98109"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98219</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Straw</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98239"/>
    <skos:scopeNote xml:lang="en">Roofing material consisting of stems or stalks of wheat, rye, oats or barley separated from grain and laid flat in 'yealms' which form an overlapping surface which sheds water.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98047">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98047</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Mathematical Tile</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97777"/>
    <skos:scopeNote xml:lang="en">Tile nailed externally to a wall and usually laid in mortar designed to present a brick-like appearance.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98061">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97944"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98061</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Moorstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98173"/>
    <skos:scopeNote xml:lang="en">Stonemason's name for granite found lying upon the moorland surface, as opposed to having been quarried, in the West Country and the Lake District. Used, as found, since prehistoric times, in later years was often dressed and shaped.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98081">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98081</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pantile</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97827"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97840"/>
    <skos:scopeNote xml:lang="en">Curved, interlocking roof tile of S-shaped section usually made of clay or concrete.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98082">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98082</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Paper</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98301"/>
    <skos:scopeNote xml:lang="en">Thin flexible sheets made from the pulp of wood or other fibrous matter.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98265">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98087"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98109"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98262"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98265</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Vegetal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Pertaining to or deriving from a botanical living organism. See VEGETAL Class List for narrow terms.</skos:scopeNote>
    <skos:topConceptOf rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98089">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98089</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pebble</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98090"/>
    <skos:scopeNote xml:lang="en">Rock fragment (diameter 4-64mm) larger than gravel and smaller than cobble, combined with other material e.g. flint, for decorative effect.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98090">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98147"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98090</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Pebbledash</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98089"/>
    <skos:scopeNote xml:lang="en">A render with small washed stones added as aggregate. Popular in the early 20th century.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98116">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98080"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98116</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Plywood</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98301"/>
    <skos:scopeNote xml:lang="en">Thin layers of wood, bonded together to form a structural board. The grain of the adjacent layers lie across one another to give structural strength. Produced since mid 19th century for use in interior joinery, since 1930's for exterior use.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98118">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98118</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Polyphant</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98044"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98181"/>
    <skos:scopeNote xml:lang="en">Compact, grey/green/brown/white-speckled coloured igneous rock, peculiar to Cornwall. It is easy to carve and readily takes a polish, hence its similarity to British marbles.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98126">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97843"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/164108"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98126</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Puddingstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97774"/>
    <skos:scopeNote xml:lang="en">Conglomerate consisting of rounded flint pebbles held together in a natural silica and sand cement.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98133">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98058"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98133</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Quartz</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98134"/>
    <skos:scopeNote xml:lang="en">Hard, transparent, often coloured mineral. Can be found on its own as crystals and veins but also as a major constituent of rocks such as granite. Often used decoratively.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98145">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97840"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98145</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Reinforced Concrete</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98213"/>
    <skos:scopeNote xml:lang="en">Aggregate, cement and mortar combined with structural elements of iron or steel mesh or rod reinforcement to form stonelike masses for load bearing, structural building work.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98150">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98150</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Rhyolite</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97734"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97891"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98229"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98181"/>
    <skos:scopeNote xml:lang="en">Fine grained, acidic, light-grey/white/ brown/red-coloured igneous rock.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98156">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97810"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98156</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Roman Cement</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98026"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98180"/>
    <skos:scopeNote xml:lang="en">Technically a quick setting hydraulic cement or lime,but term has been adapted to denote cement made from burning lumps of marl found in London clay,a technique adopted for C19th building work. Name not intended to denote a relationship with Roman period</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98164">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98164</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Rubber</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98111"/>
    <skos:scopeNote xml:lang="en">Flexible, synthetic, polymeric organic material formed by chemical synthesis usually in imitation of a natural substance. It can be moulded to shape, extruded or formed into a sheet from solid or foam material.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98165">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98165</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Rubble</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:scopeNote xml:lang="en">Rough, unhewn, undressed building stones with irregular faces, generally not laid in regular courses. Index with type of stone if specified.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98170">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97903"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98170</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Sand</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97809"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97840"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97947"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98062"/>
    <skos:scopeNote xml:lang="en">Granular material consisting of small eroded fragments of rock or mineral grains, finer than gravel used as an ingredient in mortar and other traditional building materials.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98180">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97843"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98180</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Septaria</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98045"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98156"/>
    <skos:scopeNote xml:lang="en">Conglomerate consisting of nodules of calcium rich clay (marl). Used as a building stone from Roman times and as a key ingredient in Parker's Roman Cement, between 1796 and circa 1850.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98186">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98242"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98186</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Shingle</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98242"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98241"/>
    <skos:scopeNote xml:lang="en">Wooden roof tile (traditionally oak) which is riven or sawn from good quality timber to a regular size and used as a roof and/or wall covering. Index with type of wood if known.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98188">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98188</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Siltstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98183"/>
    <skos:scopeNote xml:lang="en">Fine grained, yellow/buff to grey/black coloured sedimentary rock.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98195">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97810"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98195</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Slurry</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97809"/>
    <skos:scopeNote xml:lang="en">Cement/water mix often used as covering. Use this for entries including slurrying and slurried.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98239">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98046"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98239</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Thatch</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97943"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97974"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98031"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98143"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98219"/>
    <skos:scopeNote xml:lang="en">Traditional roof covering consisting of materials such as reed, straw or heather layered and fastened together onto roof to form a run off to prevent water penetration.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98243">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98053"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98243</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Tin</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97779"/>
    <skos:scopeNote xml:lang="en">Malleable metal used for roofing and for alloys such as bronze.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98262">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98265"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98262</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Turf</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97902"/>
    <skos:scopeNote xml:lang="en">Layer of grass with earth and matted roots cut from the ground and used for earth buildings and as a covering material.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98276">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98242"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98276</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Wattle</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97873"/>
    <skos:scopeNote xml:lang="en">Wooden rods or stakes which can be interlaced with twigs or branches to make walls or fences, or more commonly, to form the basis of panels in traditional timber framed buildings which are then covered with daub.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98282">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98242"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98282</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Weatherboard</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98301"/>
    <skos:scopeNote xml:lang="en">Length of timber boarding (usually elm, now pine) fixed horizontally or vertically to the exterior of a structure which may be 'tongue and grooved' or 'feathered' to provide external protection.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98293">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98216"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98293</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Whinstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97734"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97891"/>
    <skos:scopeNote xml:lang="en">Northern quarryman's name for any fine grained, dark grey/black to green coloured igneous rock. Index with specific stone type where given.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98303">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98080"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98303</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Woodwool Slab</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97809"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98301"/>
    <skos:scopeNote xml:lang="en">A sheet or board made from a mixture of thin strips of wood and cement which are bound together through compression within a mould. Woodwool slabs are used for roof or wall cladding, providing fire resistance, and heat and sound insulation.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/164108">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98126"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/164108</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Hertfordshire Puddingstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97774"/>
    <skos:scopeNote xml:lang="en">A conglomerate rock comprising well rounded flint pebbles in a very hard matrix of fine pale coloured sand, bound together by hard natural silica cement. The pebbles are usually coloured ochre or red and have black rims.</skos:scopeNote>
  </skos:Concept>

