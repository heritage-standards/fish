    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98044"/>
    <skos:scopeNote xml:lang="en">Composite substance of plaster formed by gypsum, sand and lime and coloured with pigments, fixed under heat and highly polished. Used to imitate marble and popular in the 17th and 18th centuries for architectural features.</skos:scopeNote>
  </skos:Concept>

