        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Lightweight Concrete</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A concrete which is either aerated or made from lightweight aggregate.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98124">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97840"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
