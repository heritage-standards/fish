    <skos:prefLabel xml:lang="en">Bakelite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">An early thermosetting plastic commonly used for its properties of electrical insulation.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98111">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97726"/>
