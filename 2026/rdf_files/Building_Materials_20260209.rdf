    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Sandstone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97800"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97993"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98024"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98183"/>
    <skos:scopeNote xml:lang="en">Geologically sandstone consists of particles of quartz naturally cemented together by either silica, calcium or iron. It is this geological composition that accounts for the varying colours and grain sizes found in the many building sandstones.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98179">
    <skos:altLabel xml:lang="en">Ballachulish Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Scotch Slate</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98194"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98179</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Scottish Slate</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97928"/>
    <skos:scopeNote xml:lang="en">Collective term for the Scottish Slates including the Aberdeen/Baniff and Ballachulish/Easdale groups. Fine grained, varying in colour from brown to dark grey/blue. Geologically different from Lake District, Welsh and West Country groups of slate.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97702">
