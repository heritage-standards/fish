    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Earth</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98087"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98262"/>
    <skos:scopeNote xml:lang="en">Combination of organic and inorganic material cohered to form a hard solid wall or covering. Use for structures created by the excavation and piling up of earth, such as ice houses. Earth may be used in combination with other materials.</skos:scopeNote>
  </skos:Concept>

