    <skos:altLabel xml:lang="en">Delabole Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Devon Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Mill Hill Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Tintagel Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Trebarwith Rustic Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Trecarne Rustic Slate</skos:altLabel>
    <skos:altLabel xml:lang="en">Tredinnick Rustic Slate</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98194"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98287</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">West Country Slate</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98183"/>
    <skos:scopeNote xml:lang="en">Collective term for the slates from Devon and Cornwall. Hard, fine grained metamorphic rock. Varying in colour from dark grey/green to blueish/grey. West Country Slate is geologically different from both Lake District and Welsh Slate.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98223">
    <skos:altLabel xml:lang="en">Bognor Rock</skos:altLabel>
    <skos:altLabel xml:lang="en">Calverley Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Midhurst Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Pulborough Stone</skos:altLabel>
    <skos:altLabel xml:lang="en">Tunbridge Wells Stone</skos:altLabel>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97984">
        <skos:altLabel xml:lang="en">Horsham Slab</skos:altLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98223"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/97984</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Horsham Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, fissile sandstone which weathers to a dark brown colour. Mainly used as a stone roofing material (stone slate) throughout Sussex and Surrey.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98280">
        <skos:altLabel xml:lang="en">Weald Stone</skos:altLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98223"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98280</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
        <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
        <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Wealden Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fine grained, brown/yellow to dark grey coloured cretaceous sandstone. It is a particularly good freestone and was often used for ashlar finishes.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98171"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/eh_tbm/concepts/98223</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-02-09T14:11:02</dc:issued>
    <cc:license rdf:resource="https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/"/>
    <cc:attributionURL rdf:resource="https://historicengland.org.uk/"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
    <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Sussex Stone</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97866"/>
    <skos:scopeNote xml:lang="en">Fine grained, buff, brown to green coloured Cretaceous sandstone. Quarried at various locations in Sussex. Not to be confused with Sussex marble which is a cretaceous limestone.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98013">
