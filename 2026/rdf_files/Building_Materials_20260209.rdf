    <skos:scopeNote xml:lang="en">A binder combined with various aggregates which sets and holds together into a mass which then hardens and gains strength.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97813">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98041"/>
