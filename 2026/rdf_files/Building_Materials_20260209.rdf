        <dc:publisher rdf:resource="https://historicengland.org.uk/"/>
        <dc:spatial rdf:resource="http://vocab.getty.edu/tgn/7002445"/>
        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Tufaceous Limestone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Very light, depositional limestone formed by the precipitation of calcium carbonate rich water (Tufa). The more dense and compact form, Travertine, is formed in a similar way.</skos:scopeNote>
      </skos:Concept>
