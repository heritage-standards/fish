    <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
    <skos:prefLabel xml:lang="en">Aberdeen Granite</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Medium grained, dark bluish-grey stone. Quarried mainly from the Rubislaw Quarry.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98123">
