        <dc:spatial rdf:resource="http://dbpedia.org/resource/England"/>
        <skos:prefLabel xml:lang="en">Pennant Stone</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard, fine grained, blue/grey coloured sandstone. Quarried in South Wales and the Bristol area and commonly used, throughout the country, as a stone roofing material (stone slate).</skos:scopeNote>
      </skos:Concept>
