  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tbm/concepts/98058">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tbm/concepts/97892"/>
