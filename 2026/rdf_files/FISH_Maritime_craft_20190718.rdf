  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100496">
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">A floating pier, comprised of a floating pierhead (SPUD) and a roadway resting on pontoons (BEETLES). The pierhead and roadway were capable of rising and falling with the tide enabling unloading of troops and equipment to occur at any state of the tide.</skos:scopeNote>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:broader>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100409">
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100409</dcterms:identifier>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100394"/>
        <skos:prefLabel xml:lang="en">Mulberry Harbour</skos:prefLabel>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/170095"/>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/131953"/>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/131955"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
        <skos:scopeNote xml:lang="en">An artificial harbour, constructed using prefabricated, concrete caissons, floating breakwaters and blockships, which were towed across the channel and assembled off the coast of Normandy to assist the allied forces after the D-Day landings in June 1944.</skos:scopeNote>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100496"/>
      </skos:Concept>
    </skos:broader>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/146361">
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">Concrete or steel pontoons that supported the Whale piers. They were moored in position using wires attsched to Kite anchors.</skos:scopeNote>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/146361</dcterms:identifier>
