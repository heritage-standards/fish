    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100443"/>
    <skos:scopeNote xml:lang="en">A Dutch barge-like sailing vessel whose shallow draught enables it to navigate in shallow water not accessible by other vessels. Used for fishing or carriage of cargo in the 19th century this type of vessel was adapted for use as a type of leisure craft.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
