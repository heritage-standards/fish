        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100384"/>
        <skos:prefLabel xml:lang="en">Rescue Vessel</skos:prefLabel>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">A specially equipped ship designed to care for survivors of stricken vessels and offshore drilling platforms. These ships were often converted naval trawlers or minesweepers.</skos:scopeNote>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
