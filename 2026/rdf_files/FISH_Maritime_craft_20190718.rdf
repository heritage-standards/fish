        <skos:related rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/138609"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">From 1822, any vessel in the service of HM Coastguard, principally deployed on Customs and Revenue duties, i.e. anti-smuggling operations. Superseded the Preventive Service Vessel.</skos:scopeNote>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/145105"/>
