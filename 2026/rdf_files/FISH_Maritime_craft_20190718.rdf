    <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100372</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Warships constructed of iron plate or with wooden hulls covered by iron plates. Used as a generic name for the first examples of armour plated warships.</skos:scopeNote>
