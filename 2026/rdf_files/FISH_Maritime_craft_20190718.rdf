    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100445">
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100445</dcterms:identifier>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100446"/>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100485"/>
        <skos:scopeNote xml:lang="en">A small and powerful vessel used to assist vessels that are sinking or disabled at sea.</skos:scopeNote>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:prefLabel xml:lang="en">Salvage Tug</skos:prefLabel>
