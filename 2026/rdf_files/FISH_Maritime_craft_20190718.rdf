        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <skos:scopeNote xml:lang="en">A small clinker-built craft, dating primarily from the 19th and early 20th centuries, fitted with oars and often a sail, usually found on the north-east coast of England and used for fishing or pilotage.</skos:scopeNote>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/139332</dcterms:identifier>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
