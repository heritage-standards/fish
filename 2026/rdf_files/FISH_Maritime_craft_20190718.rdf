        <skos:prefLabel xml:lang="en">Dredger</skos:prefLabel>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100286"/>
        <skos:scopeNote xml:lang="en">A craft used to deepen shipping channels, harbours and other water courses.</skos:scopeNote>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
