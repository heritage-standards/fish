        <skos:scopeNote xml:lang="en">A vessel used to put down and pick up moorings on the sea bed for large vessels.</skos:scopeNote>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
