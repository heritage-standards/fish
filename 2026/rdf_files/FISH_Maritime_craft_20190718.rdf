    <skos:prefLabel xml:lang="en">Hydrofoil</skos:prefLabel>
    <skos:scopeNote xml:lang="en">High speed craft developed in the 20th Century which employ a wing-like structure mounted on struts below the hull which lift the vessel above the water line during forward motion, reducing drag and increasing speed.</skos:scopeNote>
  </skos:Concept>
