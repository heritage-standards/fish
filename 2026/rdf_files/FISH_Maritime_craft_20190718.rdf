    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">Privateer operating under government licence to act against enemy merchant shipping. The term is closely associated with North African privateers which operated off the Barbary coast prior to the mid-1800's.</skos:scopeNote>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
