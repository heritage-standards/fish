        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">A relatively small and heavily built vessel equipped with large engines. Used for towing ships at sea or manouevring them in tight spaces.</skos:scopeNote>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100445"/>
