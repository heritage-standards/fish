        <skos:scopeNote xml:lang="en">A small vessel used as transport for customs officers.</skos:scopeNote>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/145105"/>
