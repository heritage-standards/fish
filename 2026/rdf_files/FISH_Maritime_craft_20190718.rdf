    <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100385</dcterms:identifier>
    <skos:scopeNote xml:lang="en">Large warship with no armour and a high speed. Used for reconnaisance and raids on enemy merchant shipping.</skos:scopeNote>
    <skos:broader>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100311">
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
        <skos:prefLabel xml:lang="en">Cruiser</skos:prefLabel>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100311</dcterms:identifier>
        <skos:altLabel xml:lang="en">Second Class Cruiser</skos:altLabel>
        <skos:scopeNote xml:lang="en">Large warship equipped with turret mounted guns. Intended for independent action for trade protection, reconaissance and fire support for amphibious operations.</skos:scopeNote>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100385"/>
