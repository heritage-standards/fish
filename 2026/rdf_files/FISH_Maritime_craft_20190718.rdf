    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
    <skos:scopeNote xml:lang="en">Generic name for a vessel used for work rather than for recreation, transportation, or military purposes. The vessels include tugs, barges, landing craft, dredgers and standby safety vessels. Use only were the exact type of vessel is unknown.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
