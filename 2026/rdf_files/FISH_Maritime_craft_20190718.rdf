    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
    <skos:scopeNote xml:lang="en">Prior to 1822 a vessel used by the customs department involved with the prevention of smuggling.</skos:scopeNote>
    <skos:related>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/145104">
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
