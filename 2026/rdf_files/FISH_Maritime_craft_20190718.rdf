        <skos:scopeNote xml:lang="en">A warship constructed of iron plate with its main armament mounted in a revolving turret on deck.</skos:scopeNote>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
