        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:scopeNote xml:lang="en">Unpowered flat bottomed vessel, used for carrying cargo from ship to shore or as a working platform.</skos:scopeNote>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Lighter</skos:prefLabel>
