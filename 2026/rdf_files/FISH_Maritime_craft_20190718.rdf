  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/140562">
    <skos:prefLabel xml:lang="en">Foyboat</skos:prefLabel>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
    <skos:scopeNote xml:lang="en">Small, heavily built coble, usually fitted with lugsail and oars, used on the north-east coast of England to assist, tow, pilot, provision or otherwise attend ships.</skos:scopeNote>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <skos:broader>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/139332">
