        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2019-07-18T10:47:53</dcterms:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/145105</dcterms:identifier>
        <skos:scopeNote xml:lang="en">Any vessel in the service of one of the historical or modern agencies concerned with the prevention of inbound or outbound smuggling: namely the Preventive Service, the Coastguard, or the Customs and Excise. Use more specific term.</skos:scopeNote>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc/concepts/138609"/>
      </skos:Concept>
    </skos:broader>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/138609</dcterms:identifier>
    <skos:related>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/eh_tmc/concepts/100312">
        <dcterms:identifier>http://purl.org/heritagedata/schemes/eh_tmc/concepts/100312</dcterms:identifier>
