        <skos:prefLabel xml:lang="en">Customs Boat</skos:prefLabel>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/eh_tmc"/>
      </skos:Concept>
    </skos:related>
    <skos:altLabel xml:lang="en">Preventative Service Vessel</skos:altLabel>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
