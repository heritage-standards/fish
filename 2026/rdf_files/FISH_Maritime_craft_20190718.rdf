        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">A small warship with a shallow draught. Used for patrol duties and shore bombardment on major rivers.</skos:scopeNote>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
