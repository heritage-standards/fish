        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
      </skos:Concept>
    </skos:broader>
    <skos:scopeNote xml:lang="en">A rescue tug equipped to care for survivors from torpedoed vessels and also available for towing to port ships damaged by enemy action.</skos:scopeNote>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
