	<rdf:Description rdf:about="http://purl.org/heritagedata/schemes/145/concepts/106922">
		<skos:scopeNote xml:lang="en">The land mass comprising, the continents of North and Central America and South America. Use more specific type.</skos:scopeNote>
	</rdf:Description>
	<rdf:Description rdf:about="http://purl.org/heritagedata/schemes/145/concepts/106960">
		<skos:scopeNote xml:lang="en">Bordering the continents of Africa, Antarctica, Europe, North and South America the Atlantic is the second largest of the oceans, covering 31,736,000 square miles.</skos:scopeNote>
	</rdf:Description>
	<rdf:Description rdf:about="http://purl.org/heritagedata/schemes/145/concepts/106961">
		<skos:scopeNote xml:lang="en">Bordering the five continents of Antarctica, Asia, Australasia, North and South America, the Pacific is the largest of the world's oceans, and covers more area (63,838,000 square miles) than that of the combined seven continents.</skos:scopeNote>
	</rdf:Description>
