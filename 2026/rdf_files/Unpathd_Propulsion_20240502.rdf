    <skos:prefLabel xml:lang="en">Pole</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A means of propelling a craft using a long pole, pushed against the bed of a watercourse or body of water.  Primarily used in inland waters by craft such as logboats and punts.</skos:scopeNote>
