    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Gemstones</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141334"/>
    <skos:scopeNote xml:lang="en">Cut or uncut stones, usually intended to be set into jewellery, and including precious gems, e.g. diamonds, sapphires, or semi-precious materials, e.g. quartz, agate, amber.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/142049">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79134"/>
