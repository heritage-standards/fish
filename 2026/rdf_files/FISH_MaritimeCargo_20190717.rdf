    <skos:scopeNote xml:lang="en">Large mammals, domesticated for riding and as draught animals.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78892">
