        <skos:prefLabel xml:lang="en">Copperas</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Sulphates, used in medicine and to colour inks.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

