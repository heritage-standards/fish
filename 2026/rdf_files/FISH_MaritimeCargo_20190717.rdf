        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Roofing Shingles</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Thin, rectangular tiles, usually made of wood, used for roofing.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79208">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78964"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79208</dc:identifier>
