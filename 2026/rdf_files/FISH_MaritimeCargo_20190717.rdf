    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Vehicles</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Transportation, usually wheeled or tracked, used for the conveyance of goods or people.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/159171">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79089"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
