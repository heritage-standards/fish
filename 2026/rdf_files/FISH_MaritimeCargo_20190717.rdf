    <skos:prefLabel xml:lang="en">Rolling Stock</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Carriages, locomotives and other vehicles used on a railway.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84476">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78937"/>
