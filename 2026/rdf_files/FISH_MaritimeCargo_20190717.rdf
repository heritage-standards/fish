    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Shellfish</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Aquatic invertebrate animals whose outer covering is a shell, often 'farmed' to be eaten. Includes molluscs and crustaceans.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79143">
