        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Tar</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A thick, viscous, black liquid obtained by the destructive distillation of coal or other organic substances used for preserving wood or rope and for covering road surfaces.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79133">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79106"/>
