    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/84057"/>
    <skos:scopeNote xml:lang="en">The hard material, consisting mainly of calcium compounds, which makes up the skeleton of vertebrates. Used for ornaments or ground for use in the manufacture of bone china.</skos:scopeNote>
  </skos:Concept>

