    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Biscuit</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Traditionally, pieces of unleavened cake or bread usually small in size and dry, crisp and hard.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79009">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78912"/>
