        <skos:prefLabel xml:lang="en">Cast Iron</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A metallic alloy of iron, carbon and silicon formed by casting in a mould.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79049">
