        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Ginger</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The stem of the plant Zingiber officinale, with a characterisitc hot and peppery taste, used in cookery and medicine.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/143973">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79191"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
