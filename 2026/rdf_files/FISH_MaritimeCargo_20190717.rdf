    <skos:prefLabel xml:lang="en">Flint</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Stone consisting of nearly pure silica, which can be used as a building material or knapped to produce flint objects.</skos:scopeNote>
  </skos:Concept>

