    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Slaves</skos:prefLabel>
    <skos:scopeNote xml:lang="en">People who are considered to be the property of someone else and who are bound to obedience.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79123">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79183"/>
