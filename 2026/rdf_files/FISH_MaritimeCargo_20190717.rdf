    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Sculpture</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Three-dimensional artwork usually created out of stone, e.g. marble; metal, e.g. bronze; ceramics, e.g. terracotta, or other suitable materials.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141503">
