        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Chocolate</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Paste or cake of the fruit of the cacao-tree, sweetened with other substances and used to make beverages or confectionery.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79010"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109193"/>
