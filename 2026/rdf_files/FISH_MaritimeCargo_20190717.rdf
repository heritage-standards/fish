        <skos:prefLabel xml:lang="en">Iron Ingots</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Solid bars made from pure iron.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/170077">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79046"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
