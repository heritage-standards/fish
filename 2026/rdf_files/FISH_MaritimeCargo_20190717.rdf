    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Cloth</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Woven or felted fabric used in the manufacture of garments, tablecloths, towels etc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78912">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79009"/>
