        <skos:prefLabel xml:lang="en">Florins</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Originally gold coins issued in Florence, but later used for various coins issued on the continent. In modern Britain, the two shilling piece.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/111793"/>
