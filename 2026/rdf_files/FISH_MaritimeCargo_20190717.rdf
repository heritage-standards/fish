    <skos:scopeNote xml:lang="en">A colourless, thick sweet liquid used in the manufacture of chemicals.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79106">
