        <skos:prefLabel xml:lang="en">Shingle</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Small stones which have been rounded usually by the action of sea water.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

