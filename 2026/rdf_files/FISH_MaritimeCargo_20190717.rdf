        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Farm Machinery</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Machinery including tractors, ploughs, harrows etc, which are used on farms.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/143250">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79072"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
