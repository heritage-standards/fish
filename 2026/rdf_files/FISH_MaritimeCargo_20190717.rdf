        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79161</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Rubbish</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Waste material.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79045">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/110934"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79045</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Industrial Waste</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Waste material resulting from industrial manufacturing processes.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79184">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/110934"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79184</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Sludge</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Mud, which has often been dredged from the beds of rivers.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84509">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/110934"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/84509</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Sewage</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Waste matter, usually liquid in form, consisting of the contents of sewers and cesspits.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/86296">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/110934"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/86296</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Clinker</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Usually slag, a residue from burning stone, but can be used for vitrified bricks.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/110934</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Fertilizer And Waste</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Includes chemical and natural fertilizers and waste products. use more specific term.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/86172">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79207"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/86172</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Yarn</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Threads prepared for use in a manufacturing process such as spinning, weaving etc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79207">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/86172"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84133">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79207"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/84133</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Lace</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An ornate, openwork fabric made by twisting, knotting or looping threads. Originally made by hand but more recently manufactured mechanically.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/111673"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/111693"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79207</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Textiles And Clothing</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Clothing, cloth and woven fabric manufactured from either natural or artificial fibres.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83197">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/140472"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83197</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Cochineal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A red dye made from the dried bodies of the insect Dactylopius coccus.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/140472">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83197"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/84371"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/142049"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/140472</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Pigment</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Colour or dye, often in powder form, from natural mineral or vegetable sources (e.g. ochre) or created through chemical process (e.g. lamp black).</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83395">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79150"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83395</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Railway Sleepers</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Large blocks of timber used to support railway tracks.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79150">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83395"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/82998">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79150"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/82998</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Railway Track</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Rolled iron or steel formed into rails.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79157"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79150</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Railway Components</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Equipment and parts used in the manufacture of railway tracks, locomotives and rolling stock.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/109213">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/86416"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79081">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109213"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79081</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Masts</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Long poles or spars, usually set vertically, on sailing boats and ships to support the sails.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83135">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109213"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83135</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Anchors</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Structures, traditonally consisting of a long shank with two arms at one end and a ring to attach to cable at the other, used to hold a ship in one place by mooring it to the bottom of the sea. Usually made of stone or metal.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/109213</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Ship Fittings</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Materials used to equip and fit out a ship. Includes masts, spars, rigging etc. Use only where evidence is less specific, otherwise use most relevant term.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83680">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79002"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83680</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Whiting</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Small fish, common in European waters, caught for food.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79002">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83680"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79066">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79002"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79066</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Live Fish</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fish which have been caught and kept alive. Fish were kept alive on ships in earlier centuries to ensure they reached their destination as fresh as possible. In more recent times exotic fish have been kept alive to sell as pets.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79036">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79002"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79036</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Herring</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fish of the family Clupeidae, common to the North Atlantic. They are caught for food.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78959">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79002"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78959</dc:identifier>
