        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">White Spirit</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A volatile, colourless distillate of petroleum used as a solvent and paint thinner.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

