        <skos:prefLabel xml:lang="en">Sturne</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Unfermented wine.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
