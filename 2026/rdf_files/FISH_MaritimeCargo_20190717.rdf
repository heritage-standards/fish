        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Pitch</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A dark, viscous substance obtained, from the distillation of wood tar or turpentine, and used as a sealant for caulking the seams of a ship or boat.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
