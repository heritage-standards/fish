    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141334"/>
    <skos:scopeNote xml:lang="en">Personal apparatus for telling the time, worn either as jewellery or purely functional in nature, usually on the wrist or as a suspended fob.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/143241">
