        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Gin</skos:prefLabel>
        <skos:scopeNote xml:lang="en">An alcoholic beverage distilled from grain or malt and usually flavoured with juniper berries.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78919">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/87148"/>
