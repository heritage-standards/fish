        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Mercury</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A heavy, metallic element, which is liquid at room temperature. Used in thermometers and medicinal preparations.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/82905"/>
