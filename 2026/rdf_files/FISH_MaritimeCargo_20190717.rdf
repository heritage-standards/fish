        <skos:scopeNote xml:lang="en">A flammable liquid that occurs naturally and is also now distilled.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79203">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79106"/>
