    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Animal Fodder</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Food, usually hay or straw, kept for the feeding of animals.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/143377">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79086"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/143377</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Armour</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Protective equipment, usually made of metal, to protect parts of the body, e.g. helmets, breastplates, or full suits of armour, to protect troops or individuals in warfare. Most examples date from the Middle Ages, obsolete from the 17th century.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141334">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
