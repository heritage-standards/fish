  <skos:ConceptScheme rdf:about="http://purl.org/heritagedata/schemes/77">
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2021-11-19</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77</dc:identifier>
    <dc:title xml:lang="en">FISH Maritime Cargo Types Thesaurus</dc:title>
    <dc:description xml:lang="en">Used to record the type of cargo being carried by a vessel on its final voyage and often found in association with the wreck site.</dc:description>
    <skos:hasTopConcept rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
  </skos:ConceptScheme>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84146">
    <skos:altLabel xml:lang="en">Wire Cable</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83100"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/84146</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Wire</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Thin rods or threads of metal formed by rolling or wire-drawing and used for a variety of purposes including electrical circuitry.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/87450">
    <skos:altLabel xml:lang="en">Wire Cable</skos:altLabel>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84537">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/87450"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
