        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Arrowroot</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A pure starch obtained from the tubers of the plant Maranta arundinacea used in cookery as a thickening agent.</skos:scopeNote>
      </skos:Concept>
