    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78904">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78906"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78904</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Barrel Hoops</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Metal hoops used to hold the staves of barrels in position.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78905">
        <skos:altLabel xml:lang="en">Pipe Staves</skos:altLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78906"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78905</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Barrel Staves</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Pieces of wood used to form the sides of barrels.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78906</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Barrels</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Containers of cylindrical form, traditionally made of curved wooden staves bound together by hoops of metal. Also includes modern plastic and metal barrels.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/118633">
    <skos:altLabel xml:lang="en">Coal Patent Fuel</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78951"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/118633</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Patent Fuel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A mixture of coals that have been formed into briquettes or blocks. This fuel took its name from the fact that it was under patent in the late nineteenth century.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/82915">
    <skos:altLabel xml:lang="en">Elephant Teeth</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78891"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78991">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/82915"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78991</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Elephant Tusks</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The large, pointed teeth, made of ivory, which are specially developed to protrude from the mouth of elephants.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/82915</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Ivory</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109033"/>
    <skos:scopeNote xml:lang="en">A highly-prized, hard, white, fine-grained dentine constituting the main part of the teeth of walruses, hippopotami and elephants. Used in the manufacture of ornaments and piano keys.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/111793">
    <skos:altLabel xml:lang="en">Gold Specie</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78961"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/111793</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Gold Coin</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Gold fashioned into coins for use as currency.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/109033">
    <skos:altLabel xml:lang="en">Horns</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78891"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/109033</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Animal Horn</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/82915"/>
    <skos:scopeNote xml:lang="en">The bony outgrowths found on the heads of mammals used for display or combat used for a variety of purposes.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79069">
    <skos:altLabel xml:lang="en">Log Wood</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83222"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79069</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Logwood</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The heartwood of a leguminous tree from which an extract is obtained. The extract being used for dyeing.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79086">
    <skos:altLabel xml:lang="en">Military Stores</skos:altLabel>
    <skos:altLabel xml:lang="en">Ordnance</skos:altLabel>
    <skos:altLabel xml:lang="en">Ordnance Stores</skos:altLabel>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79089"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79219"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141502"/>
