        <skos:prefLabel xml:lang="en">Dynamite</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A high explosive, manufactured by absorbing unstable nitroglycerine in a material such as kieselguhr, a soft, earthy material.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79094">
