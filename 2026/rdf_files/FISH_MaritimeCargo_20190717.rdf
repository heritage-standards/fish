    <skos:prefLabel xml:lang="en">People</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Human beings. Use more specific type where known.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79191">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109193"/>
