    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Telescopes</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141506"/>
    <skos:scopeNote xml:lang="en">Optical and/or navigational instruments with powerful lenses for observing remote objects or used in astronomy.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78928">
