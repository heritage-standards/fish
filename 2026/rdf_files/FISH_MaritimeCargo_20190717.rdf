        <skos:prefLabel xml:lang="en">Bottled Goods</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Goods, usually foodstuffs, preserved in glass bottles, jars, etc. Examples are bottled fruit, pickled onions, jam, honey.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/84252"/>
