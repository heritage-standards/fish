        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Cement</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Powder mixed with water and applied as a paste for binding stones and bricks or for forming floors, walls etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/152310">
