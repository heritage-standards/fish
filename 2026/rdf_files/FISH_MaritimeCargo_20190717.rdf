        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Cloves</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Dried flower buds, used as a pungent aromatic spice.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79191</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Spices</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Aromatic vegetable substances, either in their natural form or ground, used to add flavour or scent to food.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/109193">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79191"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109194"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79009"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
