        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Iron Bars</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Iron, usually unworked, in the form of bars.</skos:scopeNote>
