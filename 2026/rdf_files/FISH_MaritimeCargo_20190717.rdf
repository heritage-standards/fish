        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Preserves</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Traditionally any food preserved by boiling with sugar, salting, pickling etc. Nowadays used specifically for fruit which has been preserved with sugar.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78921">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79009"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78921</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Bread</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A staple foodstuff made with flour, water and usually yeast, which is kneaded and then baked. Can include unleavened (no yeast)  varieties.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/168109">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79009"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
