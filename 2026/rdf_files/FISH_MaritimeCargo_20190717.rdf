        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Nickel</skos:prefLabel>
        <skos:scopeNote xml:lang="en">a hard metal used in a lot of alloys.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79192"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141504">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79085"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
