    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Emigrants</skos:prefLabel>
    <skos:scopeNote xml:lang="en">People who leave their native country to settle in another, often for financial or religious reasons.</skos:scopeNote>
  </skos:Concept>

