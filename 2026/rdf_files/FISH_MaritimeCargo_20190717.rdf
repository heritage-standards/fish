    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Iron</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79192"/>
    <skos:scopeNote xml:lang="en">A magnetic metal found abundantly in certain ores and widely used for the manufacture of tools, machinery etc. Iron is also a chief component of  steel.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79085">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79046"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78967"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/85380">
