        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Coffee</skos:prefLabel>
        <skos:scopeNote xml:lang="en">The beans, or powder resulting from grinding the beans, of shrubs of the genus Coffea. The powder is used to make the drink Coffee.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

