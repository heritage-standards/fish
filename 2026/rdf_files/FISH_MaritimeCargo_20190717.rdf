    <skos:prefLabel xml:lang="en">Meat</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The flesh of animals, either raw or cooked, used as food.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79125">
