        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Pickled Salmon</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Salmon which has been pickled in vinegar or brine to preserve it.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/142096</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Salmon</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Fish of the Salmonidae family, caught for food.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/145061">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79134"/>
