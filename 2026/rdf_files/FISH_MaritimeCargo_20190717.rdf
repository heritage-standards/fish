        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Corrugated Iron</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Sheets of iron or steel bent into a series of ridges and hollows to give added strength and rigidity.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

