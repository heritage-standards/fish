    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Salted Mackerel</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Mackerel which has been salted to preserve it.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/170005">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/85407"/>
