        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Pig Iron</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Blocks of cast iron as it appears when first removed from the smelting furnace.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

