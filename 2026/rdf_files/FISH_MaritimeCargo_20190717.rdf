    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Spices And Seasonings</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Various flavoured aromatic and savoury substances, such as herbs, salt etc, used to impart flavour to food.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79199">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79097"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79199</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Swords</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Weapons used for cutting and thrusting, consisting of a blade and a hilt.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79097">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79199"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79032"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78889"/>
