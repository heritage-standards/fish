        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/78920</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Brass</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Originally a metallic alloy of copper and tin or zinc, now used solely for an alloy of copper and zinc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79085</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Metal</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any material, including gold, silver, copper, tin etc. which is ductile, malleable, usually lustrous and a good conductor of heat and electricity.</skos:scopeNote>
  </skos:Concept>

