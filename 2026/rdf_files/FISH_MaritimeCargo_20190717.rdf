    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Fire Bricks</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Bricks capable of withstanding heat without burning. Used to line fireplaces, kilns etc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78964">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/82910"/>
