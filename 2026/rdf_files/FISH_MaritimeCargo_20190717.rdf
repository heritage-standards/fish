        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Scrap Metal</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Fragments of metal broken up and set aside for reprocessing.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79056"/>
