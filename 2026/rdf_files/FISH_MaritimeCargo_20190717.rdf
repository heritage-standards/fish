    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Landing Craft</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Inshore craft used for carrying troops and military equipment used either for beach landings or as a ferry; as cargo smaller landing craft could be carried aboard larger craft in the D-Day operations, for example.</skos:scopeNote>
  </skos:Concept>

