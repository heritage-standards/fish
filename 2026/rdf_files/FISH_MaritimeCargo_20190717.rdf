    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Fruit</skos:prefLabel>
    <skos:scopeNote xml:lang="en">The edible product of a plant, usually consisting of the seed and its sweet, juicy envelope.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79007">
