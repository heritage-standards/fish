        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Mining Machinery</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Machinery, e.g. drive wheels, used in powering and excavating mines, i.e. mines for the extraction of minerals such as coal, lead or tin.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
