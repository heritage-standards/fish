    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Bombs</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Containers filled with high explosive, which can be fired from artillery pieces, thrown, dropped by aircraft or placed by hand and detonated in various ways.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78994">
