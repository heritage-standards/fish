    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Jewellery</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141916"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141902"/>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/145060"/>
    <skos:scopeNote xml:lang="en">Intended for personal decoration, objects made of precious, semi-precious or imitation metals and gemstones.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/143178">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79093"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/83931"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/143178</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Fullers Earth</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Sedimentary clay with smectite mineral properties, originally used for the cleansing [&quot;fulling&quot;] of cloth; in the 20th century it was used for a wider range of industrial applications.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79201">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78891"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79201</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Tallow</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78914"/>
    <skos:scopeNote xml:lang="en">A fatty substance rendered from animal fat and used in the manufacture of soap, candles and for dressing leather.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/142096">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79002"/>
