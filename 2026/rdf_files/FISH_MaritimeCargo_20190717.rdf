        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Mines</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Explosive devices, usually of metal, placed in the ground or floating in water with the purpose of endangering enemy personnel or shipping.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79031">
