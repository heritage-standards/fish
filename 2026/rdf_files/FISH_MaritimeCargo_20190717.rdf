    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Bulldozers</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Heavy caterpillar tractors fitted with broad blades to the front for moving or levelling earth and obstacles.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79222">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/159169"/>
    <skos:narrower>
