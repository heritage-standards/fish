        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Calico</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Plain, white, cotton cloth often unbleached.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79179">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/111673"/>
