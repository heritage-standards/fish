        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Tiles</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Shaped material used for covering buildings, usually as a roofing material though can be used on walls or floors. Often of fired clay they can be of other materials particularly stone.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84124">
