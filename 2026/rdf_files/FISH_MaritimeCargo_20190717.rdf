    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Nitrate</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A fertilizer containing nitrogen.</skos:scopeNote>
  </skos:Concept>

