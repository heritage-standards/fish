    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/142093"/>
    <skos:scopeNote xml:lang="en">A herbaceous plant grown for its fibre and marijuana, a drug derivative. The fibres are used in the manufacture of rope.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/78993">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109153"/>
