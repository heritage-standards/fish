        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Pyrites</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Traditionally a mineral that could be used for striking fire but now a term commonly used to refer to various sulphides, especially iron disulphide.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84373">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79093"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
