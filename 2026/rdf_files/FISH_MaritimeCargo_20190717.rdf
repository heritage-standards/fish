    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">General Cargo</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Use for cargoes which are not specified.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/159169">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79222"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
