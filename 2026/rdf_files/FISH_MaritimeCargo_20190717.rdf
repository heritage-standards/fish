    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Dress Accessories</skos:prefLabel>
    <skos:related rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141334"/>
    <skos:scopeNote xml:lang="en">Items worn or carried as an adjunct to clothing, for example, headdresses, sashes, fans, masks etc.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/152635">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/152634"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/152635</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Tank Components</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Machinery and parts for the manufacture or assembly of military tanks, i.e. armoured vehicles.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/152634">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/152635"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79089"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
