        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Gunpowder</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A powder made from charcoal, sulphur and potassium nitrate and used as an explosive in fireworks, flintlock guns etc.</skos:scopeNote>
      </skos:Concept>
