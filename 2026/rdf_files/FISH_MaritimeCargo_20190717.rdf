        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Port Wine</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A strong, sweet fortified wine made in Portugal.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/85636">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79229"/>
