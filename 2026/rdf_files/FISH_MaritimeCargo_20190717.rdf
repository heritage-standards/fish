    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Petroleum</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A dark, viscous liquid, obtained from the ground, which is refined for use as a fuel for motor vehicles and in generators to produce light and heat, and as a solvent.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79183">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79123"/>
