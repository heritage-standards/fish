    <skos:prefLabel xml:lang="en">Sulphates</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A sulphuric acid compound.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79157">
