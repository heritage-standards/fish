        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Manganese</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A hard metallic element used in steels and magnetic alloys. Compounds containing manganese are used in glass-making and other industrial processes.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/87433">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79093"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
