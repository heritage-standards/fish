    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Textiles</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Threads of material used to form cloth.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/82910">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78964"/>
