        <skos:prefLabel xml:lang="en">Hops</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Conelike spikes of the hop plant used in the brewing industry to give a bitter flavour to beer and malt liquors.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/88460"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78981"/>
