        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Fishing Gear</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Equipment used to catch fish</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79140">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79140</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Porcelain</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Hard semi-translucent ceramic material made out of kaolin, quartz and feldspar which is biscuit fired at around 1000 degrees Celsius and glaze fired at around 1300 degrees Celsius.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79214"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/145060"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/87291">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/87291</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Navigation Buoys</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Buoys used to direct craft on water along the correct route or away from a hazard. Usually used in coastal areas.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/88465">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/88465</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Perfume</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A substance designed to emit a sweet smell.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79072"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141506"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79222"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84274">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/84274</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Diving Equipment</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Equipment including diving suits, wet suits, oxygen tanks etc. used to enable people to undertake underwater activities.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141902"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/159341"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/84532">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/84532</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Springs</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Coiled substance, usually metal or plastic, used to absorb shocks or in timepieces since it can stretch and return to its original shape.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141503"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/159342">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/159342</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Beads</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Articles intended for personal adornment, usually to be strung on items of jewellery or sewn onto clothing. They may be made out of worked raw materials (eg. shells) or be manufactured goods, for example glass beads.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83959">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83959</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Fireworks</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Explosive devices which produce spectacular visual effects when ignited.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/83449">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/83449</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Chain</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A series of links joined together to form something that is flexible and strong. Usually metal, chains have a variety of uses but usually involve joining one item to another.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/143377"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141334"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/88466">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/88466</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Glassware</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Articles, particularly drinking vessels, manufactured from glass.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/79117">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/79117</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Paint</skos:prefLabel>
        <skos:scopeNote xml:lang="en">A liquid used to provide a protective or decorative cover to a surface.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141857">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/141857</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Cosmetics</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Preparations for beautifying or enhancing the body, face, hair or skin, e.g. creams, and coloured &quot;make-up&quot; items, e.g. rouge, lipstick, etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/160446"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/139769"/>
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/142093"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/159340">
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
        <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/159340</dc:identifier>
        <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:prefLabel xml:lang="en">Horse Tack</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Equipment enabling a horse to be ridden or driven, eg. saddles, bridles, harnesses, stirrups etc.</skos:scopeNote>
      </skos:Concept>
    </skos:narrower>

    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/78933"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/109313</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Manufactured Goods</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Items that have been through a manufacturing process. Use specific type where known.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/87415">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141331"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79196"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/87415</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Stone Blocks</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Worked pieces of stone. Use more specific type of stone where known.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141502">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109313"/>
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/79086"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/141502</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Weapons</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Any form of arms or ammunition whether from a formal organized military context or as a general cargo. Use specific terms - e.g. swords, bombs, where known; otherwise use this term primarily in contexts where the arms are unspecified or ancient.</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/141885">
    <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/109133"/>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/77"/>
    <dc:identifier>http://purl.org/heritagedata/schemes/77/concepts/141885</dc:identifier>
    <dc:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2021-11-19T14:33:00</dc:issued>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dc:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:prefLabel xml:lang="en">Stationery</skos:prefLabel>
    <skos:scopeNote xml:lang="en">Paper products intended for note-taking or correspondence, e.g. blank notebooks, diaries, writing paper, postcards</skos:scopeNote>
  </skos:Concept>

  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/77/concepts/109133">
    <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/77/concepts/141885"/>
