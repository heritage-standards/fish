  <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/70/concepts/82836">
    <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-29T09:37:25</dcterms:issued>
    <skos:broader>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/70/concepts/159223">
        <skos:narrower rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/82836"/>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-29T09:37:25</dcterms:issued>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
        <skos:prefLabel xml:lang="en">External Combustion Engine</skos:prefLabel>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/139068"/>
        <skos:scopeNote xml:lang="en">A heat engine where an (internal) working fluid is heated by combustion of an external source, through the engine wall or a heat exchanger.</skos:scopeNote>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/70/concepts/159223</dcterms:identifier>
      </skos:Concept>
    </skos:broader>
    <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/70/concepts/159228">
        <dcterms:identifier>http://purl.org/heritagedata/schemes/70/concepts/159228</dcterms:identifier>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-29T09:37:25</dcterms:issued>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/82836"/>
        <skos:scopeNote xml:lang="en">A type of steam engine where the steam is first expanded in a high-pressure cylinder, then having given up heat and losing pressure, it exhausts directly into one or more larger volume low-pressure cylinders.</skos:scopeNote>
        <skos:prefLabel xml:lang="en">Compound Engine</skos:prefLabel>
      </skos:Concept>
    </skos:narrower>
    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
    <dcterms:identifier>http://purl.org/heritagedata/schemes/70/concepts/82836</dcterms:identifier>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/70/concepts/159229">
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
        <skos:prefLabel xml:lang="en">Triple Expansion Engine</skos:prefLabel>
        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/82836"/>
        <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
        <skos:scopeNote xml:lang="en">A steam engine that uses three expansion stages of progressively lower pressure, to extract further energy from the steam.</skos:scopeNote>
        <cc:attributionURL rdf:resource="http://www.historicengland.org.uk"/>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/70/concepts/159229</dcterms:identifier>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-29T09:37:25</dcterms:issued>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
      </skos:Concept>
    </skos:narrower>
    <skos:prefLabel xml:lang="en">Steam</skos:prefLabel>
    <skos:scopeNote xml:lang="en">A watercraft powered by a marine steam engine. Use also for a vessel employing a steam engine as its principle source of motive power.</skos:scopeNote>
  </skos:Concept>
