        <cc:attributionName xml:lang="en">Historic England</cc:attributionName>
        <skos:scopeNote xml:lang="en">An engine that extracts thermal energy from pressurized steam, and converts it into rotary motion.</skos:scopeNote>
        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
      </skos:Concept>
    </skos:narrower>
    <skos:narrower>
      <skos:Concept rdf:about="http://purl.org/heritagedata/schemes/70/concepts/139069">
        <skos:scopeNote xml:lang="en">An aircraft propelled by jet engines, which provide forward thrust by pulling in air, heating and compressing it, then expelling it along with exhaust gasses.</skos:scopeNote>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/79237"/>
