        <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/70"/>
        <skos:prefLabel xml:lang="en">Jet Engine</skos:prefLabel>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2020-09-29T09:37:25</dcterms:issued>
        <dcterms:identifier>http://purl.org/heritagedata/schemes/70/concepts/139069</dcterms:identifier>
        <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
        <skos:broader rdf:resource="http://purl.org/heritagedata/schemes/70/concepts/159225"/>
      </skos:Concept>
    </skos:narrower>
