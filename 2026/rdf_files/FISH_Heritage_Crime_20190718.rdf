    <skos:inScheme rdf:resource="http://purl.org/heritagedata/schemes/596"/>
    <skos:scopeNote xml:lang="en">The intentional touching of another in a sexual manner where the perpetrator does not believe that the other party consents to their actions. Created by section 3 of the Sexual Offences Act 2003.</skos:scopeNote>
