    <cc:license rdf:resource="http://creativecommons.org/licenses/by/3.0"/>
    <dcterms:publisher rdf:resource="http://www.historicengland.org.uk"/>
    <skos:scopeNote xml:lang="en">Groups of people who meet to perform group sex. Such activity can occur amongst people of all sexual orientations and genders. Group sex may take place in public for example, at nude beaches, secluded heritage assets or outdoor events or nightclubs.</skos:scopeNote>
